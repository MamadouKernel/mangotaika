@model List<ActualiteDto>
@{
    ViewData["Title"] = "Actualités";
}

<div class="container py-5">
    <h2 class="section-title text-center mb-1"><i class="bi bi-newspaper text-or"></i> <span class="accent">Actualités</span></h2>
    <p class="text-center text-muted-custom mb-4">Les dernières nouvelles du District MANGO TAÏKA</p>
    <div class="section-divider mx-auto mb-4"></div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-newspaper" style="font-size:3rem;opacity:0.3;"></i>
            <p class="text-muted-custom mt-2">Aucune actualité pour le moment.</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var a in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card-3d h-100" style="cursor:pointer;" onclick="location.href='@Url.Action("Details", new { id = a.Id })'">
                        @if (!string.IsNullOrEmpty(a.ImageUrl))
                        {
                            <img src="@a.ImageUrl" alt="@a.Titre" style="width:100%;height:200px;object-fit:cover;border-radius:18px 18px 0 0;" />
                        }
                        else
                        {
                            <div style="width:100%;height:200px;background:rgba(89,117,55,0.12);border-radius:18px 18px 0 0;display:flex;align-items:center;justify-content:center;">
                                <i class="bi bi-newspaper" style="font-size:3rem;opacity:0.3;"></i>
                            </div>
                        }
                        <div class="p-3">
                            <small class="text-muted-custom"><i class="bi bi-calendar3"></i> @a.DatePublication.ToString("dd MMMM yyyy")</small>
                            <h5 class="mt-2 mb-2" style="color:var(--vert);">@a.Titre</h5>
                            <p class="text-muted-custom small mb-0">@(a.Resume ?? (a.Contenu.Length > 150 ? a.Contenu[..150] + "..." : a.Contenu))</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
