@model List<ActualiteDto>
@{
    ViewData["Title"] = "Gestion des actualites";
    Layout = "_LayoutAdmin";
    var canManage = User.IsInRole("Administrateur") || User.IsInRole("Gestionnaire");
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="section-title mb-0"><i class="bi bi-newspaper text-or"></i> <span class="accent">Actualites</span></h2>
    @if (canManage)
    {
        <a asp-action="Create" class="btn btn-mango"><i class="bi bi-plus-lg"></i> Nouvelle actualite</a>
    }
</div>

<div class="row g-4">
    @foreach (var a in Model)
    {
        <div class="col-lg-4 col-md-6">
            <div class="card-3d p-4 h-100 d-flex flex-column">
                <h5 class="text-or mb-2">@a.Titre</h5>
                <p class="text-muted-custom small mb-2">
                    @if (a.EstPublie)
                    {
                        <span class="badge-3d badge-validee">Publie</span>
                    }
                    else
                    {
                        <span class="badge-3d badge-brouillon">Brouillon</span>
                    }
                </p>
                <div class="d-flex flex-column gap-1 mb-3 flex-grow-1" style="font-size:0.85rem;">
                    <span><i class="bi bi-calendar3 text-bleu"></i> @a.DatePublication.ToString("dd/MM/yyyy")</span>
                    <span><i class="bi bi-person text-or"></i> @(a.NomCreateur ?? "-")</span>
                </div>
                <div class="d-flex flex-wrap gap-2 mt-auto">
                    <a asp-action="Details" asp-route-id="@a.Id" class="btn btn-sm btn-outline-or" title="Voir"><i class="bi bi-eye"></i></a>
                    @if (canManage)
                    {
                        <a asp-action="Edit" asp-route-id="@a.Id" class="btn btn-sm btn-bleu" title="Modifier"><i class="bi bi-pencil"></i></a>
                        @if (!a.EstPublie)
                        {
                            <form asp-action="Publier" asp-route-id="@a.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm" style="background:rgba(16,185,129,0.2);color:#34d399;border:1px solid rgba(16,185,129,0.3);border-radius:14px;" title="Publier">
                                    <i class="bi bi-send"></i>
                                </button>
                            </form>
                        }
                        else
                        {
                            <form asp-action="Depublier" asp-route-id="@a.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm" style="background:rgba(234,179,8,0.2);color:#ca8a04;border:1px solid rgba(234,179,8,0.3);border-radius:14px;" title="Depublier">
                                    <i class="bi bi-eye-slash"></i>
                                </button>
                            </form>
                        }
                        <form asp-action="Delete" asp-route-id="@a.Id" method="post" class="d-inline" onsubmit="return confirm('Supprimer cette actualite ?')">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm" style="background:rgba(239,68,68,0.15);color:#f87171;border:1px solid rgba(239,68,68,0.3);border-radius:14px;" title="Supprimer">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                    }
                </div>
            </div>
        </div>
    }
</div>

<partial name="_ListPagination" />
