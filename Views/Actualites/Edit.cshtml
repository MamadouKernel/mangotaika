@model ActualiteDto
@{
    ViewData["Title"] = "Modifier l'actualité";
    Layout = "_LayoutAdmin";
}

<h2 class="section-title mb-1"><i class="bi bi-pencil text-or"></i> Modifier <span class="accent">@Model.Titre</span></h2>
<div class="section-divider"></div>

<div class="card-3d p-4 mt-3">
    <form asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data" class="form-modern">
        <div class="mb-3">
            <label class="form-label">Titre</label>
            <input name="Titre" class="form-control" value="@Model.Titre" required />
        </div>
        <div class="mb-3">
            <label class="form-label">Résumé (optionnel)</label>
            <input name="Resume" class="form-control" value="@Model.Resume" maxlength="300" />
        </div>
        <div class="mb-3">
            <label class="form-label">Contenu</label>
            <textarea name="Contenu" class="form-control" rows="10" required>@Model.Contenu</textarea>
        </div>
        <div class="mb-3">
            <label class="form-label">Image (laisser vide pour garder l'actuelle)</label>
            <input name="Image" class="form-control" type="file" accept="image/*" onchange="previewImg(this)" />
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" class="mt-2" style="max-height:200px;border-radius:14px;" alt="Image actuelle" />
            }
            <img id="imgPreview" class="mt-2" style="max-height:200px;border-radius:14px;display:none;" alt="Aperçu" />
        </div>
        <div class="d-flex gap-2 mt-2">
            <button type="submit" class="btn btn-mango" title="Enregistrer"><i class="bi bi-check-lg"></i></button>
            <a asp-action="Admin" class="btn btn-outline-or" title="Annuler"><i class="bi bi-x-lg"></i></a>
        </div>
    </form>
</div>

@section Scripts {
<script>
function previewImg(input) {
    const preview = document.getElementById('imgPreview');
    if (input.files && input.files[0]) {
        const reader = new FileReader();
        reader.onload = e => { preview.src = e.target.result; preview.style.display = 'block'; };
        reader.readAsDataURL(input.files[0]);
    } else { preview.style.display = 'none'; }
}
</script>
}
