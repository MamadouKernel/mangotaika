@model ContactMessage
@{
    ViewData["Title"] = "Message";
    Layout = "_LayoutAdmin";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
    <h2 class="section-title mb-0"><i class="bi bi-envelope-open text-or"></i> @Model.Sujet</h2>
    <a asp-action="Index" asp-route-type="@Model.Type" class="btn btn-outline-or btn-sm" title="Liste"><i class="bi bi-arrow-left"></i></a>
</div>

<div class="card-3d p-4">
    <p class="mb-2">
        <span class="badge-3d @(Model.Type == "Avis" ? "badge-archivee" : "badge-soumise")">@Model.Type</span>
        @if (!Model.EstLu)
        {
            <span class="badge-3d badge-validee ms-1">Non lu</span>
        }
    </p>
    <p class="text-muted-custom small mb-3">@Model.DateEnvoi.ToString("dd/MM/yyyy HH:mm")</p>
    <dl class="row mb-4 small">
        <dt class="col-sm-2 text-muted-custom">Nom</dt>
        <dd class="col-sm-10">@Model.Nom</dd>
        <dt class="col-sm-2 text-muted-custom">E-mail</dt>
        <dd class="col-sm-10"><a href="mailto:@Model.Email">@Model.Email</a></dd>
    </dl>
    <h6 class="text-or mb-2">Message</h6>
    <p class="text-muted-custom mb-4" style="white-space:pre-wrap;line-height:1.7;">@Model.Message</p>

    <div class="d-flex flex-wrap gap-2">
        @if (!Model.EstLu)
        {
            <form asp-action="MarquerLu" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-or btn-sm" title="Marquer lu"><i class="bi bi-check2"></i></button>
            </form>
        }
        <form asp-action="Supprimer" asp-route-id="@Model.Id" method="post" class="d-inline" onsubmit="return confirm('Supprimer ce message ?')">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-sm" style="background:rgba(239,68,68,0.2);color:#f87171;border:1px solid rgba(239,68,68,0.3);border-radius:14px;" title="Supprimer">
                <i class="bi bi-trash"></i>
            </button>
        </form>
    </div>
</div>
