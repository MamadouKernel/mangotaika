@model MotCommissaire
@{
    ViewData["Title"] = "Mot du Commissaire";
    Layout = "_LayoutAdmin";
    var canManage = User.IsInRole("Administrateur") || User.IsInRole("Gestionnaire");
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
    <h2 class="section-title mb-0"><i class="bi bi-megaphone-fill text-or"></i> Annee @Model.Annee</h2>
    <div class="d-flex flex-wrap gap-2">
        @if (canManage)
        {
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-bleu btn-sm" title="Modifier"><i class="bi bi-pencil"></i></a>
        }
        <a asp-action="Index" class="btn btn-outline-or btn-sm" title="Liste"><i class="bi bi-arrow-left"></i></a>
    </div>
</div>

<div class="card-3d p-4">
    <span class="badge-3d @(Model.EstActif ? "badge-validee" : "badge-rejetee")">@(Model.EstActif ? "Actif" : "Inactif")</span>
    <p class="text-muted-custom small mt-3 mb-0" style="white-space:pre-wrap;">@Model.Contenu</p>
</div>
