@model ScoutDto
@{
    ViewData["Title"] = "Modifier scout";
    Layout = "_LayoutAdmin";
    var groupes = ViewBag.Groupes as List<MangoTaika.Data.Entities.Groupe> ?? new();
    var branches = ViewBag.Branches as List<MangoTaika.Data.Entities.Branche> ?? new();
}

<h2 class="section-title mb-1"><i class="bi bi-pencil-fill text-or"></i> Modifier le <span class="accent">scout</span></h2>
<div class="section-divider"></div>

<div class="card-3d p-4 mt-3">
    <form asp-action="Edit" asp-route-id="@Model.Id" method="post" class="form-modern">
        <div class="mb-3">
            <label class="form-label">Matricule</label>
            <input name="Matricule" class="form-control" value="@Model.Matricule" />
        </div>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Nom</label>
                <input name="Nom" class="form-control" value="@Model.Nom" />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">Prénom</label>
                <input name="Prenom" class="form-control" value="@Model.Prenom" />
            </div>
        </div>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Date de naissance</label>
                <input name="DateNaissance" class="form-control" type="date" value="@Model.DateNaissance.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">Sexe</label>
                <select name="Sexe" class="form-select">
                    <option value="M" selected="@(Model.Sexe == "M")">Masculin</option>
                    <option value="F" selected="@(Model.Sexe == "F")">Féminin</option>
                </select>
            </div>
        </div>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Téléphone</label>
                <input name="Telephone" class="form-control" value="@Model.Telephone" />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">Email</label>
                <input name="Email" class="form-control" type="email" value="@Model.Email" />
            </div>
        </div>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Région Scoute</label>
                <input name="RegionScoute" class="form-control" value="@Model.RegionScoute" placeholder="Ex: ABIDJAN" />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">District</label>
                <input name="District" class="form-control" value="@Model.District" placeholder="Ex: Requin Féroce" />
            </div>
        </div>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">N° Carte</label>
                <input name="NumeroCarte" class="form-control" value="@Model.NumeroCarte" placeholder="Ex: 052026-69184" />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">Fonction</label>
                <input name="Fonction" class="form-control" value="@Model.Fonction" placeholder="Ex: LOUVETEAU (8 - 11 ANS)" />
            </div>
        </div>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Adresse géographique</label>
                <input name="AdresseGeographique" class="form-control" value="@Model.AdresseGeographique" placeholder="Ex: Cocody Riviera Palmeraie" />
            </div>
            <div class="col-md-6 mb-3 d-flex align-items-center pt-4">
                <div class="form-check form-switch">
                    <input name="AssuranceAnnuelle" class="form-check-input" type="checkbox" value="true" @(Model.AssuranceAnnuelle ? "checked" : "") />
                    <label class="form-check-label">Assurance annuelle à jour</label>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Groupe</label>
                <select name="GroupeId" id="GroupeId" class="form-select">
                    <option value="">-- Choisir un groupe --</option>
                    @foreach (var g in groupes)
                    {
                        <option value="@g.Id" selected="@(Model.GroupeId == g.Id)">@g.Nom</option>
                    }
                </select>
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">Branche</label>
                <select name="BrancheId" id="brancheSelect" class="form-select" data-current="@Model.BrancheId">
                    <option value="">-- Choisir une branche --</option>
                </select>
            </div>
        </div>
        <div class="d-flex gap-2 mt-2">
            <button type="submit" class="btn btn-mango" title="Mettre à jour"><i class="bi bi-check-lg"></i></button>
            <a asp-action="Index" class="btn btn-outline-or" title="Annuler"><i class="bi bi-x-lg"></i></a>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        function loadBranches(groupeId, selectedId) {
            var brancheSelect = document.getElementById('brancheSelect');
            if (!groupeId) {
                brancheSelect.innerHTML = '<option value="">-- Choisir d\'abord un groupe --</option>';
                return;
            }
            brancheSelect.innerHTML = '<option value="">Chargement...</option>';
            fetch('/Scouts/GetBranchesByGroupe?groupeId=' + groupeId)
                .then(r => r.json())
                .then(data => {
                    var html = '<option value="">-- Choisir une branche --</option>';
                    data.forEach(b => {
                        var sel = (selectedId && b.id == selectedId) ? ' selected' : '';
                        html += '<option value="' + b.id + '"' + sel + '>' + b.nom + ' (' + (b.ageMin || 0) + '-' + (b.ageMax || 99) + ' ans)</option>';
                    });
                    brancheSelect.innerHTML = html;
                });
        }
        document.getElementById('GroupeId').addEventListener('change', function () {
            loadBranches(this.value, null);
        });
        // Charger les branches au démarrage si un groupe est déjà sélectionné
        var initGroupe = document.getElementById('GroupeId').value;
        var initBranche = document.getElementById('brancheSelect').dataset.current;
        if (initGroupe) loadBranches(initGroupe, initBranche);
    </script>
}
