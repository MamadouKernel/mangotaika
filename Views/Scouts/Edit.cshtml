@model ScoutCreateDto
@using System.Text.Json
@{
    ViewData["Title"] = "Modifier scout";
    Layout = "_LayoutAdmin";
    var groupes = ViewBag.Groupes as List<MangoTaika.Data.Entities.Groupe> ?? new();
    var branches = ViewBag.Branches as List<MangoTaika.Data.Entities.Branche> ?? new();
    var routeId = ViewContext.RouteData.Values["id"];
    var selectedGroupeId = Model?.GroupeId;
    var selectedBrancheId = Model?.BrancheId;
    var initialBranches = selectedGroupeId.HasValue
        ? branches.Where(b => b.GroupeId == selectedGroupeId.Value).OrderBy(b => b.AgeMin).ThenBy(b => b.Nom).ToList()
        : new List<MangoTaika.Data.Entities.Branche>();
    var branchesPayload = branches
        .OrderBy(b => b.AgeMin)
        .ThenBy(b => b.Nom)
        .Select(b => new
        {
            id = b.Id,
            nom = b.Nom,
            ageMin = b.AgeMin,
            ageMax = b.AgeMax,
            groupeId = b.GroupeId
        })
        .ToList();
}

<h2 class="section-title mb-1"><i class="bi bi-pencil-fill text-or"></i> Modifier le <span class="accent">scout</span></h2>
<div class="section-divider"></div>

<div class="card-3d p-4 mt-3">
    <form asp-action="Edit" asp-route-id="@routeId" method="post" class="form-modern">
        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

        <div class="mb-3">
            <label asp-for="Matricule" class="form-label">Matricule</label>
            <input asp-for="Matricule" class="form-control" placeholder="Ex: 0583753X" />
            <span asp-validation-for="Matricule" class="text-danger small"></span>
            <small class="text-muted-custom">Format attendu : 0583753X.</small>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="Nom" class="form-label">Nom</label>
                <input asp-for="Nom" class="form-control" />
                <span asp-validation-for="Nom" class="text-danger small"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="Prenom" class="form-label">Prenom</label>
                <input asp-for="Prenom" class="form-control" />
                <span asp-validation-for="Prenom" class="text-danger small"></span>
            </div>
        </div>

        <div class="row">
            <div class="col-md-4 mb-3">
                <label asp-for="DateNaissance" class="form-label">Date de naissance</label>
                <input asp-for="DateNaissance" class="form-control" type="date" />
                <span asp-validation-for="DateNaissance" class="text-danger small"></span>
            </div>
            <div class="col-md-4 mb-3">
                <label asp-for="LieuNaissance" class="form-label">Lieu de naissance</label>
                <input asp-for="LieuNaissance" class="form-control" />
            </div>
            <div class="col-md-4 mb-3">
                <label asp-for="Sexe" class="form-label">Sexe</label>
                <select asp-for="Sexe" class="form-select">
                    <option value="">-- Choisir --</option>
                    <option value="M">Masculin</option>
                    <option value="F">Feminin</option>
                </select>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="Telephone" class="form-label">Telephone</label>
                <input asp-for="Telephone" class="form-control" />
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="Email" class="form-label">Email</label>
                <input asp-for="Email" class="form-control" type="email" />
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="RegionScoute" class="form-label">Region Scoute</label>
                <input asp-for="RegionScoute" class="form-control" placeholder="Ex: ABIDJAN" />
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="District" class="form-label">District</label>
                <input asp-for="District" class="form-control" placeholder="Ex: Requin Feroce" />
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="NumeroCarte" class="form-label">Numero de carte</label>
                <input asp-for="NumeroCarte" class="form-control" placeholder="Ex: ASCCI-001" />
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="Fonction" class="form-label">Fonction</label>
                <input asp-for="Fonction" class="form-control" placeholder="Ex: LOUVETEAU (8 - 11 ANS)" />
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="AdresseGeographique" class="form-label">Adresse geographique</label>
                <input asp-for="AdresseGeographique" class="form-control" placeholder="Ex: Cocody Riviera Palmeraie" />
            </div>
            <div class="col-md-6 mb-3 d-flex align-items-center pt-4">
                <div class="form-check form-switch">
                    <input asp-for="AssuranceAnnuelle" class="form-check-input" type="checkbox" />
                    <label asp-for="AssuranceAnnuelle" class="form-check-label">Assurance annuelle a jour</label>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="GroupeId" class="form-label">Groupe</label>
                <select asp-for="GroupeId" id="GroupeId" class="form-select">
                    <option value="">-- Choisir un groupe --</option>
                    @foreach (var g in groupes)
                    {
                        <option value="@g.Id">@g.Nom</option>
                    }
                </select>
                <span asp-validation-for="GroupeId" class="text-danger small"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="BrancheId" class="form-label">Branche</label>
                <select asp-for="BrancheId" id="brancheSelect" class="form-select" data-current="@selectedBrancheId">
                    @if (!initialBranches.Any())
                    {
                        <option value="">-- Choisir d'abord un groupe --</option>
                    }
                    else
                    {
                        <option value="">-- Choisir une branche --</option>
                        @foreach (var branche in initialBranches)
                        {
                            <option value="@branche.Id" selected="@(selectedBrancheId == branche.Id ? "selected" : null)">
                                @branche.Nom (@(branche.AgeMin ?? 0)-@(branche.AgeMax ?? 99) ans)
                            </option>
                        }
                    }
                </select>
                <span asp-validation-for="BrancheId" class="text-danger small"></span>
            </div>
        </div>

        <div class="d-flex gap-2 mt-2">
            <button type="submit" class="btn btn-mango" title="Mettre a jour"><i class="bi bi-check-lg"></i></button>
            <a asp-action="Index" class="btn btn-outline-or" title="Annuler"><i class="bi bi-x-lg"></i></a>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        const scoutBranches = @Html.Raw(JsonSerializer.Serialize(branchesPayload));

        function loadBranches(groupeId, selectedId) {
            var brancheSelect = document.getElementById('brancheSelect');
            if (!groupeId) {
                brancheSelect.innerHTML = '<option value="">-- Choisir d\'abord un groupe --</option>';
                brancheSelect.disabled = true;
                return;
            }

            var groupKey = String(groupeId).toLowerCase();
            var data = scoutBranches.filter(function (branche) {
                return String(branche.groupeId).toLowerCase() === groupKey;
            });

            var html = '<option value="">-- Choisir une branche --</option>';
            data.forEach(function (branche) {
                var sel = (selectedId && String(branche.id).toLowerCase() === String(selectedId).toLowerCase()) ? ' selected' : '';
                html += '<option value="' + branche.id + '"' + sel + '>' + branche.nom + ' (' + (branche.ageMin || 0) + '-' + (branche.ageMax || 99) + ' ans)</option>';
            });

            brancheSelect.innerHTML = html;
            brancheSelect.disabled = false;
        }

        document.getElementById('GroupeId').addEventListener('change', function () {
            loadBranches(this.value, null);
        });

        var initGroupe = document.getElementById('GroupeId').value;
        var initBranche = document.getElementById('brancheSelect').dataset.current;
        if (initGroupe) {
            loadBranches(initGroupe, initBranche);
        } else {
            document.getElementById('brancheSelect').disabled = true;
        }
    </script>
    <partial name="_ValidationScriptsPartial" />
}
