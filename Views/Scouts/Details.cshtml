@using MangoTaika.Data.Entities
@model ScoutDto
@{
    ViewData["Title"] = $"{Model.Prenom} {Model.Nom}";
    Layout = "_LayoutAdmin";
    var inscriptions = ViewBag.InscriptionsAnnuelles as List<InscriptionAnnuelleScout> ?? new();
    var scoutQrValue = ViewBag.ScoutQrValue as string ?? string.Empty;
    var contactUrgence = string.IsNullOrWhiteSpace(Model.ContactUrgenceNom)
        ? "Aucun contact d'urgence renseigne"
        : $"{Model.ContactUrgenceNom} {(string.IsNullOrWhiteSpace(Model.ContactUrgenceRelation) ? string.Empty : $"({Model.ContactUrgenceRelation})")}".Trim();
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <h2 class="section-title mb-0"><i class="bi bi-person-fill text-or"></i> @Model.Prenom <span class="accent">@Model.Nom</span></h2>
    <div class="d-flex gap-2">
        <button type="button" class="btn btn-outline-or" data-bs-toggle="modal" data-bs-target="#scoutQrModal" title="QR du scout">
            <i class="bi bi-qr-code"></i> QR du scout
        </button>
        <a asp-controller="InscriptionsAnnuelles" asp-action="Create" asp-route-scoutId="@Model.Id" class="btn btn-bleu" title="Inscription annuelle">
            <i class="bi bi-journal-check"></i>
        </a>
        <a asp-action="Index" class="btn btn-outline-or" title="Retour"><i class="bi bi-arrow-left"></i></a>
    </div>
</div>

<div class="card-3d p-4 mb-4 scout-details-shell">
    <div class="row g-4 align-items-start">
        <div class="col-xl-3 col-lg-4">
            <div class="scout-profile-card">
                @if (!string.IsNullOrWhiteSpace(Model.PhotoUrl))
                {
                    <img src="@Model.PhotoUrl" alt="Photo de @Model.Prenom @Model.Nom" class="scout-profile-card__photo" />
                }
                else
                {
                    <div class="scout-profile-card__photo scout-profile-card__photo--placeholder">
                        <i class="bi bi-person-circle"></i>
                    </div>
                }
                <span class="badge-3d badge-soumise">@(string.IsNullOrWhiteSpace(Model.Matricule) ? "Sans matricule" : Model.Matricule)</span>
                <strong class="scout-profile-card__name">@Model.Prenom @Model.Nom</strong>
                <span class="scout-profile-card__role">@(Model.Fonction ?? "Fonction non renseignee")</span>
                <div class="scout-profile-card__status">
                    @if (Model.AssuranceAnnuelle)
                    {
                        <span class="badge-3d badge-approuvee">Cotisation a jour</span>
                    }
                    else
                    {
                        <span class="badge-3d badge-rejetee">@(string.IsNullOrWhiteSpace(Model.Matricule) ? "En attente de cotisation" : "Cotisation non a jour")</span>
                    }
                </div>
                <button type="button" class="btn btn-outline-or scout-profile-card__qr-btn" data-bs-toggle="modal" data-bs-target="#scoutQrModal">
                    <i class="bi bi-qr-code"></i> Afficher le QR terrain
                </button>
            </div>
        </div>

        <div class="col-xl-9 col-lg-8">
            <div class="scout-details-grid mb-3">
                <div class="scout-info-card">
                    <span class="scout-info-card__label">Naissance</span>
                    <strong>@Model.DateNaissance.ToString("dd/MM/yyyy")</strong>
                    <small>@(Model.LieuNaissance ?? "Lieu non renseigne")</small>
                </div>
                <div class="scout-info-card">
                    <span class="scout-info-card__label">Contacts</span>
                    <strong>@(Model.Telephone ?? "Telephone non renseigne")</strong>
                    <small>@(Model.Email ?? "Email non renseigne")</small>
                </div>
                <div class="scout-info-card">
                    <span class="scout-info-card__label">Affectation</span>
                    <strong>@(Model.NomGroupe ?? "Non affecte")</strong>
                    <small>@(Model.NomBranche ?? "Branche non affectee")</small>
                </div>
                <div class="scout-info-card">
                    <span class="scout-info-card__label">Formation scoute</span>
                    <strong>@(Model.NiveauFormationScoute ?? "Niveau non renseigne")</strong>
                    <small>@(Model.FonctionVieActive ?? "Vie active non renseignee")</small>
                </div>
            </div>

            <div class="row g-3">
                <div class="col-md-7">
                    <div class="detail-block h-100">
                        <h5>Fiche administrative</h5>
                        <dl class="row mb-0 small">
                            <dt class="col-sm-5 text-muted-custom">Numero de carte</dt>
                            <dd class="col-sm-7">@(Model.NumeroCarte ?? "-")</dd>

                            <dt class="col-sm-5 text-muted-custom">Sexe</dt>
                            <dd class="col-sm-7">@(Model.Sexe ?? "-")</dd>

                            <dt class="col-sm-5 text-muted-custom">Region scoute</dt>
                            <dd class="col-sm-7">@(Model.RegionScoute ?? "-")</dd>

                            <dt class="col-sm-5 text-muted-custom">District</dt>
                            <dd class="col-sm-7">@(Model.District ?? "-")</dd>

                            <dt class="col-sm-5 text-muted-custom">Fonction vie active</dt>
                            <dd class="col-sm-7">@(Model.FonctionVieActive ?? "-")</dd>

                            <dt class="col-sm-5 text-muted-custom">Adresse</dt>
                            <dd class="col-sm-7">@(Model.AdresseGeographique ?? "-")</dd>
                        </dl>
                    </div>
                </div>
                <div class="col-md-5">
                    <div class="detail-block h-100 detail-block--emergency">
                        <h5><i class="bi bi-shield-check"></i> Contact d'urgence</h5>
                        <p class="mb-1"><strong>@contactUrgence</strong></p>
                        <p class="text-muted-custom mb-3">@(Model.ContactUrgenceTelephone ?? "Telephone d'urgence non renseigne")</p>
                        <div class="detail-block__footer">
                            <span>Statut ASCCI</span>
                            <strong>@(Model.StatutASCCI ?? "Non verifie")</strong>
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2 flex-wrap mt-3">
                <a href="https://adhesion.scoutascci.org/" target="_blank" rel="noopener" class="btn btn-outline-or" title="Adhesion SYGESCA">
                    <i class="bi bi-box-arrow-up-right"></i>
                </a>
                <a asp-controller="InscriptionsAnnuelles" asp-action="Index" asp-route-groupeId="@Model.GroupeId" class="btn btn-outline-or" title="Historique annuel">
                    <i class="bi bi-journal-check"></i> Historique annuel
                </a>
                <a asp-controller="Competences" asp-action="Progression" asp-route-id="@Model.Id" class="btn btn-outline-or" title="Parcours scout">
                    <i class="bi bi-graph-up-arrow"></i> Parcours scout
                </a>
            </div>
        </div>
    </div>
</div>

<div class="card-3d p-4">
    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
        <h5 class="mb-0 text-or">Historique des inscriptions annuelles</h5>
        <span class="badge-3d badge-soumise">@inscriptions.Count</span>
    </div>
    @if (inscriptions.Any())
    {
        <div class="table-responsive">
            <table class="table-modern">
                <thead>
                    <tr>
                        <th>Annee</th>
                        <th>Groupe</th>
                        <th>Branche</th>
                        <th>Fonction</th>
                        <th>Statut</th>
                        <th>Cotisation</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var inscription in inscriptions)
                {
                    <tr>
                        <td>@inscription.LibelleAnnee</td>
                        <td>@(inscription.Groupe?.Nom ?? "-")</td>
                        <td>@(inscription.Branche?.Nom ?? "-")</td>
                        <td>@(string.IsNullOrWhiteSpace(inscription.FonctionSnapshot) ? "-" : inscription.FonctionSnapshot)</td>
                        <td>@inscription.Statut</td>
                        <td>@(inscription.CotisationNationaleAjour ? "A jour" : "Non")</td>
                        <td class="text-end"><a asp-controller="InscriptionsAnnuelles" asp-action="Details" asp-route-id="@inscription.Id" class="btn btn-sm btn-outline-or"><i class="bi bi-eye"></i></a></td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-muted-custom">Aucune inscription annuelle enregistree pour ce scout.</div>
    }
</div>

<div class="modal fade" id="scoutQrModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content scout-qr-modal">
            <div class="modal-header border-0">
                <div>
                    <h5 class="modal-title mb-1">QR d'identification du scout</h5>
                    <small class="text-muted-custom">A utiliser sur la page de presence d'une activite pour reconnaitre ce scout automatiquement.</small>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
            </div>
            <div class="modal-body text-center">
                <div id="scoutIdentityQrCode" class="scout-qr-code"></div>
                <div class="scout-qr-summary mb-3">
                    <strong>@Model.Prenom @Model.Nom</strong>
                    <span>@(string.IsNullOrWhiteSpace(Model.Matricule) ? "Sans matricule - QR securise par identifiant interne" : Model.Matricule)</span>
                    <span>@(Model.NomGroupe ?? "Groupe non renseigne")</span>
                    <span>@(Model.NomBranche ?? "Branche non renseignee")</span>
                </div>
                <div class="presence-qr-linkbox mb-3">
                    <span class="presence-qr-linkbox__label">Code scout</span>
                    <code class="presence-qr-linkbox__value">@scoutQrValue</code>
                </div>
                <div class="d-flex justify-content-center gap-2 flex-wrap">
                    <button type="button" class="btn btn-outline-or" id="copyScoutQrCode" data-scout-code="@scoutQrValue">
                        <i class="bi bi-copy"></i> Copier le code scout
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .scout-details-shell {
        overflow: hidden;
    }

    .scout-profile-card {
        padding: 18px;
        border-radius: 24px;
        background: linear-gradient(180deg, rgba(95, 127, 67, 0.16), rgba(255, 255, 255, 0.82));
        border: 1px solid rgba(95, 127, 67, 0.18);
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: 12px;
    }

    .scout-profile-card__photo {
        width: 100%;
        max-width: 220px;
        aspect-ratio: 1;
        object-fit: cover;
        border-radius: 28px;
        border: 1px solid rgba(95, 127, 67, 0.18);
        background: rgba(255, 255, 255, 0.88);
    }

    .scout-profile-card__photo--placeholder {
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--vert-logo);
        font-size: 3.2rem;
    }

    .scout-profile-card__name {
        font-size: 1.15rem;
        color: #223547;
    }

    .scout-profile-card__role {
        color: #6a7a8c;
        font-weight: 600;
    }

    .scout-profile-card__status {
        display: flex;
        justify-content: center;
    }

    .scout-profile-card__qr-btn {
        width: 100%;
    }

    .scout-details-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 14px;
    }

    .scout-info-card,
    .detail-block {
        padding: 18px;
        border-radius: 22px;
        background: rgba(255, 255, 255, 0.72);
        border: 1px solid rgba(95, 127, 67, 0.12);
        height: 100%;
    }

    .scout-info-card__label {
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: #7a899c;
        display: block;
        margin-bottom: 6px;
    }

    .scout-info-card strong {
        color: var(--vert-logo);
        display: block;
        font-size: 1.08rem;
    }

    .scout-info-card small {
        color: #67778a;
    }

    .detail-block h5 {
        margin-bottom: 14px;
        color: #223547;
    }

    .detail-block--emergency {
        background: linear-gradient(180deg, rgba(239, 68, 68, 0.08), rgba(255, 255, 255, 0.82));
        border-color: rgba(239, 68, 68, 0.12);
    }

    .detail-block__footer {
        padding-top: 12px;
        margin-top: 12px;
        border-top: 1px dashed rgba(95, 127, 67, 0.18);
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .detail-block__footer span {
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: #7a899c;
    }

    .detail-block__footer strong {
        color: var(--vert-logo);
    }

    .scout-qr-modal {
        border-radius: 24px;
        border: 1px solid rgba(95, 127, 67, 0.14);
    }

    .scout-qr-code {
        min-height: 260px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .scout-qr-code > div {
        padding: 16px;
        border-radius: 22px;
        background: rgba(255, 255, 255, 0.94);
        border: 1px solid rgba(95, 127, 67, 0.14);
    }

    .scout-qr-summary {
        display: flex;
        flex-direction: column;
        gap: 4px;
        color: #607086;
    }

    .scout-qr-summary strong {
        font-size: 1.08rem;
        color: var(--bleu-logo);
    }

    .presence-qr-linkbox {
        padding: 14px 16px;
        border-radius: 18px;
        background: rgba(95, 127, 67, 0.08);
        border: 1px solid rgba(95, 127, 67, 0.18);
        text-align: left;
    }

    .presence-qr-linkbox__label {
        display: block;
        font-size: 0.76rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: #718096;
        margin-bottom: 6px;
    }

    .presence-qr-linkbox__value {
        display: block;
        white-space: normal;
        word-break: break-word;
        color: var(--bleu-logo);
        background: transparent;
        padding: 0;
    }

    .scout-qr-fallback {
        width: 220px;
        min-height: 220px;
        padding: 20px;
        border-radius: 22px;
        border: 1px dashed rgba(95, 127, 67, 0.35);
        background: rgba(95, 127, 67, 0.06);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 10px;
        text-align: center;
        color: #56667a;
    }

    .scout-qr-fallback i {
        font-size: 2rem;
        color: #5f7f43;
    }

    .scout-qr-fallback strong {
        color: var(--bleu-logo);
        font-size: 1.05rem;
    }

    .scout-qr-fallback span {
        font-size: 0.92rem;
        line-height: 1.45;
    }
</style>

@section Scripts {
    <script src="~/js/qrcode.min.js" asp-append-version="true"></script>
    <script>
        (function () {
            var qrModal = document.getElementById('scoutQrModal');
            var qrContainer = document.getElementById('scoutIdentityQrCode');
            var copyButton = document.getElementById('copyScoutQrCode');
            var scoutQrValue = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(scoutQrValue));

            function renderFallbackQr() {
                if (!qrContainer) {
                    return;
                }

                var fallback = document.createElement('div');
                fallback.className = 'scout-qr-fallback';
                fallback.innerHTML = '<i class="bi bi-qr-code"></i><strong>QR indisponible</strong><span>Utilisez le code scout affiche juste en dessous pour le pointage.</span>';
                qrContainer.replaceChildren(fallback);
            }

            function renderQr() {
                if (!qrContainer || !scoutQrValue) {
                    return;
                }

                qrContainer.replaceChildren();

                if (typeof QRCode !== 'undefined') {
                    new QRCode(qrContainer, {
                        text: scoutQrValue,
                        width: 220,
                        height: 220,
                        colorDark: '#2b3d31',
                        colorLight: '#ffffff',
                        correctLevel: QRCode.CorrectLevel.H
                    });
                    return;
                }

                renderFallbackQr();
            }

            if (qrModal) {
                qrModal.addEventListener('shown.bs.modal', renderQr);
            }

            if (copyButton) {
                copyButton.addEventListener('click', async function () {
                    if (!scoutQrValue) {
                        return;
                    }

                    try {
                        await navigator.clipboard.writeText(scoutQrValue);
                        copyButton.innerHTML = '<i class="bi bi-check2"></i> Code copie';
                        window.setTimeout(function () {
                            copyButton.innerHTML = '<i class="bi bi-copy"></i> Copier le code scout';
                        }, 1800);
                    } catch (error) {
                        window.prompt('Copiez ce code scout :', scoutQrValue);
                    }
                });
            }
        })();
    </script>
}