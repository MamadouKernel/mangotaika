@model ScoutDto
@{
    ViewData["Title"] = $"{Model.Prenom} {Model.Nom}";
    Layout = "_LayoutAdmin";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="section-title mb-0"><i class="bi bi-person-fill text-or"></i> @Model.Prenom <span class="accent">@Model.Nom</span></h2>
    <a asp-action="Index" class="btn btn-outline-or" title="Retour"><i class="bi bi-arrow-left"></i></a>
</div>

<div class="card-3d p-4">
    <div class="row">
        <div class="col-md-6">
            <p><span class="text-muted-custom">Matricule :</span> <span class="badge-3d badge-soumise">@Model.Matricule</span></p>
            <p><span class="text-muted-custom">N° Carte :</span> @(Model.NumeroCarte ?? "—")</p>
            <p><span class="text-muted-custom">Date de naissance :</span> @Model.DateNaissance.ToString("dd/MM/yyyy")</p>
            <p><span class="text-muted-custom">Sexe :</span> @(Model.Sexe ?? "—")</p>
        </div>
        <div class="col-md-6">
            <p><span class="text-muted-custom">Téléphone :</span> @(Model.Telephone ?? "—")</p>
            <p><span class="text-muted-custom">Email :</span> @(Model.Email ?? "—")</p>
            <p><span class="text-muted-custom">Fonction :</span> @(Model.Fonction ?? "—")</p>
            <p><span class="text-muted-custom">Adresse :</span> @(Model.AdresseGeographique ?? "—")</p>
            <p><span class="text-muted-custom">Assurance annuelle :</span>
                @if (Model.AssuranceAnnuelle)
                {
                    <span class="badge-3d badge-approuvee">✅ À jour</span>
                }
                else
                {
                    <span class="badge-3d badge-rejetee">❌ Non à jour</span>
                }
            </p>
        </div>
    </div>
    <hr style="border-color:var(--gris-border);" />
    <div class="row">
        <div class="col-md-6">
            <p><span class="text-muted-custom">Région Scoute :</span> @(Model.RegionScoute ?? "—")</p>
        </div>
        <div class="col-md-6">
            <p><span class="text-muted-custom">District :</span> @(Model.District ?? "—")</p>
        </div>
    </div>
    <hr style="border-color:var(--gris-border);" />
    <div class="row">
        <div class="col-md-6">
            <p><span class="text-muted-custom">Groupe :</span> @(Model.NomGroupe ?? "Non affecté")</p>
        </div>
        <div class="col-md-6">
            <p><span class="text-muted-custom">Branche :</span> @(Model.NomBranche ?? "Non affecté")</p>
        </div>
    </div>
    <hr style="border-color:var(--gris-border);" />
    <div class="d-flex gap-2 flex-wrap">
        <a href="https://adhesion.scoutascci.org/" target="_blank" rel="noopener" class="btn btn-outline-or" title="Adhésion SYGESCA">
            <i class="bi bi-box-arrow-up-right"></i>
        </a>
    </div>
</div>
