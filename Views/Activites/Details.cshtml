@model ActiviteDto
@using MangoTaika.Data.Entities
@{
    ViewData["Title"] = Model.Titre;
    Layout = "_LayoutAdmin";
    var canManage = User.IsInRole("Administrateur") || User.IsInRole("Gestionnaire");
    var scouts = ViewBag.ScoutsGroupe as List<Scout> ?? new();
    var rapportActivite = ViewBag.RapportActivite as RapportActivite;
    var presenceUrl = ViewBag.PresenceUrl as string ?? string.Empty;
    var participantIds = Model.Participants.Select(p => p.ScoutId).ToHashSet();
    var scoutsDisponibles = scouts.Where(s => !participantIds.Contains(s.Id)).ToList();
    var pointageDisponible = Model.Statut == StatutActivite.EnCours || Model.Statut == StatutActivite.Terminee;
    var pointageCloture = Model.PointageCloture;
    var pointageBadgeClass = pointageCloture ? "badge-rejetee" : pointageDisponible ? "badge-approuvee" : "badge-soumise";
    var pointageLabel = pointageCloture ? "Pointage cloture" : pointageDisponible ? "Pointage ouvert" : "Pointage en attente";
}

<div class="tracking-module tracking-module--activity-detail">
    <section class="tracking-hero tracking-hero--compact">
        <div class="tracking-hero__content">
            <span class="tracking-hero__eyebrow"><i class="bi bi-calendar-check"></i> Suivi complet de l'activite</span>
            <h2 class="section-title tracking-hero__title mb-2"><i class="bi bi-calendar-event-fill text-or"></i> <span class="accent">@Model.Titre</span></h2>
            <p class="tracking-hero__text mb-0">Creee par @Model.NomCreateur le @Model.DateCreation.ToString("dd/MM/yyyy")</p>
            <div class="tracking-hero__chips">
                <span class="tracking-chip"><i class="bi bi-patch-check"></i> @Model.Statut</span>
                <span class="tracking-chip tracking-chip--soft"><i class="bi bi-bookmark-star"></i> @Model.Type</span>
                <span class="tracking-chip tracking-chip--highlight"><i class="bi bi-qr-code-scan"></i> @pointageLabel</span>
            </div>
        </div>
        <div class="tracking-hero__actions">
            <div class="tracking-hero__focus">
                <span>Pilotage</span>
                <strong>@Model.NbParticipants</strong>
                <small>participant(s) suivis sur cette activite</small>
            </div>
            <div class="tracking-action-stack">
                @if (canManage && Model.Statut == StatutActivite.Brouillon)
                {
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-or"><i class="bi bi-pencil"></i> Modifier</a>
                }
                <a asp-action="Index" class="btn btn-outline-or"><i class="bi bi-arrow-left"></i> Retour</a>
            </div>
        </div>
    </section>

    <div class="tracking-panel tracking-panel--soft p-3 mb-4">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
        <div class="d-flex align-items-center gap-2 flex-wrap">
            <span class="badge-3d badge-@Model.Statut.ToString().ToLower()" style="font-size: 0.85rem;">@Model.Statut</span>
            <span class="badge bg-secondary bg-opacity-25" style="color: var(--bleu-logo); border-radius: 10px;">@Model.Type</span>
            <span class="badge-3d @pointageBadgeClass">@pointageLabel</span>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            @if (canManage && Model.Statut == StatutActivite.Brouillon)
            {
                <form asp-action="Soumettre" asp-route-id="@Model.Id" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-mango btn-sm" title="Soumettre"><i class="bi bi-send"></i></button>
                </form>
            }
            @if (canManage && Model.Statut == StatutActivite.Soumise)
            {
                <form asp-action="Valider" asp-route-id="@Model.Id" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm" style="background: rgba(16,185,129,0.2); color: #10b981; border: 1px solid rgba(16,185,129,0.3); border-radius: 14px;" title="Valider"><i class="bi bi-check-lg"></i></button>
                </form>
                <button type="button" class="btn btn-sm" style="background: rgba(239,68,68,0.15); color: #f87171; border: 1px solid rgba(239,68,68,0.3); border-radius: 14px;" data-bs-toggle="modal" data-bs-target="#rejetModal" title="Rejeter"><i class="bi bi-x-lg"></i></button>
            }
            @if (canManage && Model.Statut == StatutActivite.Validee)
            {
                <form asp-action="Demarrer" asp-route-id="@Model.Id" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-mango btn-sm" title="Demarrer"><i class="bi bi-play-fill"></i></button>
                </form>
            }
            @if (canManage && Model.Statut == StatutActivite.EnCours)
            {
                <form asp-action="Terminer" asp-route-id="@Model.Id" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm" style="background: rgba(16,185,129,0.2); color: #10b981; border: 1px solid rgba(16,185,129,0.3); border-radius: 14px;" title="Terminer"><i class="bi bi-check-circle"></i></button>
                </form>
            }
            @if (canManage && (Model.Statut == StatutActivite.Terminee || Model.Statut == StatutActivite.Rejetee))
            {
                <form asp-action="Archiver" asp-route-id="@Model.Id" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-outline-or" title="Archiver"><i class="bi bi-archive"></i></button>
                </form>
            }
            @if (canManage && Model.Statut == StatutActivite.Rejetee)
            {
                <form asp-action="Rebrouillon" asp-route-id="@Model.Id" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-outline-or" title="Corriger"><i class="bi bi-arrow-counterclockwise"></i></button>
                </form>
            }
        </div>
    </div>
    @if (!string.IsNullOrEmpty(Model.MotifRejet))
    {
        <div class="mt-2 p-2" style="background: rgba(239,68,68,0.1); border-radius: 10px; border: 1px solid rgba(239,68,68,0.2);">
            <small style="color: #f87171;"><i class="bi bi-exclamation-triangle"></i> Motif du rejet : @Model.MotifRejet</small>
        </div>
    }
</div>

<div class="tracking-panel p-4 mb-4">
    <div class="row g-3 activite-kpi-grid">
        <div class="col-md-3">
            <div class="activite-kpi-card">
                <span>Date</span>
                <strong>@Model.DateDebut.ToString("dd/MM/yyyy")</strong>
                <small>Debut @Model.DateDebut.ToString("HH:mm")</small>
            </div>
        </div>
        <div class="col-md-3">
            <div class="activite-kpi-card">
                <span>Lieu</span>
                <strong>@(Model.Lieu ?? "-")</strong>
                <small>@(Model.NomGroupe ?? "Tout le district")</small>
            </div>
        </div>
        <div class="col-md-3">
            <div class="activite-kpi-card">
                <span>Participants</span>
                <strong>@Model.NbParticipants</strong>
                <small>Documents : @Model.NbDocuments</small>
            </div>
        </div>
        <div class="col-md-3">
            <div class="activite-kpi-card activite-kpi-card--qr">
                <span>Pointage</span>
                <strong>@pointageLabel</strong>
                <small>@(pointageCloture ? "Presences verrouillees" : pointageDisponible ? "Corrections autorisees jusqu'a cloture" : "En attente du demarrage")</small>
            </div>
        </div>
    </div>
</div>

<div class="tracking-panel tracking-panel--soft p-4 mb-4">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
            <h5 class="mb-1"><i class="bi bi-journal-richtext text-or"></i> Rapport d'activite</h5>
            <p class="text-muted-custom mb-0">Le rapport post-activite formalise le bilan, les difficultes et les recommandations apres cloture.</p>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            @if (canManage)
            {
                <button type="button" class="btn btn-outline-or" data-bs-toggle="modal" data-bs-target="#presenceQrModal">
                    <i class="bi bi-qr-code-scan"></i> QR presence
                </button>
            }
            <a asp-action="Presence" asp-route-id="@Model.Id" class="btn btn-outline-or"><i class="bi bi-phone"></i> Page presence</a>
            @if (canManage && pointageDisponible && !pointageCloture)
            {
                <form asp-action="CloturerPointage" asp-route-id="@Model.Id" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="returnAction" value="Details" />
                    <button type="submit" class="btn btn-mango"><i class="bi bi-lock"></i> Cloturer le pointage</button>
                </form>
            }
            else if (canManage && pointageCloture && Model.Statut != StatutActivite.Archivee)
            {
                <form asp-action="ReouvrirPointage" asp-route-id="@Model.Id" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="returnAction" value="Details" />
                    <button type="submit" class="btn btn-outline-or"><i class="bi bi-unlock"></i> Reouvrir le pointage</button>
                </form>
            }
            @if (rapportActivite is null)
            {
                <a asp-controller="RapportsActivite" asp-action="Create" asp-route-activiteId="@Model.Id" class="btn btn-mango"><i class="bi bi-plus-lg"></i> Creer le rapport</a>
            }
            else
            {
                <a asp-controller="RapportsActivite" asp-action="Details" asp-route-id="@rapportActivite.Id" class="btn btn-outline-or"><i class="bi bi-eye"></i> Voir le rapport</a>
            }
        </div>
    </div>
</div>

<ul class="nav nav-tabs tracking-tabs mb-3" role="tablist">
    <li class="nav-item"><a class="nav-link active" data-bs-toggle="tab" href="#infos" style="color: var(--bleu-logo);"><i class="bi bi-info-circle"></i> Informations</a></li>
    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#participants" style="color: var(--bleu-logo);"><i class="bi bi-people"></i> Participants (@Model.NbParticipants)</a></li>
    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#documents" style="color: var(--bleu-logo);"><i class="bi bi-paperclip"></i> Documents (@Model.NbDocuments)</a></li>
    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#journal" style="color: var(--bleu-logo);"><i class="bi bi-clock-history"></i> Journal (@Model.Commentaires.Count)</a></li>
</ul>

<div class="tab-content">
    <div class="tab-pane fade show active" id="infos">
        <div class="card-3d p-4">
            <div class="row">
                <div class="col-md-6">
                    <p><span class="text-muted-custom">Type :</span> @Model.Type</p>
                    <p><span class="text-muted-custom">Date de debut :</span> @Model.DateDebut.ToString("dd/MM/yyyy HH:mm")</p>
                    <p><span class="text-muted-custom">Date de fin :</span> @(Model.DateFin?.ToString("dd/MM/yyyy HH:mm") ?? "-")</p>
                    <p><span class="text-muted-custom">Lieu :</span> @(Model.Lieu ?? "-")</p>
                </div>
                <div class="col-md-6">
                    <p><span class="text-muted-custom">Groupe :</span> @(Model.NomGroupe ?? "Tout le district")</p>
                    <p><span class="text-muted-custom">Responsable :</span> @(Model.NomResponsable ?? "-")</p>
                    <p><span class="text-muted-custom">Budget previsionnel :</span> @(Model.BudgetPrevisionnel?.ToString("N0") ?? "-") FCFA</p>
                    <p><span class="text-muted-custom">Lien de presence :</span> <a href="@presenceUrl" class="text-or">Ouvrir</a></p>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <hr style="border-color: var(--gris-border);" />
                <p style="white-space: pre-line; color: var(--texte-secondaire);">@Model.Description</p>
            }
        </div>
    </div>

    <div class="tab-pane fade" id="participants">
        @if (canManage && Model.Statut != StatutActivite.Archivee && !pointageCloture && scoutsDisponibles.Any())
        {
            <div class="card-3d p-3 mb-3">
                <form asp-action="AjouterParticipant" asp-route-id="@Model.Id" method="post" class="d-flex gap-2 align-items-end">
                    @Html.AntiForgeryToken()
                    <div class="flex-grow-1">
                        <label class="form-label small">Ajouter un scout</label>
                        <select name="scoutId" class="form-select" required>
                            <option value="">-- Selectionner --</option>
                            @foreach (var s in scoutsDisponibles)
                            {
                                <option value="@s.Id">@s.Matricule - @s.Prenom @s.Nom @(s.Branche != null ? $"({s.Branche.Nom})" : string.Empty)</option>
                            }
                        </select>
                    </div>
                    <button type="submit" class="btn btn-mango" title="Ajouter un participant"><i class="bi bi-person-plus"></i></button>
                </form>
            </div>
        }
        @if (pointageCloture)
        {
            <div class="alert alert-secondary mb-3">Le pointage de cette activite est cloture. Reouvre-le depuis l'en-tete pour ajuster les presences ou la liste des participants.</div>
        }

        @if (Model.Participants.Any())
        {
            <div class="card-3d">
                <div class="table-responsive">
                    <table class="table-modern">
                        <thead>
                            <tr>
                                <th>Matricule</th>
                                <th>Nom</th>
                                <th>Branche</th>
                                <th>Presence</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in Model.Participants)
                            {
                                <tr>
                                    <td><code>@p.Matricule</code></td>
                                    <td>@p.NomComplet</td>
                                    <td>@(p.NomBranche ?? "-")</td>
                                    <td>
                                        @if (canManage && pointageDisponible && !pointageCloture)
                                        {
                                            <form asp-action="MarquerPresence" asp-route-id="@Model.Id" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="participantId" value="@p.Id" />
                                                <select name="presence" class="form-select form-select-sm" style="width: auto; display: inline; border-radius: 10px;" onchange="this.form.submit()">
                                                    @foreach (var sp in Enum.GetValues<StatutPresence>())
                                                    {
                                                        <option value="@sp" selected="@(p.Presence == sp)">@sp</option>
                                                    }
                                                </select>
                                            </form>
                                        }
                                        else
                                        {
                                            <span class="badge-3d badge-@(p.Presence == StatutPresence.Present ? "validee" : p.Presence == StatutPresence.Absent ? "rejetee" : "soumise")">@p.Presence</span>
                                        }
                                    </td>
                                    <td>
                                        @if (canManage && Model.Statut != StatutActivite.Archivee && !pointageCloture)
                                        {
                                            <form asp-action="RetirerParticipant" asp-route-id="@Model.Id" method="post" class="d-inline" onsubmit="return confirm('Retirer ce participant ?')">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="participantId" value="@p.Id" />
                                                <button type="submit" class="btn btn-sm p-0 px-1" style="color: #f87171;" title="Retirer ce participant"><i class="bi bi-x-circle"></i></button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else
        {
            <div class="text-center py-4 text-muted-custom"><i class="bi bi-people" style="font-size: 2rem; opacity: 0.3;"></i><p class="mt-2">Aucun participant inscrit.</p></div>
        }
    </div>

    <div class="tab-pane fade" id="documents">
        @if (canManage && Model.Statut != StatutActivite.Archivee)
        {
            <div class="card-3d p-3 mb-3">
                <form asp-action="AjouterDocument" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data" class="d-flex gap-2 align-items-end flex-wrap">
                    @Html.AntiForgeryToken()
                    <div>
                        <label class="form-label small">Type</label>
                        <select name="typeDocument" class="form-select" style="width: auto;">
                            <option value="Programme">Programme</option>
                            <option value="Budget">Budget</option>
                            <option value="Autorisation">Autorisation</option>
                            <option value="Compte-rendu">Compte-rendu</option>
                            <option value="Photo">Photo</option>
                            <option value="Autre">Autre</option>
                        </select>
                    </div>
                    <div class="flex-grow-1">
                        <label class="form-label small">Fichier</label>
                        <input type="file" name="fichier" class="form-control" required />
                    </div>
                    <button type="submit" class="btn btn-mango" title="Televerser un document"><i class="bi bi-upload"></i></button>
                </form>
            </div>
        }

        @if (Model.Documents.Any())
        {
            <div class="row g-3">
                @foreach (var doc in Model.Documents)
                {
                    <div class="col-md-4">
                        <div class="card-3d p-3">
                            <div class="d-flex align-items-center gap-2">
                                <i class="bi bi-file-earmark-@(doc.TypeDocument == "Photo" ? "image" : doc.TypeDocument == "Budget" ? "spreadsheet" : "text")" style="font-size: 1.5rem; color: var(--vert-logo);"></i>
                                <div class="flex-grow-1" style="min-width: 0;">
                                    <a href="@doc.CheminFichier" target="_blank" class="text-or small d-block text-truncate" title="@doc.NomFichier">@doc.NomFichier</a>
                                    <small class="text-muted-custom">@(doc.TypeDocument ?? "Autre") - @doc.DateUpload.ToString("dd/MM/yyyy")</small>
                                </div>
                                @if (canManage && Model.Statut != StatutActivite.Archivee)
                                {
                                    <form asp-action="SupprimerDocument" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Supprimer ce document ?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="docId" value="@doc.Id" />
                                        <button type="submit" class="btn btn-sm p-0" style="color: #f87171;" title="Supprimer le document"><i class="bi bi-trash"></i></button>
                                    </form>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-4 text-muted-custom"><i class="bi bi-paperclip" style="font-size: 2rem; opacity: 0.3;"></i><p class="mt-2">Aucun document.</p></div>
        }
    </div>

    <div class="tab-pane fade" id="journal">
        @if (canManage)
        {
            <div class="card-3d p-3 mb-3">
                <form asp-action="AjouterCommentaire" asp-route-id="@Model.Id" method="post" class="d-flex gap-2">
                    @Html.AntiForgeryToken()
                    <input name="contenu" class="form-control" placeholder="Ajouter un commentaire..." required />
                    <button type="submit" class="btn btn-mango" title="Ajouter un commentaire"><i class="bi bi-chat-dots"></i></button>
                </form>
            </div>
        }

        @if (Model.Commentaires.Any())
        {
            <div class="timeline-journal">
                @foreach (var c in Model.Commentaires)
                {
                    var iconClass = c.TypeAction switch
                    {
                        "Creation" => "bi-plus-circle text-or",
                        "Soumission" => "bi-send text-or",
                        "Validation" => "bi-check-circle",
                        "Rejet" => "bi-x-circle",
                        "Demarrage" => "bi-play-circle text-or",
                        "Cloture" => "bi-check-circle",
                        "Archivage" => "bi-archive text-or",
                        "Document" => "bi-paperclip text-or",
                        "Correction" => "bi-arrow-counterclockwise text-or",
                        _ => "bi-chat-dots text-or"
                    };
                    var bgColor = c.TypeAction switch
                    {
                        "Validation" => "rgba(16,185,129,0.15)",
                        "Rejet" => "rgba(239,68,68,0.1)",
                        _ => "transparent"
                    };
                    var textColor = c.TypeAction switch
                    {
                        "Validation" => "#10b981",
                        "Rejet" => "#f87171",
                        _ => "var(--texte-secondaire)"
                    };
                    <div class="d-flex gap-3 mb-3 p-2" style="background: @bgColor; border-radius: 12px;">
                        <div style="min-width: 30px; text-align: center; padding-top: 2px;">
                            <i class="bi @iconClass" style="font-size: 1.2rem;"></i>
                        </div>
                        <div>
                            <p class="mb-0" style="color: @textColor;">@c.Contenu</p>
                            <small class="text-muted-custom">@c.NomAuteur - @c.DateCreation.ToString("dd/MM/yyyy HH:mm")</small>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-4 text-muted-custom"><i class="bi bi-clock-history" style="font-size: 2rem; opacity: 0.3;"></i><p class="mt-2">Aucune entree.</p></div>
        }
    </div>
</div>

</div>

@if (canManage)
{
<div class="modal fade" id="rejetModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content" style="border-radius: 18px; border: 1px solid var(--gris-border);">
            <form asp-action="Rejeter" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header" style="border-bottom: 1px solid var(--gris-border);">
                    <h5 class="modal-title" style="color: var(--bleu-logo);">Rejeter l'activite</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
                </div>
                <div class="modal-body">
                    <label class="form-label">Motif du rejet</label>
                    <textarea name="motif" class="form-control" rows="3" placeholder="Expliquez la raison du rejet..." required></textarea>
                </div>
                <div class="modal-footer" style="border-top: 1px solid var(--gris-border);">
                    <button type="button" class="btn btn-outline-or" data-bs-dismiss="modal">Annuler</button>
                    <button type="submit" class="btn" style="background: rgba(239,68,68,0.2); color: #f87171; border: 1px solid rgba(239,68,68,0.3); border-radius: 14px;">Confirmer le rejet</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="presenceQrModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content presence-qr-modal">
            <div class="modal-header border-0">
                <div>
                    <h5 class="modal-title mb-1">QR code de presence</h5>
                    <small class="text-muted-custom">Scanner pour ouvrir la page de pointage rapide.</small>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
            </div>
            <div class="modal-body text-center">
                <div id="presenceQrCode" class="presence-qr-code"></div>
                <p class="small text-muted-custom mb-2">Partage ce QR avec l'appareil de pointage pour ouvrir directement la page de presence.</p>
                <div class="presence-qr-linkbox mb-3">
                    <span class="presence-qr-linkbox__label">Lien de pointage</span>
                    <code class="presence-qr-linkbox__value">@presenceUrl</code>
                </div>
                <div class="d-flex justify-content-center gap-2 flex-wrap">
                    <button type="button" class="btn btn-outline-or" id="copyPresenceLink" data-presence-url="@presenceUrl">
                        <i class="bi bi-copy"></i> Copier le lien
                    </button>
                    <a href="@presenceUrl" class="btn btn-outline-or">Ouvrir la page de presence</a>
                </div>
            </div>
        </div>
    </div>
</div>
}

<style>
    .activite-kpi-card {
        padding: 18px;
        border-radius: 22px;
        background: rgba(255, 255, 255, 0.72);
        border: 1px solid rgba(94, 117, 188, 0.12);
        height: 100%;
    }

    .activite-kpi-card span {
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: #7a899c;
        display: block;
        margin-bottom: 8px;
    }

    .activite-kpi-card strong {
        color: var(--bleu-logo);
        display: block;
        font-size: 1.18rem;
    }

    .activite-kpi-card small {
        color: #67778a;
    }

    .activite-kpi-card--qr {
        background: linear-gradient(180deg, rgba(95, 127, 67, 0.14), rgba(255, 255, 255, 0.88));
    }

    .presence-qr-modal {
        border-radius: 24px;
        border: 1px solid rgba(95, 127, 67, 0.14);
    }

    .presence-qr-code {
        min-height: 260px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .presence-qr-code > div {
        padding: 16px;
        border-radius: 22px;
        background: rgba(255, 255, 255, 0.94);
        border: 1px solid rgba(95, 127, 67, 0.14);
    }

    .presence-qr-linkbox {
        padding: 14px 16px;
        border-radius: 18px;
        background: rgba(95, 127, 67, 0.08);
        border: 1px solid rgba(95, 127, 67, 0.18);
        text-align: left;
    }

    .presence-qr-linkbox__label {
        display: block;
        font-size: 0.76rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: #718096;
        margin-bottom: 6px;
    }

    .presence-qr-linkbox__value {
        display: block;
        white-space: normal;
        word-break: break-word;
        color: var(--bleu-logo);
        background: transparent;
        padding: 0;
    }

    .presence-qr-fallback {
        width: 220px;
        min-height: 220px;
        padding: 20px;
        border-radius: 22px;
        border: 1px dashed rgba(95, 127, 67, 0.35);
        background: rgba(95, 127, 67, 0.06);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 10px;
        text-align: center;
        color: #56667a;
    }

    .presence-qr-fallback i {
        font-size: 2rem;
        color: #5f7f43;
    }

    .presence-qr-fallback strong {
        color: var(--bleu-logo);
        font-size: 1.05rem;
    }

    .presence-qr-fallback span {
        font-size: 0.92rem;
        line-height: 1.45;
    }
</style>

@section Scripts {
    <script src="~/js/qrcode.min.js" asp-append-version="true"></script>
    <script>
        (function () {
            var qrModal = document.getElementById('presenceQrModal');
            var qrContainer = document.getElementById('presenceQrCode');
            var copyButton = document.getElementById('copyPresenceLink');
            var presenceUrl = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(presenceUrl));

            function renderFallbackQr() {
                if (!qrContainer || !presenceUrl) {
                    return;
                }

                var fallback = document.createElement('div');
                fallback.className = 'presence-qr-fallback';
                fallback.innerHTML = '<i class="bi bi-qr-code"></i><strong>QR indisponible</strong><span>Utilisez le lien de pointage juste en dessous pour ouvrir directement la page.</span>';
                qrContainer.replaceChildren(fallback);
            }

            function renderQr() {
                if (!qrContainer || !presenceUrl) {
                    return;
                }

                qrContainer.replaceChildren();

                if (typeof QRCode !== 'undefined') {
                    new QRCode(qrContainer, {
                        text: presenceUrl,
                        width: 220,
                        height: 220,
                        colorDark: '#2b3d31',
                        colorLight: '#ffffff',
                        correctLevel: QRCode.CorrectLevel.H
                    });
                    return;
                }

                renderFallbackQr();
            }

            if (qrModal) {
                qrModal.addEventListener('shown.bs.modal', renderQr);
            } else {
                renderQr();
            }

            if (copyButton) {
                copyButton.addEventListener('click', async function () {
                    if (!presenceUrl) {
                        return;
                    }

                    try {
                        await navigator.clipboard.writeText(presenceUrl);
                        copyButton.innerHTML = '<i class="bi bi-check2"></i> Lien copie';
                        window.setTimeout(function () {
                            copyButton.innerHTML = '<i class="bi bi-copy"></i> Copier le lien';
                        }, 1800);
                    } catch (error) {
                        window.prompt('Copiez ce lien de pointage :', presenceUrl);
                    }
                });
            }
        })();
    </script>
}
