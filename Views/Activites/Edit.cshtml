@model ActiviteDto
@using MangoTaika.Data.Entities
@{
    ViewData["Title"] = "Modifier l'activite";
    Layout = "_LayoutAdmin";
    var groupes = ViewBag.Groupes as IList<Groupe>;
}

<div class="tracking-module tracking-module--activity-form">
    <section class="tracking-hero tracking-hero--compact">
        <div class="tracking-hero__content">
            <span class="tracking-hero__eyebrow"><i class="bi bi-pencil-square"></i> Ajustement de la fiche terrain</span>
            <h2 class="section-title tracking-hero__title mb-2"><i class="bi bi-pencil text-or"></i> Modifier <span class="accent">@Model.Titre</span></h2>
            <p class="tracking-hero__text mb-0">Affinez les parametres de l'activite sans perdre la lisibilite du module: horaire, groupe, responsable et logistique restent au meme endroit.</p>
        </div>
        <div class="tracking-hero__actions">
            <div class="tracking-hero__focus">
                <span>Statut courant</span>
                <strong>@Model.Statut</strong>
                <small>la fiche detail conservera le QR de pointage apres enregistrement.</small>
            </div>
            <div class="tracking-action-stack">
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-or"><i class="bi bi-arrow-left"></i> Retour a la fiche</a>
            </div>
        </div>
    </section>

    <div class="tracking-form-layout">
        <section class="tracking-panel tracking-form-shell">
            <form asp-action="Edit" asp-route-id="@Model.Id" method="post" class="form-modern">
                <div asp-validation-summary="ModelOnly" class="text-danger small"></div>

                <div class="tracking-form-grid">
                    <div class="tracking-form-col-8">
                        <label class="form-label">Titre</label>
                        <input name="Titre" class="form-control" value="@Model.Titre" required />
                    </div>
                    <div class="tracking-form-col-4">
                        <label class="form-label">Type d'activite</label>
                        <select name="Type" class="form-select">
                            @foreach (var t in Enum.GetValues<TypeActivite>())
                            {
                                <option value="@t" selected="@(Model.Type == t)">@t</option>
                            }
                        </select>
                    </div>

                    <div class="tracking-form-col-12">
                        <label class="form-label">Description</label>
                        <textarea name="Description" class="form-control" rows="4">@Model.Description</textarea>
                    </div>

                    <div class="tracking-form-col-4">
                        <label class="form-label">Date et heure de debut</label>
                        <input name="DateDebut" class="form-control" type="datetime-local" value="@Model.DateDebut.ToString("yyyy-MM-ddTHH:mm")" required />
                    </div>
                    <div class="tracking-form-col-4">
                        <label class="form-label">Date et heure de fin</label>
                        <input name="DateFin" class="form-control" type="datetime-local" value="@(Model.DateFin?.ToString("yyyy-MM-ddTHH:mm") ?? string.Empty)" />
                    </div>
                    <div class="tracking-form-col-4">
                        <label class="form-label">Lieu</label>
                        <input name="Lieu" class="form-control" value="@Model.Lieu" />
                    </div>

                    <div class="tracking-form-col-4">
                        <label class="form-label">Groupe</label>
                        <select name="GroupeId" class="form-select">
                            <option value="">-- Tout le district --</option>
                            @if (groupes != null)
                            {
                                @foreach (var g in groupes)
                                {
                                    <option value="@g.Id" selected="@(Model.GroupeId == g.Id)">@g.Nom</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="tracking-form-col-4">
                        <label class="form-label">Responsable</label>
                        <input name="NomResponsable" class="form-control" value="@Model.NomResponsable" />
                    </div>
                    <div class="tracking-form-col-4">
                        <label class="form-label">Budget previsionnel (FCFA)</label>
                        <input name="BudgetPrevisionnel" class="form-control" type="number" min="0" step="100" value="@Model.BudgetPrevisionnel" />
                    </div>
                </div>

                <div class="tracking-note">
                    <i class="bi bi-qr-code-scan"></i>
                    <div class="tracking-note__text">
                        <strong>Presence QR</strong>
                        <div>L'heure de debut alimente la fiche detail et la page de presence. Garde-la a jour pour eviter les decalages sur le terrain.</div>
                    </div>
                </div>

                <div class="tracking-actions">
                    <button type="submit" class="btn btn-mango"><i class="bi bi-check-lg"></i> Enregistrer</button>
                    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-or">Annuler</a>
                </div>
            </form>
        </section>

        <aside class="tracking-side-stack">
            <div class="tracking-side-card">
                <span class="tracking-side-card__label"><i class="bi bi-clipboard-data"></i> Contexte</span>
                <h4>Fiche en suivi</h4>
                <p class="text-muted-custom mb-0">Cette activite compte deja @Model.NbParticipants participant(s) et @Model.NbDocuments document(s) lies.</p>
            </div>
            <div class="tracking-side-card">
                <span class="tracking-side-card__label"><i class="bi bi-shield-check"></i> Conseil</span>
                <h5>Avant de soumettre</h5>
                <p class="text-muted-custom mb-0">Verifie le responsable, le lieu et le budget avant la validation pour fluidifier le circuit de traitement.</p>
            </div>
        </aside>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}