@model List<ActiviteDto>
@{
    ViewData["Title"] = "Activités";
    Layout = "_LayoutAdmin";
    var canManage = User.IsInRole("Administrateur") || User.IsInRole("Gestionnaire");
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="section-title mb-0"><i class="bi bi-calendar-event-fill text-or"></i> <span class="accent">Activités</span></h2>
    @if (canManage)
    {
        <a asp-action="Create" class="btn btn-mango"><i class="bi bi-plus-lg"></i> Nouvelle activité</a>
    }
</div>

@{
    var countsByStatut = ViewBag.CountsByStatut as Dictionary<StatutActivite, int> ?? new();
    var totalActivites = ViewBag.TotalActivites as int? ?? Model.Count;
}
<div class="d-flex gap-2 mb-3 flex-wrap">
    <button type="button" class="btn btn-sm btn-outline-or filter-btn active" data-filter="all">Toutes (@totalActivites)</button>
    @foreach (var st in Enum.GetValues<StatutActivite>())
    {
        var count = countsByStatut.GetValueOrDefault(st);
        if (count > 0)
        {
            <button type="button" class="btn btn-sm btn-outline-or filter-btn" data-filter="@st">@st (@count)</button>
        }
    }
</div>

<div class="row g-4">
    @foreach (var a in Model)
    {
        <div class="col-lg-4 col-md-6 activite-card-item" data-statut="@a.Statut">
            <div class="card-3d p-4 h-100 d-flex flex-column">
                <h5 class="text-or mb-2">
                    <a asp-action="Details" asp-route-id="@a.Id" class="text-decoration-none" style="color:inherit;">@a.Titre</a>
                </h5>
                <p class="text-muted-custom small mb-2">
                    <span class="badge bg-secondary bg-opacity-25" style="color:var(--bleu-logo);border-radius:10px;font-size:0.7rem;">@a.Type</span>
                    <span class="badge-3d badge-@a.Statut.ToString().ToLower() ms-1" style="font-size:0.7rem;">@a.Statut</span>
                </p>
                <div class="d-flex flex-column gap-1 mb-3 flex-grow-1" style="font-size:0.85rem;">
                    <span><i class="bi bi-calendar3 text-bleu"></i> @a.DateDebut.ToString("dd/MM/yyyy")</span>
                    <span><i class="bi bi-geo-alt text-or"></i> @(a.Lieu ?? "-")</span>
                    <span><i class="bi bi-building text-bleu"></i> @(a.NomGroupe ?? "-")</span>
                    <span><i class="bi bi-people-fill text-or"></i> <span class="badge-3d badge-soumise" style="font-size:0.7rem;">@a.NbParticipants participant(s)</span></span>
                </div>
                <div class="d-flex flex-wrap gap-2 mt-auto">
                    <a asp-action="Details" asp-route-id="@a.Id" class="btn btn-sm btn-outline-or" title="Détails"><i class="bi bi-eye"></i></a>
                    @if (canManage)
                    {
                        <a asp-action="Edit" asp-route-id="@a.Id" class="btn btn-sm btn-bleu" title="Modifier"><i class="bi bi-pencil"></i></a>
                        <form asp-action="Delete" asp-route-id="@a.Id" method="post" class="d-inline" onsubmit="return confirm('Supprimer cette activité ?')">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm" style="background:rgba(239,68,68,0.15);color:#f87171;border:1px solid rgba(239,68,68,0.3);border-radius:14px;" title="Supprimer">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                    }
                </div>
            </div>
        </div>
    }
    @if (!Model.Any())
    {
        <div class="col-12 text-center text-muted-custom py-5">Aucune activité</div>
    }
</div>

<partial name="_ListPagination" />

@section Scripts {
<script>
document.querySelectorAll('.filter-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
        document.querySelectorAll('.filter-btn').forEach(function (b) { b.classList.remove('active'); });
        this.classList.add('active');
        var filter = this.dataset.filter;
        document.querySelectorAll('.activite-card-item').forEach(function (card) {
            card.style.display = (filter === 'all' || card.dataset.statut === filter) ? '' : 'none';
        });
    });
});
</script>
}
