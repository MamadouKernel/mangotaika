@model List<MangoTaika.DTOs.FormationDto>
@{ ViewData["Title"] = "Statistiques formations"; Layout = "_LayoutAdmin";
    var stats = ViewBag.Stats as Dictionary<Guid, MangoTaika.DTOs.FormationStatsDto>; }

<h2><i class="bi bi-bar-chart"></i> Statistiques des formations</h2>

<div class="table-responsive mt-3">
    <table class="table table-hover">
        <thead class="table-dark">
            <tr><th>Formation</th><th>Inscrits</th><th>Terminées</th><th>En cours</th><th>Taux réussite</th></tr>
        </thead>
        <tbody>
            @foreach (var f in Model)
            {
                var s = stats?[f.Id];
                <tr>
                    <td><a asp-action="Details" asp-route-id="@f.Id">@f.Titre</a></td>
                    <td>@s?.TotalInscrits</td>
                    <td>@s?.Terminees</td>
                    <td>@s?.EnCours</td>
                    <td>@s?.TauxReussite%</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<partial name="_ListPagination" />
