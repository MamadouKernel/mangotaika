@model MangoTaika.DTOs.RoleEditDto
@{
    ViewData["Title"] = "Nouveau role";
    Layout = "_LayoutAdmin";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="section-title mb-0"><i class="bi bi-person-plus-fill text-or"></i> Nouveau role</h2>
    <a asp-action="Index" class="btn btn-outline-or"><i class="bi bi-arrow-left"></i> Retour</a>
</div>

<div class="card-3d p-4">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="Name" class="form-label fw-semibold">Nom technique</label>
                <input asp-for="Name" class="form-control" placeholder="ex: ChefRegional" />
                <div class="form-text">Lettres, chiffres et underscores uniquement. Sert aux verifications dans le code.</div>
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Libelle" class="form-label fw-semibold">Libelle affiche</label>
                <input asp-for="Libelle" class="form-control" placeholder="ex: Chef Regional" />
                <span asp-validation-for="Libelle" class="text-danger small"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="Hierarchie" class="form-label fw-semibold">Niveau hierarchique</label>
                <input asp-for="Hierarchie" type="number" min="0" max="99" class="form-control" />
                <div class="form-text">0 = sommet de la hierarchie.</div>
                <span asp-validation-for="Hierarchie" class="text-danger small"></span>
            </div>
            <div class="col-md-9">
                <label asp-for="Visibilite" class="form-label fw-semibold">Perimetre / visibilite</label>
                <input asp-for="Visibilite" class="form-control" placeholder="ex: Donnees de la region" />
                <span asp-validation-for="Visibilite" class="text-danger small"></span>
            </div>
            <div class="col-12">
                <label asp-for="Description" class="form-label fw-semibold">Description</label>
                <textarea asp-for="Description" class="form-control" rows="3" placeholder="Role et responsabilites principales"></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>
        </div>

        <div class="alert mt-4" style="background:rgba(234,179,8,0.1);border:1px solid rgba(234,179,8,0.3);border-radius:12px;color:var(--texte);">
            <i class="bi bi-info-circle"></i> Apres creation, attribuez les permissions necessaires depuis la page <strong>Permissions</strong>. Sans permissions, le role ne donne acces a aucun module.
        </div>

        <div class="d-flex gap-2 mt-3">
            <button type="submit" class="btn btn-mango"><i class="bi bi-check2-circle"></i> Creer le role</button>
            <a asp-action="Index" class="btn btn-outline-or">Annuler</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
