@model IReadOnlyList<MangoTaika.Services.RoleDefinition>
@{
    ViewData["Title"] = "Roles et visibilite";
    Layout = "_LayoutAdmin";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
    <div>
        <h2 class="section-title mb-1"><i class="bi bi-person-lock text-or"></i> Roles et visibilite</h2>
        <p class="text-muted-custom mb-0">Matrice officielle des profils, hierarchies et perimetres d'acces.</p>
    </div>
</div>

<div class="card-3d p-4">
    <div class="table-responsive">
        <table class="table table-sm align-middle">
            <thead>
                <tr>
                    <th>Hierarchie</th>
                    <th>Role</th>
                    <th>Visibilite</th>
                    <th>Description</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var role in Model)
                {
                    <tr>
                        <td><span class="badge-3d badge-soumise">@role.Hierarchy</span></td>
                        <td class="fw-semibold">@role.Label</td>
                        <td>@role.Visibility</td>
                        <td class="text-muted-custom">@role.Description</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
