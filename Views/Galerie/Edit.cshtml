@model Galerie
@{
    ViewData["Title"] = "Modifier le média";
    Layout = "_LayoutAdmin";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
    <h2 class="section-title mb-0"><i class="bi bi-pencil text-or"></i> Modifier <span class="accent">le média</span></h2>
    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-or btn-sm" title="Aperçu"><i class="bi bi-eye"></i></a>
</div>

<div class="card-3d p-4" style="max-width:560px;">
    <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
        <div class="mb-3">
            <label class="form-label small" for="titre">Titre</label>
            <input name="titre" id="titre" class="form-control" value="@Model.Titre" required />
            @if (!ViewData.ModelState.IsValid && ViewData.ModelState["titre"]?.Errors.Count > 0)
            {
                <span class="text-danger small">@ViewData.ModelState["titre"]?.Errors.First().ErrorMessage</span>
            }
        </div>
        <div class="mb-3">
            <label class="form-label small" for="description">Description</label>
            <textarea name="description" id="description" class="form-control" rows="3">@Model.Description</textarea>
        </div>
        <div class="mb-4 form-check">
            <input type="hidden" name="estPublie" value="false" />
            <input type="checkbox" name="estPublie" id="estPublie" class="form-check-input" value="true" @(Model.EstPublie ? "checked=\"checked\"" : null) />
            <label class="form-check-label" for="estPublie">Publié (visible sur le site)</label>
        </div>
        <p class="text-muted-custom small">Pour changer le fichier média, supprimez cet élément et ajoutez-en un nouveau.</p>
        <div class="d-flex flex-wrap gap-2">
            <button type="submit" class="btn btn-mango" title="Enregistrer"><i class="bi bi-check-lg"></i></button>
            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary" title="Annuler"><i class="bi bi-x-lg"></i></a>
        </div>
    </form>
</div>
