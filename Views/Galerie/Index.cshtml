@model List<MangoTaika.Data.Entities.Galerie>
@{
    ViewData["Title"] = "Galerie";
    Layout = "_LayoutAdmin";
    var canManage = User.IsInRole("Administrateur") || User.IsInRole("Gestionnaire");
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="section-title mb-0"><i class="bi bi-images text-or"></i> <span class="accent">Galerie</span></h2>
    @if (canManage)
    {
        <a asp-action="Create" class="btn btn-mango"><i class="bi bi-plus-lg"></i> Ajouter un media</a>
    }
</div>

@if (TempData["Warning"] is string warn && !string.IsNullOrEmpty(warn))
{
    <div class="alert alert-warning border-0 mb-3" role="alert">@warn</div>
}

<div class="row g-3">
    @foreach (var item in Model)
    {
        <div class="col-6 col-md-3">
            <div class="card-3d" style="overflow:hidden;">
                @if (item.TypeMedia == "video")
                {
                    <video src="@item.CheminMedia" style="width:100%;height:180px;object-fit:cover;" muted></video>
                }
                else
                {
                    <img src="@item.CheminMedia" alt="@item.Titre" style="width:100%;height:180px;object-fit:cover;" />
                }
                <div class="p-2">
                    <small class="fw-semibold" style="color:var(--bleu-logo);">@item.Titre</small>
                    <div class="d-flex align-items-center flex-wrap gap-1 mt-1">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-or py-0 px-2" style="font-size:0.7rem;" title="Details"><i class="bi bi-eye"></i></a>
                        @if (canManage)
                        {
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-bleu py-0 px-2" style="font-size:0.7rem;" title="Modifier"><i class="bi bi-pencil"></i></a>
                            @if (item.EstPublie)
                            {
                                <form asp-action="Depublier" asp-route-id="@item.Id" method="post" class="d-inline"><button class="btn btn-sm p-0 px-1" style="color:#facc15;font-size:0.75rem;" title="Depublier"><i class="bi bi-eye-slash"></i></button></form>
                            }
                            else
                            {
                                <form asp-action="Publier" asp-route-id="@item.Id" method="post" class="d-inline"><button class="btn btn-sm p-0 px-1" style="color:#34d399;font-size:0.75rem;" title="Publier"><i class="bi bi-send"></i></button></form>
                            }
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Supprimer ce media ?')"><button type="submit" class="btn btn-sm p-0 px-1" style="color:#f87171;font-size:0.75rem;" title="Supprimer"><i class="bi bi-trash"></i></button></form>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>
