@{
    ViewData["Title"] = "Authentification à deux facteurs";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card card-mango p-4">
                <h3>Vérification en deux étapes</h3>
                <p class="text-muted">Entrez le code de votre application d'authentification.</p>
                <form method="post">
                    <div class="mb-3">
                        <label class="form-label">Code</label>
                        <input name="TwoFactorCode" class="form-control" autofocus />
                    </div>
                    <button type="submit" class="btn btn-bleu w-100">Vérifier</button>
                </form>
            </div>
        </div>
    </div>
</div>
