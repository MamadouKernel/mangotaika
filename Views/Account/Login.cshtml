@model LoginViewModel
@{
    ViewData["Title"] = "Connexion";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="auth-card text-center">
                <img src="~/images/logo.png" alt="Logo MANGO TAÏKA" class="auth-logo" />
                <h3 class="mb-1">Connexion</h3>
                <p class="text-muted-custom small mb-4">District Scout MANGO TAÏKA</p>

                <form asp-action="Login" method="post" class="form-modern text-start">
                    <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                    <div class="mb-3">
                        <label asp-for="Telephone" class="form-label">Téléphone</label>
                        <input asp-for="Telephone" class="form-control" placeholder="Ex: 0701020304" autofocus />
                        <span asp-validation-for="Telephone" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Password" class="form-label">Mot de passe</label>
                        <input asp-for="Password" class="form-control" placeholder="••••••••" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>
                    <div class="mb-4 form-check">
                        <input asp-for="RememberMe" class="form-check-input" />
                        <label asp-for="RememberMe" class="form-check-label small" style="color:var(--texte-secondaire);">Se souvenir de moi</label>
                    </div>
                    <button type="submit" class="btn btn-bleu w-100 mb-3">
                        <i class="bi bi-box-arrow-in-right"></i> Se connecter
                    </button>
                </form>
                <div class="mt-3">
                    <a asp-action="Register" class="text-or small">Pas encore de compte ? Inscrivez-vous</a>
                </div>
            </div>
        </div>
    </div>
</div>
