@model ForgotPasswordViewModel
@{
    ViewData["Title"] = "Mot de passe oublie";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="auth-card text-center">
                <img src="~/images/logo.png" alt="Logo MANGO TAIKA" class="auth-logo" />
                <h3 class="mb-1">Mot de passe oublie</h3>
                <p class="text-muted-custom small mb-4">Entrez l'adresse email rattachee a votre compte.</p>

                <form asp-action="ForgotPassword" method="post" class="form-modern text-start">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control" placeholder="exemple@mangotaika.ci" autofocus />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    <button type="submit" class="btn btn-bleu w-100 mb-3">
                        <i class="bi bi-envelope-check"></i> Envoyer le lien
                    </button>
                </form>

                <div class="mt-3">
                    <a asp-action="Login" class="text-or small">Retour a la connexion</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
