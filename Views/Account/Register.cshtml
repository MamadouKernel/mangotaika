@model RegisterViewModel
@{
    ViewData["Title"] = "Inscription";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="auth-card text-center">
                <img src="~/images/logo.png" alt="Logo MANGO TAIKA" class="auth-logo" />
                <h3 class="mb-1">Inscription</h3>
                <p class="text-muted-custom small mb-4">Rejoignez le district MANGO TAIKA</p>

                <form asp-action="Register" method="post" class="form-modern text-start">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <div class="mb-4">
                        <label asp-for="Role" class="form-label">Vous etes</label>
                        <select asp-for="Role" class="form-select" id="roleSelect">
                            <option value="Parent">Parent / Tuteur</option>
                            <option value="Gestionnaire">Gestionnaire</option>
                            <option value="Scout">Scout</option>
                        </select>
                        <span asp-validation-for="Role" class="text-danger small"></span>
                        <p class="text-muted-custom small mt-2 mb-0">
                            <i class="bi bi-info-circle"></i> Le role <strong>Administrateur</strong> n'est pas propose ici : il est attribue uniquement par un administrateur existant, pour des raisons de securite.
                        </p>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Nom" class="form-label">Nom</label>
                            <input asp-for="Nom" class="form-control" />
                            <span asp-validation-for="Nom" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Prenom" class="form-label">Prenom</label>
                            <input asp-for="Prenom" class="form-control" />
                            <span asp-validation-for="Prenom" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Telephone" class="form-label">Numero de telephone</label>
                        <input asp-for="Telephone" class="form-control" placeholder="Ex: 0701020304" />
                        <span asp-validation-for="Telephone" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">Email <span class="text-muted-custom small">(optionnel)</span></label>
                        <input asp-for="Email" class="form-control" placeholder="votre@@email.com" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3" id="matriculesSection">
                        <label asp-for="Matricules" class="form-label">
                            Matricule(s) de vos enfants <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Matricules" class="form-control" placeholder="Ex: 0583753X, 0583754X" />
                        <span asp-validation-for="Matricules" class="text-danger small"></span>
                        <small class="text-muted-custom">Saisissez le(s) matricule(s) separes par des virgules. Format attendu : 0583753X.</small>
                    </div>

                    <div class="mb-3" id="codeSection" style="display:none;">
                        <label asp-for="CodeInvitation" class="form-label">
                            Code d'invitation <span class="text-danger">*</span>
                        </label>
                        <input asp-for="CodeInvitation" class="form-control" placeholder="Ex: MT-20260321-A1B2C3" />
                        <span asp-validation-for="CodeInvitation" class="text-danger small"></span>
                        <small class="text-muted-custom">Ce code vous a ete transmis par un administrateur du district.</small>
                    </div>

                    <div class="mb-3" id="scoutSection" style="display:none;">
                        <label asp-for="MatriculeScout" class="form-label">
                            Mon matricule scout <span class="text-danger">*</span>
                        </label>
                        <input asp-for="MatriculeScout" class="form-control" placeholder="Ex: 0583753X" />
                        <span asp-validation-for="MatriculeScout" class="text-danger small"></span>
                        <small class="text-muted-custom">Votre matricule vous a ete attribue par votre chef de groupe. Format attendu : 0583753X.</small>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label">Mot de passe</label>
                        <input asp-for="Password" class="form-control" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ConfirmPassword" class="form-label">Confirmer le mot de passe</label>
                        <input asp-for="ConfirmPassword" class="form-control" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <partial name="_ConsentementARTCI" />
                    <span asp-validation-for="Consentement" class="text-danger small d-block mb-2"></span>
                    <button type="submit" class="btn btn-mango w-100 mb-3">
                        <i class="bi bi-person-plus-fill"></i> S'inscrire
                    </button>
                </form>

                <div class="mt-3">
                    <a asp-action="Login" class="text-or small">Deja un compte ? Connectez-vous</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const roleSelect = document.getElementById('roleSelect');
            const matriculesSection = document.getElementById('matriculesSection');
            const codeSection = document.getElementById('codeSection');
            const scoutSection = document.getElementById('scoutSection');

            function toggleSections() {
                const role = roleSelect.value;
                matriculesSection.style.display = role === 'Parent' ? 'block' : 'none';
                codeSection.style.display = role === 'Gestionnaire' ? 'block' : 'none';
                scoutSection.style.display = role === 'Scout' ? 'block' : 'none';
            }

            roleSelect.addEventListener('change', toggleSections);
            toggleSections();
        })();
    </script>
    <partial name="_ValidationScriptsPartial" />
}
