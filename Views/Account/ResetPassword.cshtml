@model ResetPasswordViewModel
@{
    ViewData["Title"] = "Reinitialiser le mot de passe";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="auth-card text-center">
                <img src="~/images/logo.png" alt="Logo MANGO TAIKA" class="auth-logo" />
                <h3 class="mb-1">Nouveau mot de passe</h3>
                <p class="text-muted-custom small mb-4">Choisissez un mot de passe solide puis confirmez-le.</p>

                <form asp-action="ResetPassword" method="post" class="form-modern text-start">
                    <input asp-for="UserId" type="hidden" />
                    <input asp-for="Token" type="hidden" />
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label"></label>
                        <input asp-for="Password" class="form-control" autocomplete="new-password" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>
                    <div class="mb-4">
                        <label asp-for="ConfirmPassword" class="form-label"></label>
                        <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-bleu w-100 mb-3">
                        <i class="bi bi-shield-check"></i> Reinitialiser
                    </button>
                </form>

                <div class="mt-3">
                    <a asp-action="Login" class="text-or small">Retour a la connexion</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
