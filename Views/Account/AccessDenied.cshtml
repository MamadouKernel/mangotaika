@{
    ViewData["Title"] = "Accès refusé";
}

<div class="container py-5 text-center" style="max-width:600px;">
    <div class="card-3d p-5">
        <i class="bi bi-shield-lock" style="font-size:4rem;color:var(--vert-logo);opacity:0.6;"></i>
        <h2 class="mt-3 mb-2" style="color:var(--bleu-logo);">Accès refusé</h2>
        <p class="text-muted-custom mb-4">Vous n'avez pas les permissions nécessaires pour accéder à cette page.</p>
        <div class="d-flex gap-2 justify-content-center">
            <a asp-controller="Home" asp-action="Index" class="btn btn-mango"><i class="bi bi-house"></i> Accueil</a>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a asp-controller="Dashboard" asp-action="Index" class="btn btn-outline-or"><i class="bi bi-speedometer2"></i> Tableau de bord</a>
            }
        </div>
    </div>
</div>
