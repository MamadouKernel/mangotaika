@model List<MangoTaika.Data.Entities.CodeInvitation>
@{
    ViewData["Title"] = "Codes d'invitation";
    Layout = "_LayoutAdmin";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="section-title mb-0"><i class="bi bi-key-fill text-or"></i> Codes <span class="accent">d'invitation</span></h2>
    <form asp-action="GenererCode" method="post">
        <button type="submit" class="btn btn-mango" title="Générer un code"><i class="bi bi-plus-lg"></i></button>
    </form>
</div>

<p class="text-muted-custom small mb-4">Ces codes permettent aux gestionnaires de s'inscrire. Chaque code est à usage unique.</p>

<div class="row g-4">
    @foreach (var c in Model)
    {
        <div class="col-lg-4 col-md-6">
            <div class="card-3d p-4 h-100 d-flex flex-column">
                <code class="d-block mb-3" style="font-size:1rem;color:var(--vert-logo);font-weight:700;">@c.Code</code>
                <div class="d-flex flex-column gap-1 mb-3 flex-grow-1" style="font-size:0.85rem;">
                    <span><i class="bi bi-person text-bleu"></i> Généré par @($"{c.Createur.Prenom} {c.Createur.Nom}")</span>
                    <span><i class="bi bi-calendar3 text-or"></i> @c.DateCreation.ToString("dd/MM/yyyy HH:mm")</span>
                    <span>
                        @if (c.EstUtilise)
                        {
                            <span class="badge-3d badge-rejetee">Utilisé</span>
                        }
                        else
                        {
                            <span class="badge-3d badge-validee">Disponible</span>
                        }
                    </span>
                    @if (c.UtilisePar != null)
                    {
                        <span><i class="bi bi-person-check text-bleu"></i> @($"{c.UtilisePar.Prenom} {c.UtilisePar.Nom}")</span>
                        <span><i class="bi bi-clock-history text-or"></i> @(c.DateUtilisation?.ToString("dd/MM/yyyy HH:mm") ?? "—")</span>
                    }
                </div>
                <div class="mt-auto">
                    <a asp-action="DetailsCodeInvitation" asp-route-id="@c.Id" class="btn btn-sm btn-outline-or" title="Détails"><i class="bi bi-eye"></i></a>
                </div>
            </div>
        </div>
    }
    @if (!Model.Any())
    {
        <div class="col-12 text-center text-muted-custom py-5">Aucun code généré</div>
    }
</div>

<partial name="_ListPagination" />
