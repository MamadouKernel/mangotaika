@{
    ViewData["Title"] = "Lien envoye";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="auth-card text-center">
                <img src="~/images/logo.png" alt="Logo MANGO TAIKA" class="auth-logo" />
                <i class="bi bi-envelope-check text-or" style="font-size:3rem;"></i>
                <h3 class="mt-3 mb-2">Lien envoye</h3>
                <p class="text-muted-custom mb-4">
                    Le lien de reinitialisation vient d'etre envoye a l'adresse email du compte.
                    Ouvrez ce lien pour definir et confirmer votre nouveau mot de passe.
                </p>
                <a asp-action="Login" class="btn btn-bleu w-100">
                    <i class="bi bi-box-arrow-in-right"></i> Retour a la connexion
                </a>
            </div>
        </div>
    </div>
</div>
