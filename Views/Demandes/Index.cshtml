@model List<DemandeAutorisationDto>
@using MangoTaika.Data.Entities
@{
    var pageTitle = ViewBag.PageTitle as string ?? "Demandes d'autorisation";
    var pageSubtitle = ViewBag.PageSubtitle as string;
    var isBacklogChefGroupe = ViewBag.BacklogChefGroupe as bool? == true;
    var now = DateTime.UtcNow;
    var demandesSoumises = Model.Count(d => d.Statut == StatutDemande.Soumise);
    var demandesUrgentes = Model.Count(d => d.Statut == StatutDemande.Soumise && (now - d.DateCreation).TotalDays >= 3);
    var demandesAttenteChefGroupe = Model.Count(d => d.Statut == StatutDemande.Soumise && !d.ChefGroupeValidee);
    var demandesAttenteDistrict = Model.Count(d => d.Statut == StatutDemande.Soumise && d.ChefGroupeValidee && d.TypeActivite == TypeActiviteDemande.Camp);
    ViewData["Title"] = pageTitle;
    Layout = "_LayoutAdmin";
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <div>
        <h2 class="section-title mb-1"><i class="bi bi-file-earmark-check-fill text-or"></i> @pageTitle</h2>
        @if (!string.IsNullOrWhiteSpace(pageSubtitle))
        {
            <p class="text-muted-custom mb-0">@pageSubtitle</p>
        }
    </div>
    <a asp-action="Create" class="btn btn-mango" style="@(ViewBag.PeutCreer == true ? string.Empty : "display:none;")"><i class="bi bi-plus-lg"></i> Nouvelle demande</a>
</div>

@if (isBacklogChefGroupe)
{
    <div class="row g-3 mb-4">
        <div class="col-lg-3 col-md-6">
            <div class="card-3d p-3 h-100" style="border-left:4px solid #597537;">
                <div class="text-muted-custom small">File chef de groupe</div>
                <div class="d-flex align-items-end gap-2">
                    <strong style="font-size:2rem;color:var(--bleu-gris);">@demandesAttenteChefGroupe</strong>
                    <span class="pb-2 text-muted-custom">a traiter</span>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6">
            <div class="card-3d p-3 h-100" style="border-left:4px solid #ef4444;">
                <div class="text-muted-custom small">Priorite</div>
                <div class="d-flex align-items-end gap-2">
                    <strong style="font-size:2rem;color:#b91c1c;">@demandesUrgentes</strong>
                    <span class="pb-2 text-muted-custom">urgente(s)</span>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6">
            <div class="card-3d p-3 h-100" style="border-left:4px solid #eab308;">
                <div class="text-muted-custom small">Soumises</div>
                <div class="d-flex align-items-end gap-2">
                    <strong style="font-size:2rem;color:var(--bleu-gris);">@demandesSoumises</strong>
                    <span class="pb-2 text-muted-custom">en cours</span>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6">
            <div class="card-3d p-3 h-100" style="border-left:4px solid #0ea5e9;">
                <div class="text-muted-custom small">Camp</div>
                <div class="d-flex align-items-end gap-2">
                    <strong style="font-size:2rem;color:var(--bleu-gris);">@demandesAttenteDistrict</strong>
                    <span class="pb-2 text-muted-custom">vers district</span>
                </div>
            </div>
        </div>
    </div>
}

<div class="row g-4">
    @foreach (var demande in Model)
    {
        var ageDays = Math.Max(0, (now - demande.DateCreation).Days);
        var isUrgent = demande.Statut == StatutDemande.Soumise && ageDays >= 3;
        var cardStyle = isUrgent
            ? "border:1px solid rgba(239,68,68,0.35);box-shadow:0 16px 36px rgba(239,68,68,0.08);"
            : string.Empty;
        var badgeClass = demande.Statut switch
        {
            StatutDemande.Initialisee => "badge-brouillon",
            StatutDemande.Soumise => "badge-soumise",
            StatutDemande.EnRevision => "badge-archivee",
            StatutDemande.Validee => "badge-validee",
            StatutDemande.Rejetee => "badge-rejetee",
            _ => "badge-brouillon"
        };

        var statutLabel = demande.Statut switch
        {
            StatutDemande.EnRevision => "Modification demandee",
            _ => demande.Statut.ToString()
        };
        var validationLabel = demande.Statut switch
        {
            StatutDemande.Soumise when !demande.ChefGroupeValidee => "Attente chef de groupe",
            StatutDemande.Soumise when demande.ChefGroupeValidee && demande.TypeActivite == TypeActiviteDemande.Camp => "Attente district",
            StatutDemande.Validee when demande.ChefGroupeValidee => "Validee par chef de groupe",
            _ => null
        };

        <div class="col-lg-4 col-md-6">
            <div class="card-3d p-4 h-100 d-flex flex-column" style="@cardStyle">
                <h5 class="text-or mb-2">@demande.Titre</h5>
                <p class="text-muted-custom small mb-2">
                    <span class="badge-3d @badgeClass">@statutLabel</span>
                    @if (!string.IsNullOrWhiteSpace(validationLabel))
                    {
                        <span class="badge-3d badge-soumise ms-1">@validationLabel</span>
                    }
                    @if (demande.Statut == StatutDemande.Soumise)
                    {
                        <span class="badge-3d badge-brouillon ms-1">Depuis @ageDays j</span>
                    }
                    @if (isUrgent)
                    {
                        <span class="badge-3d badge-rejetee ms-1"><i class="bi bi-exclamation-triangle"></i> Urgent</span>
                    }
                </p>
                <div class="d-flex flex-column gap-1 mb-3 flex-grow-1" style="font-size:0.85rem;">
                    <span><i class="bi bi-tag text-bleu"></i> @demande.TypeActivite</span>
                    <span><i class="bi bi-diagram-3 text-bleu"></i> @(demande.NomGroupe ?? "-")</span>
                    <span><i class="bi bi-compass text-or"></i> @(demande.NomBranche ?? "-")</span>
                    <span><i class="bi bi-calendar3 text-or"></i> @demande.DateActivite.ToString("dd/MM/yyyy")</span>
                    <span><i class="bi bi-people text-bleu"></i> @demande.NombreParticipants participant(s)</span>
                    <span><i class="bi bi-person text-bleu"></i> @(demande.NomDemandeur ?? "-")</span>
                </div>
                <div class="mt-auto">
                    <a asp-action="Details" asp-route-id="@demande.Id" class="btn btn-sm btn-outline-or" title="Details"><i class="bi bi-eye"></i> Voir</a>
                </div>
            </div>
        </div>
    }
    @if (!Model.Any())
    {
        <div class="col-12 text-center text-muted-custom py-5">Aucune demande d'autorisation enregistree.</div>
    }
</div>

<partial name="_ListPagination" />
