@model List<DemandeAutorisationDto>
@{
    ViewData["Title"] = "Demandes d'autorisation";
    Layout = "_LayoutAdmin";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="section-title mb-0"><i class="bi bi-file-earmark-check-fill text-or"></i> Demandes <span class="accent">d'autorisation</span></h2>
    <a asp-action="Create" class="btn btn-mango" style="@(ViewBag.PeutCreer == true ? "" : "display:none;")"><i class="bi bi-plus-lg"></i> Nouvelle demande</a>
</div>

<div class="row g-4">
    @foreach (var d in Model)
    {
        var badgeClass = d.Statut switch {
            StatutDemande.Initialisee => "badge-brouillon",
            StatutDemande.Soumise => "badge-soumise",
            StatutDemande.EnRevision => "badge-archivee",
            StatutDemande.Validee => "badge-validee",
            StatutDemande.Rejetee => "badge-rejetee",
            _ => "badge-brouillon"
        };
        <div class="col-lg-4 col-md-6">
            <div class="card-3d p-4 h-100 d-flex flex-column">
                <h5 class="text-or mb-2">@d.Titre</h5>
                <p class="text-muted-custom small mb-2"><span class="badge-3d @badgeClass">@d.Statut</span></p>
                <div class="d-flex flex-column gap-1 mb-3 flex-grow-1" style="font-size:0.85rem;">
                    <span><i class="bi bi-tag text-bleu"></i> @d.TypeActivite</span>
                    <span><i class="bi bi-calendar3 text-or"></i> @d.DateActivite.ToString("dd/MM/yyyy")</span>
                    <span><i class="bi bi-person text-bleu"></i> @(d.NomDemandeur ?? "—")</span>
                </div>
                <div class="mt-auto">
                    <a asp-action="Details" asp-route-id="@d.Id" class="btn btn-sm btn-outline-or" title="Détails"><i class="bi bi-eye"></i></a>
                </div>
            </div>
        </div>
    }
    @if (!Model.Any())
    {
        <div class="col-12 text-center text-muted-custom py-5">Aucune demande</div>
    }
</div>

<partial name="_ListPagination" />
