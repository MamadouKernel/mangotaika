@model DemandeAutorisationDto
@using MangoTaika.Data.Entities
@{
    ViewData["Title"] = Model.Titre;
    Layout = "_LayoutAdmin";
    var canValidateDistrict = ViewBag.CanValidateDistrict as bool? == true;
    var canSubmit = ViewBag.CanSubmit as bool? == true;
    var canManageDocuments = ViewBag.CanManageDocuments as bool? == true;
    var validationTarget = ViewBag.ValidationTarget as string ?? "Commissaire de district";

    var badgeClass = Model.Statut switch
    {
        StatutDemande.Initialisee => "badge-brouillon",
        StatutDemande.Soumise => "badge-soumise",
        StatutDemande.EnRevision => "badge-archivee",
        StatutDemande.Validee => "badge-validee",
        StatutDemande.Rejetee => "badge-rejetee",
        _ => "badge-brouillon"
    };

    var statutLabel = Model.Statut switch
    {
        StatutDemande.Initialisee => "Initialisee",
        StatutDemande.Soumise => "Soumise",
        StatutDemande.EnRevision => "Modification demandee",
        StatutDemande.Validee => "Validee",
        StatutDemande.Rejetee => "Rejetee",
        _ => Model.Statut.ToString()
    };
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="section-title mb-0"><i class="bi bi-file-earmark-check-fill text-or"></i> @Model.Titre</h2>
    <a asp-action="Index" class="btn btn-outline-or" title="Retour"><i class="bi bi-arrow-left"></i></a>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card-3d p-4">
            <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
                <span class="badge-3d @badgeClass" style="font-size:0.85rem;">@statutLabel</span>
                <small class="text-muted-custom">Creee le @Model.DateCreation.ToString("dd/MM/yyyy HH:mm")</small>
            </div>
            @if (canSubmit && (Model.Statut == StatutDemande.Initialisee || Model.Statut == StatutDemande.EnRevision))
            {
                <div class="alert d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3 mb-4" style="background:rgba(89,117,55,0.08);border:1px solid rgba(89,117,55,0.22);border-radius:14px;color:var(--texte);">
                    <div>
                        <strong>Transmission en attente</strong>
                        <div class="small text-muted-custom">Cette demande doit etre soumise au @validationTarget pour entrer dans le circuit de validation.</div>
                    </div>
                    <form asp-action="Soumettre" asp-route-id="@Model.Id" method="post" class="mb-0">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-mango"><i class="bi bi-send"></i> Soumettre</button>
                    </form>
                </div>
            }

            <div class="row mb-3">
                <div class="col-md-6"><p><span class="text-muted-custom">Type :</span> @Model.TypeActivite</p></div>
                <div class="col-md-6"><p><span class="text-muted-custom">Groupe concerne :</span> @(Model.NomGroupe ?? "-")</p></div>
            </div>
            <div class="row mb-3">
                <div class="col-md-6"><p><span class="text-muted-custom">Branche concernee :</span> @(Model.NomBranche ?? "-")</p></div>
                <div class="col-md-6"><p><span class="text-muted-custom">Responsables :</span> @(Model.Responsables ?? "-")</p></div>
            </div>
            <div class="row mb-3">
                <div class="col-md-4"><p><span class="text-muted-custom">Date :</span> @Model.DateActivite.ToString("dd/MM/yyyy")@(Model.DateFin.HasValue ? $" - {Model.DateFin:dd/MM/yyyy}" : string.Empty)</p></div>
                <div class="col-md-4"><p><span class="text-muted-custom">Lieu :</span> @(Model.Lieu ?? "-")</p></div>
                <div class="col-md-4"><p><span class="text-muted-custom">Participants :</span> @Model.NombreParticipants</p></div>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.Description))
            {
                <p><span class="text-muted-custom">Description :</span><br />@Model.Description</p>
            }
            @if (!string.IsNullOrWhiteSpace(Model.Objectifs))
            {
                <p><span class="text-muted-custom">Objectif :</span><br />@Model.Objectifs</p>
            }
            @if (!string.IsNullOrWhiteSpace(Model.MoyensLogistiques))
            {
                <p><span class="text-muted-custom">Moyens logistiques :</span><br />@Model.MoyensLogistiques</p>
            }
            @if (!string.IsNullOrWhiteSpace(Model.Budget))
            {
                <p><span class="text-muted-custom">Budget previsionnel :</span> @Model.Budget</p>
            }
            @if (!string.IsNullOrWhiteSpace(Model.Observations))
            {
                <p><span class="text-muted-custom">Observations :</span><br />@Model.Observations</p>
            }
            @if (!string.IsNullOrWhiteSpace(Model.MotifRejet))
            {
                <div class="alert" style="background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);border-radius:12px;color:#ef4444;">
                    <i class="bi bi-exclamation-triangle-fill"></i> Motif de rejet : @Model.MotifRejet
                </div>
            }

            <hr style="border-color:var(--gris-border);" />
            <p class="text-muted-custom small mb-1">Demandeur : @(Model.NomDemandeur ?? "-")</p>
            @if (!string.IsNullOrWhiteSpace(Model.NomValideur))
            {
                <p class="text-muted-custom small mb-0">Traitee par : @Model.NomValideur le @Model.DateValidation?.ToString("dd/MM/yyyy")</p>
            }

            <div class="d-flex gap-2 mt-3 flex-wrap">
                @if (canSubmit && (Model.Statut == StatutDemande.Initialisee || Model.Statut == StatutDemande.EnRevision))
                {
                    <form asp-action="Soumettre" asp-route-id="@Model.Id" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-mango"><i class="bi bi-send"></i> Soumettre</button>
                    </form>
                }
                @if (canValidateDistrict && Model.Statut == StatutDemande.Soumise)
                {
                    <div class="w-100 alert mb-2" style="background:rgba(89,117,55,0.08);border:1px solid rgba(89,117,55,0.22);border-radius:12px;color:var(--texte);">
                        <i class="bi bi-person-check"></i> Validation attendue : <strong>@validationTarget</strong>
                    </div>
                    <form asp-action="Valider" asp-route-id="@Model.Id" method="post">
                        @Html.AntiForgeryToken()
                        
                        <button type="submit" class="btn btn-sm" style="background:rgba(16,185,129,0.2);color:#34d399;border:1px solid rgba(16,185,129,0.3);border-radius:14px;padding:0.5rem 1.2rem;">Valider</button>
                    </form>
                    <form asp-action="Reviser" asp-route-id="@Model.Id" method="post" onsubmit="const commentaire = prompt('Precisez les modifications demandees :'); if (!commentaire) return false; this.querySelector('[name=commentaire]').value = commentaire;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="commentaire" />
                        <button type="submit" class="btn btn-sm" style="background:rgba(234,179,8,0.2);color:#eab308;border:1px solid rgba(234,179,8,0.3);border-radius:14px;padding:0.5rem 1.2rem;">Demander une modification</button>
                    </form>
                    <form asp-action="Rejeter" asp-route-id="@Model.Id" method="post" onsubmit="const motif = prompt('Precisez le motif du rejet :'); if (!motif) return false; this.querySelector('[name=motif]').value = motif;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="motif" />
                        <button type="submit" class="btn btn-sm" style="background:rgba(239,68,68,0.2);color:#f87171;border:1px solid rgba(239,68,68,0.3);border-radius:14px;padding:0.5rem 1.2rem;">Rejeter</button>
                    </form>
                }
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.TdrContenu))
        {
            <div class="card-3d p-4 mt-4">
                <h5 class="text-or mb-3"><i class="bi bi-file-text"></i> Termes de reference (TDR)</h5>
                <pre style="white-space:pre-wrap;font-family:'Poppins',sans-serif;font-size:0.85rem;color:var(--texte-secondaire);background:var(--gris-bg);padding:1.5rem;border-radius:12px;">@Model.TdrContenu</pre>
            </div>
        }

        <div class="card-3d p-4 mt-4">
            <div class="d-flex align-items-start justify-content-between gap-3 mb-3">
                <div>
                    <h5 class="text-or mb-1"><i class="bi bi-paperclip"></i> Pieces jointes</h5>
                    <p class="text-muted-custom small mb-0">Documents rattaches a la demande et repris dans l'activite apres validation.</p>
                </div>
                <span class="badge-3d badge-brouillon">@Model.Documents.Count</span>
            </div>

            @if (Model.Documents.Any())
            {
                <div class="d-grid gap-2 mb-3">
                    @foreach (var document in Model.Documents)
                    {
                        <div class="d-flex align-items-center justify-content-between gap-3 p-3" style="border:1px solid var(--gris-border);border-radius:14px;background:rgba(255,255,255,0.78);">
                            <div class="d-flex align-items-center gap-3 min-w-0">
                                <span class="d-inline-flex align-items-center justify-content-center" style="width:42px;height:42px;border-radius:12px;background:rgba(89,117,55,0.1);color:#597537;">
                                    <i class="bi bi-file-earmark-text"></i>
                                </span>
                                <div class="min-w-0">
                                    <a href="@document.CheminFichier" target="_blank" rel="noopener" class="fw-semibold text-decoration-none" style="color:var(--texte);">@document.NomFichier</a>
                                    <div class="text-muted-custom small">@(!string.IsNullOrWhiteSpace(document.TypeDocument) ? document.TypeDocument : "Piece jointe") - @document.DateUpload.ToString("dd/MM/yyyy HH:mm")</div>
                                </div>
                            </div>
                            @if (canManageDocuments)
                            {
                                <form asp-action="SupprimerDocument" asp-route-id="@Model.Id" asp-route-documentId="@document.Id" method="post" class="mb-0" onsubmit="return confirm('Retirer cette piece jointe de la demande ?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm" title="Retirer" style="background:rgba(239,68,68,0.1);color:#ef4444;border:1px solid rgba(239,68,68,0.25);border-radius:12px;">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            }
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="alert mb-3" style="background:rgba(148,163,184,0.08);border:1px solid rgba(148,163,184,0.22);border-radius:14px;color:var(--texte-secondaire);">
                    Aucun document joint a cette demande.
                </div>
            }

            @if (canManageDocuments)
            {
                <form asp-action="AjouterDocument" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data" class="row g-2 align-items-end">
                    @Html.AntiForgeryToken()
                    <div class="col-md-5">
                        <label class="form-label small">Type de document</label>
                        <input name="typeDocument" class="form-control" placeholder="Ex: TDR, Budget, Autorisation" />
                    </div>
                    <div class="col-md-5">
                        <label class="form-label small">Document</label>
                        <input name="fichier" class="form-control" type="file" accept=".pdf,.doc,.docx,.xls,.xlsx,.csv,.txt" required />
                    </div>
                    <div class="col-md-2 d-grid">
                        <button type="submit" class="btn btn-mango"><i class="bi bi-upload"></i> Ajouter</button>
                    </div>
                    <div class="col-12">
                        <p class="text-muted-custom small mb-0">Possible uniquement tant que la demande est initialisee ou en revision.</p>
                    </div>
                </form>
            }
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card-3d p-4">
            <h5 class="text-or mb-3"><i class="bi bi-clock-history"></i> Suivi de la demande</h5>
            @if (Model.Suivis.Any())
            {
                <div style="position:relative;padding-left:20px;">
                    <div style="position:absolute;left:8px;top:0;bottom:0;width:2px;background:var(--gris-border);"></div>
                    @foreach (var suivi in Model.Suivis)
                    {
                        var dotColor = suivi.NouveauStatut switch
                        {
                            StatutDemande.Validee => "#34d399",
                            StatutDemande.Rejetee => "#f87171",
                            StatutDemande.Soumise => "#597537",
                            StatutDemande.EnRevision => "#eab308",
                            _ => "#94a3b8"
                        };
                        var suiviLabel = suivi.NouveauStatut switch
                        {
                            StatutDemande.EnRevision => "Modification demandee",
                            _ => suivi.NouveauStatut.ToString()
                        };
                        var commentaire = suivi.Commentaire;
                        if (validationTarget == "Chef de groupe" && commentaire == "Demande soumise pour validation district")
                        {
                            commentaire = "Demande soumise pour validation du chef de groupe";
                        }
                        <div class="mb-3" style="position:relative;">
                            <div style="position:absolute;left:-16px;top:4px;width:12px;height:12px;border-radius:50%;background:@dotColor;border:2px solid #fff;box-shadow:0 0 0 2px @dotColor;"></div>
                            <p class="mb-0" style="font-size:0.8rem;font-weight:600;color:var(--texte);">@suiviLabel</p>
                            <p class="mb-0 text-muted-custom" style="font-size:0.75rem;">@commentaire</p>
                            <p class="mb-0" style="font-size:0.7rem;color:var(--gris-clair);">@suivi.Auteur - @suivi.Date.ToString("dd/MM/yyyy HH:mm")</p>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="text-muted-custom small">Aucun suivi enregistre.</p>
            }
        </div>
    </div>
</div>



