@model MangoTaika.Data.Entities.ProjetAGR
@using MangoTaika.Data.Entities
@{
    ViewData["Title"] = Model.Nom;
    Layout = "_LayoutAdmin";
    var recettes = Model.Transactions.Where(t => t.Type == TypeTransaction.Recette).Sum(t => t.Montant);
    var depenses = Model.Transactions.Where(t => t.Type == TypeTransaction.Depense).Sum(t => t.Montant);
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 class="section-title mb-0"><i class="bi bi-cash-stack text-or"></i> <span class="accent">@Model.Nom</span></h2>
        <small class="text-muted-custom">@(Model.Groupe?.Nom ?? "District") — @(Model.Responsable ?? "—")</small>
    </div>
    <div class="d-flex gap-2">
        @foreach (var s in Enum.GetValues<StatutProjetAGR>())
        {
            if (s != Model.Statut)
            {
                <form asp-action="ChangerStatut" asp-route-id="@Model.Id" method="post" class="d-inline">
                    <input type="hidden" name="statut" value="@s" />
                    <button class="btn btn-sm btn-outline-or">@s</button>
                </form>
            }
        }
        <a asp-action="Index" class="btn btn-outline-or"><i class="bi bi-arrow-left"></i></a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3"><div class="card-3d p-3 text-center"><small class="text-muted-custom">Budget initial</small><h4 style="color:var(--bleu-logo);">@Model.BudgetInitial.ToString("N0")</h4></div></div>
    <div class="col-md-3"><div class="card-3d p-3 text-center"><small class="text-muted-custom">Recettes</small><h4 style="color:#10b981;">+@recettes.ToString("N0")</h4></div></div>
    <div class="col-md-3"><div class="card-3d p-3 text-center"><small class="text-muted-custom">Dépenses</small><h4 style="color:#f87171;">-@depenses.ToString("N0")</h4></div></div>
    <div class="col-md-3"><div class="card-3d p-3 text-center"><small class="text-muted-custom">Bénéfice</small><h4 style="color:@(recettes - depenses >= 0 ? "#10b981" : "#f87171");">@((recettes - depenses).ToString("N0"))</h4></div></div>
</div>

<div class="card-3d p-3 mb-4">
    <form asp-action="AjouterTransaction" asp-route-id="@Model.Id" method="post" class="row g-2 align-items-end">
        <div class="col-md-3"><label class="form-label small">Libellé</label><input name="Libelle" class="form-control" required /></div>
        <div class="col-md-2"><label class="form-label small">Montant</label><input name="Montant" class="form-control" type="number" min="0" step="100" required /></div>
        <div class="col-md-2"><label class="form-label small">Type</label><select name="Type" class="form-select"><option value="Recette">Recette</option><option value="Depense">Dépense</option></select></div>
        <div class="col-md-2"><label class="form-label small">Date</label><input name="DateTransaction" class="form-control" type="date" value="@DateTime.Now.ToString("yyyy-MM-dd")" required /></div>
        <div class="col-auto"><button type="submit" class="btn btn-mango"><i class="bi bi-plus-lg"></i></button></div>
    </form>
</div>

<div class="card-3d">
    <div class="table-responsive">
        <table class="table-modern">
            <thead><tr><th>Date</th><th>Libellé</th><th>Montant</th></tr></thead>
            <tbody>
                @foreach (var t in Model.Transactions)
                {
                    <tr>
                        <td>@t.DateTransaction.ToString("dd/MM/yyyy")</td>
                        <td>@t.Libelle</td>
                        <td style="font-weight:700;color:@(t.Type == TypeTransaction.Recette ? "#10b981" : "#f87171");">@(t.Type == TypeTransaction.Recette ? "+" : "-")@t.Montant.ToString("N0") FCFA</td>
                    </tr>
                }
                @if (!Model.Transactions.Any()){<tr><td colspan="3" class="text-center text-muted-custom py-4">Aucune transaction</td></tr>}
            </tbody>
        </table>
    </div>
</div>
