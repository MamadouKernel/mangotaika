@model List<MangoTaika.Data.Entities.ProjetAGR>
@using MangoTaika.Data.Entities
@{
    ViewData["Title"] = "Projets AGR";
    Layout = "_LayoutAdmin";
    var canManage = User.IsInRole("Administrateur") || User.IsInRole("Gestionnaire");
    var groupes = ViewBag.Groupes as List<Groupe> ?? new();
    var scouts = ViewBag.Scouts as List<Scout> ?? new();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="section-title mb-0"><i class="bi bi-cash-stack text-or"></i> Projets <span class="accent">AGR</span></h2>
</div>

@if (canManage)
{
    <div class="card-3d p-3 mb-4">
        <h6 style="color:var(--bleu-logo);"><i class="bi bi-plus-circle"></i> Nouveau projet AGR</h6>
        <form asp-action="Create" method="post" class="row g-2 align-items-end mt-2">
            <div class="col-md-3"><label class="form-label small">Nom du projet</label><input name="Nom" class="form-control" required /></div>
            <div class="col-md-2"><label class="form-label small">Budget initial (FCFA)</label><input name="BudgetInitial" class="form-control" type="number" min="0" step="100" required /></div>
            <div class="col-md-2"><label class="form-label small">Date debut</label><input name="DateDebut" class="form-control" type="date" value="@DateTime.Now.ToString("yyyy-MM-dd")" required /></div>
            <div class="col-md-2" data-searchable-select-wrapper>
                <label class="form-label small">Responsable</label>
                <input type="search" class="form-control form-control-sm mb-2" placeholder="Rechercher un responsable..." data-select-search-input />
                <select name="Responsable" class="form-select" data-searchable-select data-filter-group-select="agrGroupeSelect">
                    <option value="">-</option>
                    @foreach (var s in scouts)
                    {
                        <option value="@($"{s.Prenom} {s.Nom}")"
                                data-group="@(s.GroupeId?.ToString() ?? string.Empty)"
                                data-search-label="@($"{s.Prenom} {s.Nom} {s.Matricule}")">
                            @s.Prenom @s.Nom (@s.Matricule)
                        </option>
                    }
                </select>
                <small class="text-muted-custom" data-select-search-empty hidden>Aucun responsable correspondant.</small>
            </div>
            <div class="col-md-2"><label class="form-label small">Groupe</label><select id="agrGroupeSelect" name="GroupeId" class="form-select"><option value="">- District -</option>@foreach(var g in groupes){<option value="@g.Id">@g.Nom</option>}</select></div>
            <div class="col-auto"><button type="submit" class="btn btn-mango"><i class="bi bi-check-lg"></i></button></div>
        </form>
    </div>
}

<div class="row g-3">
    @foreach (var p in Model)
    {
        var recettes = p.Transactions.Where(t => t.Type == TypeTransaction.Recette).Sum(t => t.Montant);
        var depenses = p.Transactions.Where(t => t.Type == TypeTransaction.Depense).Sum(t => t.Montant);
        var benefice = recettes - depenses;
        <div class="col-md-4">
            <div class="card-3d p-4 h-100">
                <div class="d-flex justify-content-between align-items-start">
                    <h6 style="color:var(--bleu-logo);font-weight:700;">@p.Nom</h6>
                    <span class="badge-3d badge-@p.Statut.ToString().ToLower()" style="font-size:0.7rem;">@p.Statut</span>
                </div>
                <small class="text-muted-custom">@(p.Groupe?.Nom ?? "District") - @(p.Responsable ?? "-")</small>
                <div class="mt-3">
                    <div class="d-flex justify-content-between"><small>Budget initial</small><small style="font-weight:600;">@p.BudgetInitial.ToString("N0") FCFA</small></div>
                    <div class="d-flex justify-content-between"><small style="color:#10b981;">Recettes</small><small style="color:#10b981;font-weight:600;">+@recettes.ToString("N0")</small></div>
                    <div class="d-flex justify-content-between"><small style="color:#f87171;">Depenses</small><small style="color:#f87171;font-weight:600;">-@depenses.ToString("N0")</small></div>
                    <hr style="margin:6px 0;border-color:var(--gris-border);" />
                    <div class="d-flex justify-content-between"><small style="font-weight:700;">Benefice</small><small style="font-weight:700;color:@(benefice >= 0 ? "#10b981" : "#f87171");">@benefice.ToString("N0") FCFA</small></div>
                </div>
                <div class="d-flex flex-wrap gap-2 mt-3">
                    <a asp-action="Details" asp-route-id="@p.Id" class="btn btn-sm btn-outline-or" title="Details"><i class="bi bi-eye"></i></a>
                    @if (canManage)
                    {
                        <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-bleu" title="Modifier"><i class="bi bi-pencil"></i></a>
                        <form asp-action="Delete" asp-route-id="@p.Id" method="post" class="d-inline" onsubmit="return confirm('Supprimer ?')">
                            <button type="submit" class="btn btn-sm" style="color:#f87171;" title="Supprimer"><i class="bi bi-trash"></i></button>
                        </form>
                    }
                </div>
            </div>
        </div>
    }
</div>

<partial name="_ListPagination" />
