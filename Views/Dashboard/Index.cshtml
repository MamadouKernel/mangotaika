    .dashboard-alert-metric--ok strong {
        color: #166534;
    }

    .dashboard-table-count {
        display: inline-flex;
        align-items: center;
        padding: 0.35rem 0.65rem;
        border-radius: 999px;
        background: #f7faf4;
        border: 1px solid rgba(95, 134, 44, 0.16);
        color: var(--vert-logo);
        font-size: 0.82rem;
        font-weight: 700;
    }

    .dashboard-table-pager {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 0.65rem;
        margin-top: 1rem;
    }

    .dashboard-table-pager__btn {
        width: 36px;
        height: 36px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 999px;
        border: 1px solid rgba(95, 134, 44, 0.22);
        background: #fff;
        color: var(--vert-logo);
        transition: all 0.2s ease;
    }

    .dashboard-table-pager__btn:hover:not(:disabled) {
        background: var(--vert-logo);
        color: #fff;
    }

    .dashboard-table-pager__btn:disabled {
        opacity: 0.42;
        cursor: not-allowed;
    }

    .dashboard-table-pager__info {
        min-width: 110px;
        text-align: center;
        color: var(--bleu-gris);
        font-size: 0.9rem;
        font-weight: 700;
    }

    @@media (max-width: 767.98px) {
        .stat-card-3d--feature {
            padding: 1.5rem;
        }

        .dashboard-feature-top {
