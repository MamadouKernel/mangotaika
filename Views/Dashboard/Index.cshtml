</style>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        document.querySelectorAll('[data-dashboard-group-list]').forEach((container) => {
            const rows = Array.from(container.querySelectorAll('[data-dashboard-group-row]'));
            const pageSize = Number.parseInt(container.dataset.pageSize || '5', 10);
            const pager = container.querySelector('[data-dashboard-group-pager]');
            if (!pager || rows.length <= pageSize) {
                return;
            }

            const previousButton = pager.querySelector('[data-dashboard-group-prev]');
            const nextButton = pager.querySelector('[data-dashboard-group-next]');
            const info = pager.querySelector('[data-dashboard-group-info]');
            const totalPages = Math.ceil(rows.length / pageSize);
            let currentPage = 0;

            const render = () => {
                rows.forEach((row, index) => {
                    const isVisible = index >= currentPage * pageSize && index < (currentPage + 1) * pageSize;
                    row.hidden = !isVisible;
                });

                if (info) {
                    info.textContent = `Page ${currentPage + 1} / ${totalPages}`;
                }

                if (previousButton) {
                    previousButton.disabled = currentPage === 0;
                }

                if (nextButton) {
                    nextButton.disabled = currentPage >= totalPages - 1;
                }
            };

            previousButton?.addEventListener('click', () => {
                if (currentPage > 0) {
                    currentPage -= 1;
                    render();
                }
            });

            nextButton?.addEventListener('click', () => {
                if (currentPage < totalPages - 1) {
                    currentPage += 1;
                    render();
                }
            });

            render();
        });
    });
</script>
