@using MangoTaika.Data.Entities
@model List<Permission>
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Permissions roles";

    var roles = ViewBag.Roles as List<Microsoft.AspNetCore.Identity.IdentityRole<Guid>> ?? new();
    var selectedRoleId = ViewBag.SelectedRoleId as Guid?;
    var selectedRoleName = ViewBag.SelectedRoleName as string ?? "Aucun role";
    var selectedPermissions = ViewBag.SelectedPermissions as HashSet<Guid> ?? new();
    var grouped = Model.GroupBy(p => p.Module).OrderBy(g => g.Key).ToList();
    var permissionCount = Model.Count;
    var selectedCount = selectedPermissions.Count;
    var selectedRatio = permissionCount == 0 ? 0 : (int)Math.Round(selectedCount * 100m / permissionCount);
    var selectedModules = grouped.Count(module => module.Any(p => selectedPermissions.Contains(p.Id)));
    var moduleIcons = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
    {
        ["Administration"] = "bi-shield-lock",
        ["Activites"] = "bi-calendar-check",
        ["Boutique"] = "bi-bag-check",
        ["Communication"] = "bi-megaphone",
        ["Demandes"] = "bi-clipboard-check",
        ["Finances"] = "bi-wallet2",
        ["Formations"] = "bi-mortarboard",
        ["Reporting"] = "bi-graph-up-arrow",
        ["Support"] = "bi-headset",
        ["Territoire"] = "bi-diagram-3"
    };
}

<section class="container-fluid permissions-page py-4" data-permissions-root>
    <div class="permissions-hero">
        <div class="permissions-hero__title">
            <span class="permissions-kicker"><i class="bi bi-shield-lock"></i> Controle d'acces</span>
            <h1>Permissions par role</h1>
            <p>Attribuez les vues et les actions autorisees par role. Ces droits pilotent les menus, les pages protegees et les actions sensibles.</p>
        </div>

        <div class="permissions-hero__stats">
            <div>
                <strong>@roles.Count</strong>
                <span>roles</span>
            </div>
            <div>
                <strong>@grouped.Count</strong>
                <span>modules</span>
            </div>
            <div>
                <strong data-selected-total>@selectedCount</strong>
                <span>droits actifs</span>
            </div>
        </div>
    </div>

    <div class="permissions-role-panel">
        <form method="get" class="permissions-role-form">
            <div>
                <label class="form-label">Role a configurer</label>
                <select name="roleId" class="form-select" onchange="this.form.submit()">
                    @foreach (var role in roles)
                    {
                        <option value="@role.Id" selected="@(role.Id == selectedRoleId ? "selected" : null)">@role.Name</option>
                    }
                </select>
            </div>
            <button type="submit" class="btn btn-or"><i class="bi bi-arrow-repeat"></i> Charger</button>
            <a asp-controller="Roles" asp-action="Index" class="btn btn-outline-or">
                <i class="bi bi-arrow-left"></i> Roles
            </a>
        </form>
        <div class="permissions-role-panel__hint">
            <i class="bi bi-info-circle"></i>
            Les changements sont appliques apres enregistrement. Un utilisateur deja connecte peut devoir se reconnecter pour voir le menu mis a jour.
        </div>
    </div>

    @if (selectedRoleId.HasValue)
    {
        <form asp-action="Enregistrer" method="post" class="permissions-workspace">
            @Html.AntiForgeryToken()
            <input type="hidden" name="roleId" value="@selectedRoleId" />

            <aside class="permissions-summary-panel">
                <span class="badge-soft">Role selectionne</span>
                <h2>@selectedRoleName</h2>
                <p>Les permissions cochees pilotent a la fois l'affichage des menus et l'acces direct aux pages protegees.</p>

                <div class="permissions-summary-grid">
                    <div>
                        <strong data-selected-total-inline>@selectedCount</strong>
                        <span>droits attribues</span>
                    </div>
                    <div>
                        <strong>@selectedModules</strong>
                        <span>modules couverts</span>
                    </div>
                </div>

                <div class="permissions-score">
                    <div class="permissions-score__head">
                        <span>Couverture</span>
                        <strong data-selected-ratio>@selectedRatio%</strong>
                    </div>
                    <div class="permissions-meter">
                        <span style="width: @selectedRatio%"></span>
                    </div>
                    <small><span data-selected-total-inline>@selectedCount</span> sur @permissionCount permissions</small>
                </div>

                <button type="submit" class="btn btn-or w-100">
                    <i class="bi bi-check2-circle"></i> Enregistrer
                </button>

                <div class="permissions-alert">
                    <i class="bi bi-exclamation-triangle"></i>
                    <span>Retirer une permission peut masquer une vue et bloquer son acces direct.</span>
                </div>
            </aside>

            <div class="permissions-board">
                <div class="permissions-toolbar">
                    <div class="permissions-search">
                        <i class="bi bi-search"></i>
                        <input type="search" class="form-control" placeholder="Rechercher une permission, un module ou un code..." data-permission-search />
                    </div>
                    <div class="permissions-toolbar__actions">
                        <button type="button" class="btn btn-outline-or" data-select-visible>
                            <i class="bi bi-check2-square"></i> Tout cocher
                        </button>
                        <button type="button" class="btn btn-outline-danger" data-clear-visible>
                            <i class="bi bi-x-square"></i> Tout retirer
                        </button>
                    </div>
                </div>

                <div class="permissions-modules">
                    @foreach (var module in grouped)
                    {
                        var icon = moduleIcons.TryGetValue(module.Key, out var moduleIcon) ? moduleIcon : "bi-grid-1x2";
                        var modulePermissions = module.ToList();
                        var moduleSelected = modulePermissions.Count(p => selectedPermissions.Contains(p.Id));
                        var moduleRatio = modulePermissions.Count == 0 ? 0 : (int)Math.Round(moduleSelected * 100m / modulePermissions.Count);

                        <section class="permissions-module" data-permission-module>
                            <div class="permissions-module__header">
                                <div class="permissions-module__identity">
                                    <span><i class="bi @icon"></i></span>
                                    <div>
                                        <strong>@module.Key</strong>
                                        <small><span data-module-selected>@moduleSelected</span> / @modulePermissions.Count droits</small>
                                    </div>
                                </div>
                                <div class="permissions-module__actions">
                                    <button type="button" class="btn btn-sm btn-outline-or" data-select-module>Cocher</button>
                                    <button type="button" class="btn btn-sm btn-light" data-clear-module>Retirer</button>
                                </div>
                            </div>

                            <div class="permissions-module__meter">
                                <span style="width: @moduleRatio%" data-module-meter></span>
                            </div>

                            <div class="permissions-list">
                                @foreach (var permission in modulePermissions)
                                {
                                    var inputId = $"perm_{permission.Id:N}";
                                    var isChecked = selectedPermissions.Contains(permission.Id);
                                    var codeParts = permission.Code.Split('.', StringSplitOptions.RemoveEmptyEntries);
                                    var actionLabel = codeParts.Length > 0 ? codeParts[^1] : permission.Code;

                                    <label class="permission-item @(isChecked ? "is-selected" : null)" for="@inputId">
                                        <input id="@inputId"
                                               class="permission-check"
                                               type="checkbox"
                                               name="permissionIds"
                                               value="@permission.Id"
                                               checked="@isChecked" />
                                        <span class="permission-item__content">
                                            <span class="permission-item__topline">
                                                <strong>@permission.Libelle</strong>
                                                <em>@actionLabel</em>
                                            </span>
                                            <small>@permission.Description</small>
                                            <code>@permission.Code</code>
                                        </span>
                                    </label>
                                }
                            </div>
                        </section>
                    }
                </div>
            </div>
        </form>
    }
</section>

@section Scripts {
    <script>
        (() => {
            const root = document.querySelector('[data-permissions-root]');
            if (!root) return;

            const checks = [...root.querySelectorAll('.permission-check')];
            const search = root.querySelector('[data-permission-search]');
            const total = checks.length;

            const sync = () => {
                const selected = checks.filter(check => check.checked).length;
                const ratio = total === 0 ? 0 : Math.round((selected / total) * 100);
                root.querySelectorAll('[data-selected-total]').forEach(el => el.textContent = selected);
                root.querySelectorAll('[data-selected-total-inline]').forEach(el => el.textContent = selected);
                root.querySelectorAll('[data-selected-ratio]').forEach(el => el.textContent = `${ratio}%`);
                root.querySelectorAll('.permissions-meter span').forEach(el => el.style.width = `${ratio}%`);

                root.querySelectorAll('[data-permission-module]').forEach(module => {
                    const moduleChecks = [...module.querySelectorAll('.permission-check')];
                    const moduleSelected = moduleChecks.filter(check => check.checked).length;
                    const moduleRatio = moduleChecks.length === 0 ? 0 : Math.round((moduleSelected / moduleChecks.length) * 100);
                    const moduleCount = module.querySelector('[data-module-selected]');
                    const moduleMeter = module.querySelector('[data-module-meter]');
                    if (moduleCount) moduleCount.textContent = moduleSelected;
                    if (moduleMeter) moduleMeter.style.width = `${moduleRatio}%`;
                });

                root.querySelectorAll('.permission-item').forEach(item => {
                    const check = item.querySelector('.permission-check');
                    item.classList.toggle('is-selected', check?.checked === true);
                });
            };

            const visibleChecks = scope => [...scope.querySelectorAll('.permission-item:not([hidden]) .permission-check')];

            root.addEventListener('change', event => {
                if (event.target.matches('.permission-check')) sync();
            });

            root.querySelector('[data-select-visible]')?.addEventListener('click', () => {
                visibleChecks(root).forEach(check => check.checked = true);
                sync();
            });

            root.querySelector('[data-clear-visible]')?.addEventListener('click', () => {
                visibleChecks(root).forEach(check => check.checked = false);
                sync();
            });

            root.querySelectorAll('[data-select-module]').forEach(button => {
                button.addEventListener('click', () => {
                    const module = button.closest('[data-permission-module]');
                    visibleChecks(module).forEach(check => check.checked = true);
                    sync();
                });
            });

            root.querySelectorAll('[data-clear-module]').forEach(button => {
                button.addEventListener('click', () => {
                    const module = button.closest('[data-permission-module]');
                    visibleChecks(module).forEach(check => check.checked = false);
                    sync();
                });
            });

            search?.addEventListener('input', () => {
                const query = search.value.trim().toLowerCase();
                root.querySelectorAll('[data-permission-module]').forEach(module => {
                    let hasVisibleItem = false;
                    module.querySelectorAll('.permission-item').forEach(item => {
                        const isVisible = !query || item.textContent.toLowerCase().includes(query);
                        item.hidden = !isVisible;
                        hasVisibleItem = hasVisibleItem || isVisible;
                    });
                    module.hidden = !hasVisibleItem;
                });
            });

            sync();
        })();
    </script>
}
