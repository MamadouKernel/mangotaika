@model MangoTaika.Data.Entities.Scout
@using MangoTaika.Data.Entities
@{
    ViewData["Title"] = $"Progression - {Model.Prenom} {Model.Nom}";
    Layout = "_LayoutAdmin";
    var activites = ViewBag.ActivitesParticipees as List<ParticipantActivite> ?? new();
    var etapesValidees = ViewBag.EtapesValidees as List<EtapeParcoursScout> ?? new();
    var etapesRestantes = ViewBag.EtapesRestantes as List<EtapeParcoursScout> ?? new();
    var prochaineEtape = ViewBag.ProchaineEtape as EtapeParcoursScout;
    var etapes = Model.EtapesParcours.OrderBy(e => e.OrdreAffichage).ThenBy(e => e.NomEtape).ToList();
    var prochainePosition = etapes.Any() ? etapes.Max(e => e.OrdreAffichage) + 1 : 1;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="section-title mb-0"><i class="bi bi-graph-up-arrow text-or"></i> Progression de <span class="accent">@Model.Prenom @Model.Nom</span></h2>
    <a asp-action="Index" class="btn btn-outline-or"><i class="bi bi-arrow-left"></i> Retour</a>
</div>

<div class="card-3d p-4 mb-4">
    <div class="row align-items-center">
        <div class="col-md-2 text-center">
            @if (!string.IsNullOrEmpty(Model.PhotoUrl))
            {
                <img src="@Model.PhotoUrl" alt="Photo" style="width:80px;height:80px;object-fit:cover;border-radius:50%;border:3px solid var(--vert-pastel);" />
            }
            else
            {
                <div style="width:80px;height:80px;border-radius:50%;background:var(--vert-logo);display:flex;align-items:center;justify-content:center;margin:0 auto;"><i class="bi bi-person-fill" style="font-size:2rem;color:#fff;"></i></div>
            }
        </div>
        <div class="col-md-10">
            <div class="row">
                <div class="col-md-3"><small class="text-muted-custom">Matricule</small><p style="font-weight:600;color:var(--bleu-logo);">@Model.Matricule</p></div>
                <div class="col-md-3"><small class="text-muted-custom">Groupe</small><p>@(Model.Groupe?.Nom ?? "-")</p></div>
                <div class="col-md-3"><small class="text-muted-custom">Branche</small><p>@(Model.Branche?.Nom ?? "-")</p></div>
                <div class="col-md-3"><small class="text-muted-custom">Inscrit le</small><p>@Model.DateInscription.ToString("dd/MM/yyyy")</p></div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4"><div class="card-3d p-3 text-center"><small class="text-muted-custom">Etapes validees</small><h3 style="color:#10b981;">@etapesValidees.Count</h3></div></div>
    <div class="col-md-4"><div class="card-3d p-3 text-center"><small class="text-muted-custom">Etapes restantes</small><h3 style="color:#f59e0b;">@etapesRestantes.Count</h3></div></div>
    <div class="col-md-4"><div class="card-3d p-3 text-center"><small class="text-muted-custom">Prochaine etape</small><h6 style="color:var(--bleu-logo);">@(prochaineEtape?.NomEtape ?? "Non planifiee")</h6><div class="small text-muted-custom">@(prochaineEtape?.DatePrevisionnelle?.ToString("dd/MM/yyyy") ?? "A definir")</div></div></div>
</div>

<div class="card-3d p-4 mb-4">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-3">
        <div>
            <h5 class="mb-1"><i class="bi bi-signpost-split text-or"></i> Parcours scout</h5>
            <p class="text-muted-custom mb-0">Le cahier de charge demande un suivi des etapes validees, des etapes restantes et des dates previsionnelles.</p>
        </div>
        <span class="badge-3d badge-soumise">Situation actuelle: @(etapesValidees.LastOrDefault()?.NomEtape ?? "Aucune etape validee")</span>
    </div>

    @if (etapes.Any())
    {
        <div class="table-responsive mb-4">
            <table class="table-modern">
                <thead>
                    <tr>
                        <th>Ordre</th>
                        <th>Etape</th>
                        <th>Validation</th>
                        <th>Prevision</th>
                        <th>Statut</th>
                        <th>Observations</th>
                        <th>Mise a jour</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var etape in etapes)
                {
                    var estValidee = etape.DateValidation.HasValue;
                    <tr>
                        <td>@etape.OrdreAffichage</td>
                        <td style="font-weight:600;color:var(--bleu-logo);">@etape.NomEtape</td>
                        <td>@(etape.DateValidation?.ToString("dd/MM/yyyy") ?? "-")</td>
                        <td>@(etape.DatePrevisionnelle?.ToString("dd/MM/yyyy") ?? "-")</td>
                        <td><span class="badge-3d @(estValidee ? "badge-approuvee" : "badge-soumise")">@(estValidee ? "Validee" : "Restante")</span></td>
                        <td>@(string.IsNullOrWhiteSpace(etape.Observations) ? "-" : etape.Observations)</td>
                        <td style="min-width:260px;">
                            <form asp-action="MettreAJourEtapeParcours" method="post" class="d-flex flex-column gap-2">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@etape.Id" />
                                <div class="d-flex gap-2">
                                    <input name="ordreAffichage" class="form-control form-control-sm" type="number" min="1" value="@etape.OrdreAffichage" />
                                    <input name="dateValidation" class="form-control form-control-sm" type="date" value="@(etape.DateValidation?.ToString("yyyy-MM-dd"))" />
                                    <input name="datePrevisionnelle" class="form-control form-control-sm" type="date" value="@(etape.DatePrevisionnelle?.ToString("yyyy-MM-dd"))" />
                                </div>
                                <textarea name="observations" class="form-control form-control-sm" rows="2" placeholder="Observations">@etape.Observations</textarea>
                                <div class="d-flex gap-2 justify-content-end">
                                    <button type="submit" class="btn btn-sm btn-mango"><i class="bi bi-check-lg"></i></button>
                                </div>
                            </form>
                            <form asp-action="SupprimerEtapeParcours" asp-route-id="@etape.Id" method="post" class="mt-2 d-flex justify-content-end" onsubmit="return confirm('Supprimer cette etape ?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm" style="background:rgba(239,68,68,0.15);color:#f87171;border:1px solid rgba(239,68,68,0.3);border-radius:14px;"><i class="bi bi-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-muted-custom mb-4">Aucune etape du parcours n'est encore enregistree pour ce scout.</div>
    }

    <div class="p-3" style="background:var(--fond-carte);border-radius:12px;">
        <h6 style="color:var(--bleu-logo);"><i class="bi bi-plus-circle"></i> Ajouter une etape du parcours</h6>
        <form asp-action="AjouterEtapeParcours" method="post" class="row g-2 align-items-end mt-2">
            @Html.AntiForgeryToken()
            <input type="hidden" name="ScoutId" value="@Model.Id" />
            <div class="col-lg-3"><label class="form-label small">Nom de l'etape</label><input name="NomEtape" class="form-control" placeholder="Promesse, badge, passage..." required /></div>
            <div class="col-lg-1"><label class="form-label small">Ordre</label><input name="OrdreAffichage" class="form-control" type="number" min="1" value="@prochainePosition" /></div>
            <div class="col-lg-2"><label class="form-label small">Date validation</label><input name="DateValidation" class="form-control" type="date" /></div>
            <div class="col-lg-2"><label class="form-label small">Date previsionnelle</label><input name="DatePrevisionnelle" class="form-control" type="date" /></div>
            <div class="col-lg-3"><label class="form-label small">Observations</label><input name="Observations" class="form-control" placeholder="Notes ou objectif" /></div>
            <div class="col-auto"><button type="submit" class="btn btn-mango btn-sm"><i class="bi bi-check-lg"></i></button></div>
        </form>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card-3d p-4 h-100">
            <h5><i class="bi bi-award-fill text-or"></i> Competences (@Model.Competences.Count)</h5>
            @if (Model.Competences.Any())
            {
                <div class="mt-3">
                @foreach (var c in Model.Competences.OrderByDescending(x => x.DateObtention))
                {
                    var couleur = c.Niveau switch { "Expert" => "#10b981", "Avance" => "#3b82f6", "Intermediaire" => "#eab308", _ => "#94a3b8" };
                    <div class="d-flex justify-content-between align-items-center p-2 mb-2" style="background:var(--fond-carte);border-radius:10px;">
                        <div>
                            <span style="font-weight:600;color:var(--bleu-logo);">@c.Nom</span>
                            <small class="text-muted-custom ms-1">(@c.Type)</small>
                            <br /><small class="text-muted-custom">@c.DateObtention.ToString("dd/MM/yyyy")</small>
                        </div>
                        <span class="badge" style="background:@(couleur)20;color:@couleur;border:1px solid @(couleur)40;border-radius:10px;">@c.Niveau</span>
                    </div>
                }
                </div>
            }
            else
            {
                <p class="text-muted-custom mt-3">Aucune competence enregistree.</p>
            }
        </div>
    </div>

    <div class="col-md-6">
        <div class="card-3d p-4 h-100">
            <h5><i class="bi bi-clock-history text-or"></i> Historique des fonctions (@Model.HistoriqueFonctions.Count)</h5>
            @if (Model.HistoriqueFonctions.Any())
            {
                <div class="mt-3">
                @foreach (var h in Model.HistoriqueFonctions.OrderByDescending(x => x.DateDebut))
                {
                    <div class="d-flex gap-3 p-2 mb-2" style="background:var(--fond-carte);border-radius:10px;">
                        <div style="min-width:4px;background:var(--vert-logo);border-radius:4px;"></div>
                        <div>
                            <span style="font-weight:600;color:var(--bleu-logo);">@h.Fonction</span>
                            @if (h.Groupe != null)
                            {
                                <small class="text-muted-custom"> - @h.Groupe.Nom</small>
                            }
                            <br /><small class="text-muted-custom">@h.DateDebut.ToString("dd/MM/yyyy") -> @(h.DateFin?.ToString("dd/MM/yyyy") ?? "En cours")</small>
                        </div>
                    </div>
                }
                </div>
            }
            else
            {
                <p class="text-muted-custom mt-3">Aucun historique.</p>
            }
        </div>
    </div>
</div>

<div class="card-3d p-4 mt-4">
    <h5><i class="bi bi-mortarboard-fill text-or"></i> Suivi academique (@Model.SuivisAcademiques.Count)</h5>
    @if (Model.SuivisAcademiques.Any())
    {
        <div class="table-responsive mt-3">
            <table class="table-modern">
                <thead><tr><th>Annee scolaire</th><th>Etablissement</th><th>Niveau</th><th>Classe</th><th>Moyenne</th><th>Mention</th><th>Redoublant</th><th></th></tr></thead>
                <tbody>
                    @foreach (var sa in Model.SuivisAcademiques.OrderByDescending(x => x.AnneeScolaire))
                    {
                        var couleurMoy = sa.MoyenneGenerale switch { >= 16 => "#10b981", >= 14 => "#3b82f6", >= 10 => "#eab308", _ => "#f87171" };
                        <tr>
                            <td style="font-weight:600;">@sa.AnneeScolaire</td>
                            <td>@(sa.Etablissement ?? "-")</td>
                            <td>@sa.NiveauScolaire</td>
                            <td>@(sa.Classe ?? "-")</td>
                            <td><span style="font-weight:700;color:@(sa.MoyenneGenerale.HasValue ? couleurMoy : "#94a3b8");">@(sa.MoyenneGenerale?.ToString("F2") ?? "-")</span></td>
                            <td>@(sa.Mention ?? "-")</td>
                            <td>@(sa.EstRedoublant ? "Oui" : "Non")</td>
                            <td>
                                <form asp-action="SupprimerSuiviAcademique" asp-route-id="@sa.Id" method="post" class="d-inline" onsubmit="return confirm('Supprimer ?')">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-sm p-0 px-1" style="color:#f87171;"><i class="bi bi-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p class="text-muted-custom mt-3">Aucun suivi academique enregistre.</p>
    }

    <div class="mt-3 p-3" style="background:var(--fond-carte);border-radius:12px;">
        <h6 style="color:var(--bleu-logo);"><i class="bi bi-plus-circle"></i> Ajouter un suivi</h6>
        <form asp-controller="Competences" asp-action="AjouterSuiviAcademique" method="post" class="row g-2 align-items-end mt-2">
            @Html.AntiForgeryToken()
            <input type="hidden" name="ScoutId" value="@Model.Id" />
            <div class="col-md-2"><label class="form-label small">Annee scolaire</label><input name="AnneeScolaire" class="form-control" placeholder="2025-2026" required /></div>
            <div class="col-md-2"><label class="form-label small">Etablissement</label><input name="Etablissement" class="form-control" /></div>
            <div class="col-md-2"><label class="form-label small">Niveau</label><input name="NiveauScolaire" class="form-control" placeholder="CM2, 6eme..." required /></div>
            <div class="col-md-1"><label class="form-label small">Classe</label><input name="Classe" class="form-control" placeholder="A, B..." /></div>
            <div class="col-md-1"><label class="form-label small">Moyenne</label><input name="MoyenneGenerale" class="form-control" type="number" step="0.01" min="0" max="20" /></div>
            <div class="col-md-1"><label class="form-label small">Mention</label><input name="Mention" class="form-control" placeholder="Bien..." /></div>
            <div class="col-md-1"><label class="form-label small">Redoublant</label><select name="EstRedoublant" class="form-select"><option value="false">Non</option><option value="true">Oui</option></select></div>
            <div class="col-auto"><button type="submit" class="btn btn-mango btn-sm"><i class="bi bi-check-lg"></i></button></div>
        </form>
    </div>
</div>

<div class="card-3d p-4 mt-4">
    <h5><i class="bi bi-calendar-event-fill text-or"></i> Activites participees (@activites.Count)</h5>
    @if (activites.Any())
    {
        <div class="table-responsive mt-3">
            <table class="table-modern">
                <thead><tr><th>Activite</th><th>Type</th><th>Date</th><th>Groupe</th><th>Presence</th></tr></thead>
                <tbody>
                    @foreach (var p in activites)
                    {
                        <tr>
                            <td>@p.Activite.Titre</td>
                            <td><span class="badge bg-secondary bg-opacity-25" style="color:var(--bleu-logo);border-radius:10px;font-size:0.7rem;">@p.Activite.Type</span></td>
                            <td>@p.Activite.DateDebut.ToString("dd/MM/yyyy")</td>
                            <td>@(p.Activite.Groupe?.Nom ?? "District")</td>
                            <td><span class="badge-3d badge-@(p.Presence == StatutPresence.Present ? "validee" : p.Presence == StatutPresence.Absent ? "rejetee" : "soumise")" style="font-size:0.7rem;">@p.Presence</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p class="text-muted-custom mt-3">Aucune participation enregistree.</p>
    }
</div>

