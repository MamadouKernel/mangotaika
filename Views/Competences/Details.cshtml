@model Competence
@{
    ViewData["Title"] = Model.Nom;
    Layout = "_LayoutAdmin";
    var canManage = User.IsInRole("Administrateur") || User.IsInRole("Gestionnaire");
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
    <h2 class="section-title mb-0"><i class="bi bi-award-fill text-or"></i> @Model.Nom</h2>
    <div class="d-flex flex-wrap gap-2">
        @if (canManage)
        {
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-bleu btn-sm" title="Modifier"><i class="bi bi-pencil"></i></a>
        }
        <a asp-action="Index" asp-route-scoutId="@Model.ScoutId" class="btn btn-outline-or btn-sm" title="Liste"><i class="bi bi-arrow-left"></i></a>
    </div>
</div>

<div class="card-3d p-4">
    <dl class="row mb-0 small">
        <dt class="col-sm-4 text-muted-custom">Type</dt>
        <dd class="col-sm-8">@Model.Type</dd>
        <dt class="col-sm-4 text-muted-custom">Niveau</dt>
        <dd class="col-sm-8">@(Model.Niveau ?? "-")</dd>
    </dl>
</div>
