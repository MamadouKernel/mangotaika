@using Microsoft.EntityFrameworkCore
@inject MangoTaika.Data.AppDbContext FooterDb
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MANGO TAÏKA</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    @* Cartes : Leaflet.js + OpenStreetMap (tuiles OSM) *@
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/activity-suite.css" asp-append-version="true" />
    @* Logo et Favicon - Multi-device support *@
    <link rel="manifest" href="~/manifest.json" />
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />
    <link rel="shortcut icon" type="image/x-icon" href="~/favicon.ico" />
    <link rel="icon" type="image/png" sizes="192x192" href="~/images/logo.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="~/images/logo.png" />
    <link rel="apple-touch-icon" sizes="152x152" href="~/images/logo.png" />
    <link rel="apple-touch-icon" sizes="144x144" href="~/images/logo.png" />
    <meta name="theme-color" content="#1a5f4a" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="MANGO TAÏKA" />
    <meta name="application-name" content="MANGO TAÏKA" />
    <meta name="msapplication-TileColor" content="#1a5f4a" />
    <meta name="msapplication-TileImage" content="~/images/logo.png" />
    <meta name="request-verification-token" content="@Antiforgery.GetAndStoreTokens(Context).RequestToken" />
</head>
<body>
    <div class="bg-animated"></div>

    <nav class="navbar navbar-expand-lg navbar-mango">
        <div class="container-fluid">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <img src="~/images/logo.png" alt="Logo MANGO TAÏKA" />
                <span class="brand-text">
                    <span class="brand-main">MANGO TAÏKA</span>
                    <span class="brand-sub">District Scout</span>
                </span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                    aria-controls="navbarNav" aria-expanded="false" aria-label="Basculer la navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                @if (ViewData["IsAdminLayout"] == null)
                {
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-house"></i> Accueil
                        </a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-info-circle"></i> Découvrir
                        </a>
                        <ul class="dropdown-menu">
                             <!-- CONTENUS -->
                             <li class="dropdown-header">📖 Contenus</li>
                             <li><hr class="dropdown-divider"></li>
                            <li>
                                <a class="dropdown-item" asp-controller="Home" asp-action="LivreDor">
                                    <i class="bi bi-book"></i> Livre d'or
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" asp-controller="Actualites" asp-action="Index">
                                    <i class="bi bi-newspaper"></i> Actualités
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" asp-controller="Home" asp-action="Galerie">
                                    <i class="bi bi-images"></i> Galerie
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" asp-controller="Groupes" asp-action="Carte">
                                    <i class="bi bi-geo-alt"></i> Carte des groupes
                                </a>
                            </li>

                            <li><hr class="dropdown-divider"></li>
                                <!-- SERVICES -->
                            <li class="dropdown-header">🛠️ Services</li>
                                <li><hr class="dropdown-divider"></li>
                            <li>
                                <a class="dropdown-item" href="https://ascci-checker-web.onrender.com/" target="_blank">
                                    <i class="bi bi-tools"></i> Vérification ASCCI
                                </a>
                            </li>

                            <li>
                                <a class="dropdown-item" href="https://lms.scout.org/account/course_catalog" target="_blank">
                                    <i class="bi bi-mortarboard"></i> Formation officielle (Scout.org)
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" href="https://www.scoutready.net/" target="_blank" rel="noopener">
                                    <i class="bi bi-compass"></i> ScoutReady
                                </a>
                            </li>

                        </ul>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-envelope"></i> Nous écrire
                        </a>
                        <ul class="dropdown-menu">
                            <li>
                                <a class="dropdown-item" asp-controller="Home" asp-action="Contact">
                                    <i class="bi bi-envelope"></i> Contact
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" asp-controller="Home" asp-action="Avis">
                                    <i class="bi bi-chat-dots"></i> Avis & Suggestions
                                </a>
                            </li>
                        </ul>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-people"></i> Rejoindre
                        </a>
                        <ul class="dropdown-menu">
                            <li>
                                <a class="dropdown-item" asp-controller="DemandesGroupe" asp-action="Creer">
                                    <i class="bi bi-building-add"></i> Créer un groupe
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" href="https://adhesion.scoutascci.org/" target="_blank" rel="noopener">
                                    <i class="bi bi-shield-check"></i> Adhésion SYGESCA
                                </a>
                            </li>
                        </ul>
                    </li>
                </ul>
                }
                <ul class="navbar-nav @(ViewData["IsAdminLayout"] != null ? "ms-auto" : "")">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item notification-nav-item">
                            <button type="button" class="nav-link notification-trigger" id="notificationTrigger" aria-expanded="false" aria-controls="notificationPanel">
                                <span class="notification-trigger__icon">
                                    <i class="bi bi-bell"></i>
                                    <span class="notification-badge d-none" id="notificationBadge">0</span>
                                </span>
                               @*  <span class="notification-trigger__label">Notifications</span> *@
                            </button>
                            <div class="notification-panel" id="notificationPanel" hidden>
                                <div class="notification-panel__head">
                                    <div>
                                        <div class="notification-panel__title">Centre de notifications</div>
                                        <div class="notification-panel__subtitle">Support, escalades et affectations</div>
                                    </div>
                                    <button type="button" class="btn btn-sm btn-outline-or notification-panel__clear" id="notificationClear">
                                        <i class="bi bi-check2-all"></i> Tout lire
                                    </button>
                                </div>
                                <div class="notification-panel__list" id="notificationList">
                                    <div class="notification-empty" id="notificationEmpty">
                                        <i class="bi bi-bell-slash"></i>
                                        <span>Aucune notification recente.</span>
                                    </div>
                                </div>
                            </div>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-person-circle"></i> Mon espace
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end account-dropdown-menu">
                                @if (ViewData["IsAdminLayout"] == null)
                                {
                                    <li class="account-dropdown-menu__intro">
                                        <span class="account-dropdown-menu__eyebrow">Navigation connectee</span>
                                        <span class="account-dropdown-menu__title">Acces rapide</span>
                                    </li>
                                    <li>
                                        <a class="dropdown-item account-dropdown-item" asp-controller="Dashboard" asp-action="Index">
                                            <i class="bi bi-speedometer2"></i>
                                            <span>
                                                <span class="account-dropdown-item__label">Vue d'ensemble</span>
                                                <span class="account-dropdown-item__hint">Votre tableau de bord personnalise</span>
                                            </span>
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item account-dropdown-item" asp-controller="Tickets" asp-action="MesTickets">
                                            <i class="bi bi-headset"></i>
                                            <span>
                                                <span class="account-dropdown-item__label">Centre d'assistance</span>
                                                <span class="account-dropdown-item__hint">Tickets, echanges et suivi de support</span>
                                            </span>
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider" /></li>
                                }
                                <li>
                                    <a class="dropdown-item account-dropdown-item" asp-controller="Account" asp-action="Profil">
                                        <i class="bi bi-person"></i>
                                        <span>
                                            <span class="account-dropdown-item__label">Mon profil</span>
                                            <span class="account-dropdown-item__hint">Informations personnelles et acces au compte</span>
                                        </span>
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post">
                                        <button type="submit" class="dropdown-item account-dropdown-item">
                                            <i class="bi bi-box-arrow-right"></i>
                                            <span>
                                                <span class="account-dropdown-item__label">Deconnexion</span>
                                                <span class="account-dropdown-item__hint">Fermer la session en toute securite</span>
                                            </span>
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Login">
                                <i class="bi bi-box-arrow-in-right"></i> Connexion
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Register">
                                <i class="bi bi-person-plus"></i> Inscription
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <div class="platform-slogan-bar" role="note" aria-label="Slogan de la plateforme">
        <div class="container">
            <span class="platform-slogan-bar__text">@PlatformBranding.Slogan</span>
        </div>
    </div>

    <partial name="_FlashMessages" />

    <main>
        @RenderBody()
    </main>

    <div class="notification-toast-stack" id="notificationToastStack" aria-live="polite" aria-atomic="true"></div>

    @if (ViewData["IsAdminLayout"] == null)
    {
        var footerLiensRS = await FooterDb.LiensReseauxSociaux.Where(l => l.EstActif).OrderBy(l => l.Ordre).ToListAsync();
    <footer class="footer-mango mt-5">
        <div class="container text-center">
            <img src="~/images/logo.png" alt="Logo" class="footer-logo" />
            <p class="footer-slogan mb-3">@PlatformBranding.Slogan</p>
            <p class="mb-1">District Scout MANGO TAÏKA</p>
            @if (footerLiensRS.Any())
            {
                <div class="footer-rs-links">
                    @foreach (var lien in footerLiensRS)
                    {
                        var iconClass = lien.Plateforme?.ToLower() switch
                        {
                            "facebook" => "bi-facebook",
                            "instagram" => "bi-instagram",
                            "twitter" => "bi-twitter-x",
                            "youtube" => "bi-youtube",
                            "tiktok" => "bi-tiktok",
                            "whatsapp" => "bi-whatsapp",
                            "linkedin" => "bi-linkedin",
                            "telegram" => "bi-telegram",
                            _ => lien.Icone ?? "bi-link-45deg"
                        };
                        <a href="@lien.Url" target="_blank" rel="noopener" title="@lien.Plateforme">
                            <i class="bi @iconClass"></i>
                        </a>
                    }
                </div>
            }
            <div class="footer-divider"></div>
            <p class="small mb-2">
                <a href="mailto:@(Configuration["Contact:Email"] ?? "contact@mangotaika.ci")">@(Configuration["Contact:Email"] ?? "contact@mangotaika.ci")</a>
            </p>
            <p class="small">
                <a asp-controller="Home" asp-action="Contact">Contact</a> &bull;
                <a asp-controller="Home" asp-action="Avis">Avis</a> &bull;
                <a asp-controller="Actualites" asp-action="Index">Actualités</a> &bull;
                <a asp-controller="Home" asp-action="LivreDor">Livre d'or</a> &bull;
                <a asp-controller="Groupes" asp-action="Carte">Carte</a> &bull;
                <a href="https://www.scoutready.net/" target="_blank" rel="noopener">ScoutReady</a> &bull;
                <a asp-controller="Home" asp-action="PolitiqueConfidentialite">Politique de confidentialité</a>
            </p>
            <p class="small mt-2" style="opacity:0.4;">&copy; @DateTime.Now.Year MANGO TAÏKA. Tous droits réservés.</p>
        </div>
    </footer>
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="~/js/maps-leaflet-osm.js" asp-append-version="true"></script>
    <script src="~/lib/microsoft/signalr/dist/browser/signalr.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
