@functions {
    private sealed record FeedbackMessage(string Type, string Title, string Body, string Icon);
}

@{
    var messages = new List<FeedbackMessage>();

    void AddMessage(string key, string type, string title, string icon)
    {
        var body = TempData[key] as string;
        if (!string.IsNullOrWhiteSpace(body))
        {
            messages.Add(new FeedbackMessage(type, title, body, icon));
        }
    }

    AddMessage("Success", "success", "Operation reussie", "bi-check2-circle");
    AddMessage("Info", "info", "Information utile", "bi-info-circle");
    AddMessage("Warning", "warning", "Point d'attention", "bi-exclamation-triangle");
    AddMessage("Error", "error", "Action impossible", "bi-exclamation-octagon");
    AddMessage("ImportError", "error", "Import impossible", "bi-file-earmark-x");
}

@if (messages.Count > 0)
{
    <section class="ihm-feedback-stack" aria-live="polite" aria-label="Messages de la plateforme">
        @foreach (var message in messages)
        {
            <article class="ihm-feedback ihm-feedback--@message.Type alert alert-dismissible fade show" role="alert">
                <div class="ihm-feedback__icon" aria-hidden="true">
                    <i class="bi @message.Icon"></i>
                </div>
                <div class="ihm-feedback__content">
                    <div class="ihm-feedback__title">@message.Title</div>
                    <div class="ihm-feedback__body">@message.Body</div>
                </div>
                <button type="button" class="btn-close ihm-feedback__close" data-bs-dismiss="alert" aria-label="Fermer"></button>
            </article>
        }
    </section>
}
