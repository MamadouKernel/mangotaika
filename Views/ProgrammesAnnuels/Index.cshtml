@using MangoTaika.Data.Entities
@model List<ProgrammeAnnuel>
@{
    ViewData["Title"] = "Programmes annuels";
    Layout = "_LayoutAdmin";
    var groupes = ViewBag.Groupes as List<Groupe> ?? new();
    var selectedGroupeId = ViewBag.SelectedGroupeId as Guid?;
    var selectedStatut = ViewBag.SelectedStatut as StatutWorkflowDocument?;
    var annee = ViewBag.Annee is int currentYear ? currentYear : DateTime.UtcNow.Year;
    var canCreate = ViewBag.CanCreateProgram as bool? == true;
    var canManage = ViewBag.CanManagePrograms as bool? == true;
    var canValidateDistrict = ViewBag.CanValidateDistrict as bool? == true;
    var brouillons = Model.Count(x => x.Statut == StatutWorkflowDocument.Brouillon || x.Statut == StatutWorkflowDocument.AReviser);
    var soumis = Model.Count(x => x.Statut == StatutWorkflowDocument.Soumis);
    var valides = Model.Count(x => x.Statut == StatutWorkflowDocument.Valide);
    var rejetes = Model.Count(x => x.Statut == StatutWorkflowDocument.Rejete);

    string GetStatusClass(StatutWorkflowDocument statut) => statut switch
    {
        StatutWorkflowDocument.Brouillon => "tracking-status-pill--draft",
        StatutWorkflowDocument.Soumis => "tracking-status-pill--pending",
        StatutWorkflowDocument.AReviser => "tracking-status-pill--revision",
        StatutWorkflowDocument.Valide => "tracking-status-pill--approved",
        StatutWorkflowDocument.Rejete => "badge-rejetee",
        _ => "tracking-status-pill--draft"
    };
}

<div class="tracking-module tracking-module--programmes-index">
    <section class="tracking-hero">
        <div class="tracking-hero__content">
            <span class="tracking-hero__eyebrow"><i class="bi bi-calendar-range"></i> Planification annuelle</span>
            <h2 class="section-title tracking-hero__title mb-2"><i class="bi bi-calendar-range text-or"></i> Programmes <span class="accent">annuels</span></h2>
            <p class="tracking-hero__text mb-0">Le programme annuel structure toutes les activites prevues avec branche cible, objectif, lieu, date, responsable, description et montant de participation.</p>
            <div class="tracking-hero__chips">
                <span class="tracking-chip"><i class="bi bi-calendar3"></i> Annee @annee</span>
                <span class="tracking-chip tracking-chip--soft"><i class="bi bi-collection"></i> @Model.Count programme(s)</span>
                <span class="tracking-chip tracking-chip--highlight"><i class="bi bi-check2-circle"></i> @valides valide(s)</span>
            </div>
        </div>
        <div class="tracking-hero__actions">
            <div class="tracking-hero__focus">
                <span>Suivi</span>
                <strong>@brouillons</strong>
                <small>programme(s) a completer ou corriger</small>
            </div>
            <div class="tracking-action-stack">
                <a asp-action="Calendrier" asp-route-annee="@annee" asp-route-groupeId="@selectedGroupeId" class="btn btn-outline-or"><i class="bi bi-calendar-week"></i> Vue calendrier</a>
                @if (canCreate)
                {
                    <a asp-action="Create" class="btn btn-mango"><i class="bi bi-plus-lg"></i> Nouveau programme</a>
                }
            </div>
        </div>
    </section>

    <div class="tracking-kpi-grid">
        <article class="tracking-kpi tracking-kpi--olive"><i class="bi bi-pencil-square tracking-kpi__icon"></i><span class="tracking-kpi__label">Brouillons / revisions</span><strong class="tracking-kpi__value">@brouillons</strong><span class="tracking-kpi__meta">a finaliser</span></article>
        <article class="tracking-kpi tracking-kpi--gold"><i class="bi bi-hourglass-split tracking-kpi__icon"></i><span class="tracking-kpi__label">Soumis</span><strong class="tracking-kpi__value">@soumis</strong><span class="tracking-kpi__meta">en attente district</span></article>
        <article class="tracking-kpi tracking-kpi--blue"><i class="bi bi-patch-check tracking-kpi__icon"></i><span class="tracking-kpi__label">Valides</span><strong class="tracking-kpi__value">@valides</strong><span class="tracking-kpi__meta">pret(s) a derouler</span></article>
        <article class="tracking-kpi tracking-kpi--rose"><i class="bi bi-x-octagon tracking-kpi__icon"></i><span class="tracking-kpi__label">Rejetes</span><strong class="tracking-kpi__value">@rejetes</strong><span class="tracking-kpi__meta">a reprendre</span></article>
    </div>

    <section class="tracking-panel tracking-panel--soft">
        <div class="tracking-panel__header"><div><h3 class="tracking-panel__title">Filtres</h3><p class="tracking-panel__text">Consultez les programmes par annee, entite et statut.</p></div></div>
        <form method="get" class="tracking-filter-form">
            <div class="tracking-field">
                <label class="form-label">Annee</label>
                <input type="number" class="form-control" name="annee" value="@annee" min="2000" max="2100" />
            </div>
            <div class="tracking-field-wide">
                <label class="form-label">Entite</label>
                <select class="form-select" name="groupeId">
                    <option value="">-- Toutes --</option>
                    @foreach (var groupe in groupes)
                    {
                        <option value="@groupe.Id" selected="@(selectedGroupeId == groupe.Id ? "selected" : null)">@groupe.Nom</option>
                    }
                </select>
            </div>
            <div class="tracking-field">
                <label class="form-label">Statut</label>
                <select class="form-select" name="statut">
                    <option value="">-- Tous --</option>
                    @foreach (var statut in Enum.GetValues<StatutWorkflowDocument>())
                    {
                        <option value="@statut" selected="@(selectedStatut == statut ? "selected" : null)">@statut</option>
                    }
                </select>
            </div>
            <div class="tracking-field-action">
                <button class="btn btn-bleu w-100" type="submit"><i class="bi bi-filter-circle"></i> Filtrer</button>
            </div>
        </form>
    </section>

    @if (Model.Any())
    {
        <section class="tracking-card-grid">
        @foreach (var programme in Model)
        {
            var montantTotal = programme.Activites.Sum(a => a.MontantParticipation ?? 0m);
            <article class="tracking-card">
                <div class="tracking-card__header">
                    <div>
                        <h3 class="tracking-card__title">@programme.Titre</h3>
                        <div class="tracking-card__subtitle">@(programme.Groupe?.Nom ?? "District") - @programme.AnneeReference</div>
                    </div>
                    <span class="tracking-status-pill @GetStatusClass(programme.Statut)">@programme.Statut</span>
                </div>
                <p class="tracking-card__summary">@(string.IsNullOrWhiteSpace(programme.Objectifs) ? "Aucun objectif renseigne." : programme.Objectifs)</p>
                <div class="tracking-meta-list">
                    <div class="tracking-meta-list__item"><i class="bi bi-list-task"></i><span>@programme.Activites.Count activite(s) prevue(s)</span></div>
                    <div class="tracking-meta-list__item"><i class="bi bi-cash-stack"></i><span>@montantTotal.ToString("N0") FCFA cumules</span></div>
                </div>
                <div class="tracking-card__actions">
                    <a asp-action="Details" asp-route-id="@programme.Id" class="btn btn-outline-or"><i class="bi bi-eye"></i> Voir</a>
                    <a asp-action="Calendrier" asp-route-annee="@programme.AnneeReference" asp-route-groupeId="@programme.GroupeId" class="btn btn-outline-or"><i class="bi bi-calendar-week"></i> Calendrier</a>
                    @if (canManage)
                    {
                        <a asp-action="Edit" asp-route-id="@programme.Id" class="btn btn-bleu"><i class="bi bi-pencil"></i> Modifier</a>
                    }
                </div>
            </article>
        }
        </section>
    }
    else
    {
        <div class="tracking-empty-state"><i class="bi bi-calendar2-x"></i><div>Aucun programme annuel trouve.</div></div>
    }

    @await Html.PartialAsync("_ListPagination")
</div>
