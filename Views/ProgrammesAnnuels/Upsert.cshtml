@using MangoTaika.Data.Entities
@model ProgrammeAnnuel
@{
    ViewData["Title"] = Model.Id == Guid.Empty ? "Nouveau programme annuel" : "Modifier le programme annuel";
    Layout = "_LayoutAdmin";
    var groupes = ViewBag.Groupes as List<Groupe> ?? new();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="section-title mb-1"><i class="bi bi-calendar-range text-or"></i> <span class="accent">@ViewData["Title"]</span></h2>
        <p class="text-muted-custom mb-0">Centralisez les objectifs, jalons et echeances du programme annuel.</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-or"><i class="bi bi-arrow-left"></i></a>
</div>

<div class="card-3d p-4">
    <form method="post">
        @Html.AntiForgeryToken()
        @if (Model.Id != Guid.Empty)
        {
            <input type="hidden" asp-for="Id" />
        }
        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
        <div class="row g-3">
            <div class="col-lg-4">
                <label asp-for="GroupeId" class="form-label">Entite</label>
                <select asp-for="GroupeId" class="form-select">
                    <option value="">-- Programme district --</option>
                    @foreach (var groupe in groupes)
                    {
                        <option value="@groupe.Id">@groupe.Nom</option>
                    }
                </select>
            </div>
            <div class="col-lg-2">
                <label asp-for="AnneeReference" class="form-label">Annee</label>
                <input asp-for="AnneeReference" class="form-control" />
            </div>
            <div class="col-lg-6">
                <label asp-for="Titre" class="form-label">Titre</label>
                <input asp-for="Titre" class="form-control" />
            </div>
            <div class="col-12">
                <label asp-for="Objectifs" class="form-label">Objectifs</label>
                <textarea asp-for="Objectifs" class="form-control" rows="5"></textarea>
            </div>
            <div class="col-12">
                <label asp-for="CalendrierSynthese" class="form-label">Calendrier synthese</label>
                <textarea asp-for="CalendrierSynthese" class="form-control" rows="8" placeholder="Ex.: Janvier - camp de lancement&#10;Mars - journee de district&#10;Juillet - camp d'ete"></textarea>
            </div>
            <div class="col-12">
                <label asp-for="Observations" class="form-label">Observations</label>
                <textarea asp-for="Observations" class="form-control" rows="4"></textarea>
            </div>
        </div>
        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-mango"><i class="bi bi-check-lg"></i> Enregistrer</button>
            <a asp-action="Index" class="btn btn-outline-or">Annuler</a>
        </div>
    </form>
</div>
