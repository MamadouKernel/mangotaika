@using MangoTaika.Data.Entities
@model List<PropositionMaitriseAnnuelle>
@{
    ViewData["Title"] = "Propositions de maitrise";
    Layout = "_LayoutAdmin";
    var groupes = ViewBag.Groupes as List<Groupe> ?? new();
    var selectedGroupeId = ViewBag.SelectedGroupeId as Guid?;
    var selectedStatut = ViewBag.SelectedStatut as StatutWorkflowDocument?;
    var annee = ViewBag.Annee is int currentYear ? currentYear : DateTime.UtcNow.Year;
    var canManage = User.IsInRole("Administrateur") || User.IsInRole("Gestionnaire");
    var brouillons = Model.Count(x => x.Statut == StatutWorkflowDocument.Brouillon || x.Statut == StatutWorkflowDocument.AReviser);
    var soumis = Model.Count(x => x.Statut == StatutWorkflowDocument.Soumis);
    var valides = Model.Count(x => x.Statut == StatutWorkflowDocument.Valide);

    string GetStatusClass(StatutWorkflowDocument statut) => statut switch
    {
        StatutWorkflowDocument.Brouillon => "tracking-status-pill--draft",
        StatutWorkflowDocument.Soumis => "tracking-status-pill--pending",
        StatutWorkflowDocument.AReviser => "tracking-status-pill--revision",
        StatutWorkflowDocument.Valide => "tracking-status-pill--approved",
        _ => "tracking-status-pill--draft"
    };
}

<div class="tracking-module tracking-module--maitrise-index">
    <section class="tracking-hero">
        <div class="tracking-hero__content">
            <span class="tracking-hero__eyebrow"><i class="bi bi-people"></i> Structuration de la maitrise</span>
            <h2 class="section-title tracking-hero__title mb-2"><i class="bi bi-people text-or"></i> Propositions de <span class="accent">maitrise</span></h2>
            <p class="tracking-hero__text mb-0">Un espace plus propre pour preparer l'encadrement, les besoins de formation et les arbitrages annuels par entite.</p>
            <div class="tracking-hero__chips">
                <span class="tracking-chip"><i class="bi bi-calendar3"></i> Annee @annee</span>
                <span class="tracking-chip tracking-chip--soft"><i class="bi bi-collection"></i> @Model.Count proposition(s)</span>
                <span class="tracking-chip tracking-chip--highlight"><i class="bi bi-check2-circle"></i> @valides validee(s)</span>
            </div>
        </div>
        <div class="tracking-hero__actions">
            <div class="tracking-hero__focus">
                <span>Preparation</span>
                <strong>@brouillons</strong>
                <small>proposition(s) a finaliser ou reviser</small>
            </div>
            <div class="tracking-action-stack">
                @if (canManage)
                {
                    <a asp-action="Create" class="btn btn-mango"><i class="bi bi-plus-lg"></i> Nouvelle proposition</a>
                }
            </div>
        </div>
    </section>

    <div class="tracking-kpi-grid">
        <article class="tracking-kpi tracking-kpi--olive"><i class="bi bi-journal-plus tracking-kpi__icon"></i><span class="tracking-kpi__label">Brouillons / revisions</span><strong class="tracking-kpi__value">@brouillons</strong><span class="tracking-kpi__meta">a travailler avec les equipes</span></article>
        <article class="tracking-kpi tracking-kpi--gold"><i class="bi bi-send-check tracking-kpi__icon"></i><span class="tracking-kpi__label">Soumises</span><strong class="tracking-kpi__value">@soumis</strong><span class="tracking-kpi__meta">en cours d'arbitrage</span></article>
        <article class="tracking-kpi tracking-kpi--blue"><i class="bi bi-patch-check tracking-kpi__icon"></i><span class="tracking-kpi__label">Validees</span><strong class="tracking-kpi__value">@valides</strong><span class="tracking-kpi__meta">maitrises retenues</span></article>
        <article class="tracking-kpi tracking-kpi--rose"><i class="bi bi-diagram-3 tracking-kpi__icon"></i><span class="tracking-kpi__label">Entites</span><strong class="tracking-kpi__value">@Model.Select(x => x.GroupeId).Distinct().Count()</strong><span class="tracking-kpi__meta">territoires suivis</span></article>
    </div>

    <section class="tracking-panel tracking-panel--soft">
        <div class="tracking-panel__header"><div><h3 class="tracking-panel__title">Filtres de lecture</h3><p class="tracking-panel__text">Croisez les propositions par annee, entite et statut.</p></div></div>
        <form method="get" class="tracking-filter-form">
            <div class="tracking-field">
                <label class="form-label">Annee</label>
                <input type="number" class="form-control" name="annee" value="@annee" min="2000" max="2100" />
            </div>
            <div class="tracking-field-wide">
                <label class="form-label">Entite</label>
                <select class="form-select" name="groupeId">
                    <option value="">-- Toutes --</option>
                    @foreach (var groupe in groupes)
                    {
                        <option value="@groupe.Id" selected="@(selectedGroupeId == groupe.Id ? "selected" : null)">@groupe.Nom</option>
                    }
                </select>
            </div>
            <div class="tracking-field">
                <label class="form-label">Statut</label>
                <select class="form-select" name="statut">
                    <option value="">-- Tous --</option>
                    @foreach (var statut in Enum.GetValues<StatutWorkflowDocument>())
                    {
                        <option value="@statut" selected="@(selectedStatut == statut ? "selected" : null)">@statut</option>
                    }
                </select>
            </div>
            <div class="tracking-field-action">
                <button class="btn btn-bleu w-100" type="submit"><i class="bi bi-filter-circle"></i> Filtrer</button>
            </div>
        </form>
    </section>

    @if (Model.Any())
    {
        <section class="tracking-card-grid">
        @foreach (var proposition in Model)
        {
            <article class="tracking-card">
                <div class="tracking-card__header">
                    <div>
                        <h3 class="tracking-card__title">@proposition.Titre</h3>
                        <div class="tracking-card__subtitle">@proposition.Groupe.Nom - @proposition.AnneeReference</div>
                    </div>
                    <span class="tracking-status-pill @GetStatusClass(proposition.Statut)">@proposition.Statut</span>
                </div>
                <p class="tracking-card__summary">@(string.IsNullOrWhiteSpace(proposition.ObjectifsPedagogiques) ? "Aucun objectif pedagogique renseigne." : proposition.ObjectifsPedagogiques)</p>
                <div class="tracking-meta-list">
                    <div class="tracking-meta-list__item"><i class="bi bi-people-fill"></i><span>Composition proposee disponible</span></div>
                    <div class="tracking-meta-list__item"><i class="bi bi-mortarboard"></i><span>@(string.IsNullOrWhiteSpace(proposition.BesoinsFormation) ? "Aucun besoin de formation renseigne" : "Besoins de formation identifies")</span></div>
                </div>
                <div class="tracking-card__actions">
                    <a asp-action="Details" asp-route-id="@proposition.Id" class="btn btn-outline-or"><i class="bi bi-eye"></i> Voir</a>
                    @if (canManage)
                    {
                        <a asp-action="Edit" asp-route-id="@proposition.Id" class="btn btn-bleu"><i class="bi bi-pencil"></i> Modifier</a>
                    }
                </div>
            </article>
        }
        </section>
    }
    else
    {
        <div class="tracking-empty-state"><i class="bi bi-people"></i><div>Aucune proposition de maitrise trouvee.</div></div>
    }

    @await Html.PartialAsync("_ListPagination")
</div>