@using MangoTaika.Data.Entities
@model PropositionMaitriseAnnuelle
@{
    ViewData["Title"] = Model.Titre;
    Layout = "_LayoutAdmin";
    var canManage = User.IsInRole("Administrateur") || User.IsInRole("Gestionnaire");
}

<div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
    <div>
        <h2 class="section-title mb-1"><i class="bi bi-people text-or"></i> <span class="accent">@Model.Titre</span></h2>
        <p class="text-muted-custom mb-0">@Model.Groupe.Nom - @Model.AnneeReference</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        @if (canManage)
        {
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-bleu"><i class="bi bi-pencil"></i></a>
            @if (Model.Statut is StatutWorkflowDocument.Brouillon or StatutWorkflowDocument.AReviser)
            {
                <form asp-action="Soumettre" asp-route-id="@Model.Id" method="post" class="d-inline">@Html.AntiForgeryToken()<button type="submit" class="btn btn-mango"><i class="bi bi-send"></i> Soumettre</button></form>
            }
            @if (Model.Statut == StatutWorkflowDocument.Soumis)
            {
                <form asp-action="Valider" asp-route-id="@Model.Id" method="post" class="d-inline">@Html.AntiForgeryToken()<button type="submit" class="btn btn-mango"><i class="bi bi-check2-circle"></i> Valider</button></form>
                <form asp-action="DemanderRevision" asp-route-id="@Model.Id" method="post" class="d-inline">@Html.AntiForgeryToken()<button type="submit" class="btn btn-outline-or"><i class="bi bi-arrow-counterclockwise"></i> Revision</button></form>
            }
        }
        <a asp-action="Index" class="btn btn-outline-or"><i class="bi bi-arrow-left"></i></a>
    </div>
</div>

<div class="card-3d p-4 mb-4">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
        <div class="badge-3d badge-soumise">@Model.Statut</div>
        <small class="text-muted-custom">Creee le @Model.DateCreation.ToString("dd/MM/yyyy")</small>
    </div>
    @if (!string.IsNullOrWhiteSpace(Model.CommentaireValidation))
    {
        <div class="alert alert-warning border-0">@Model.CommentaireValidation</div>
    }
    <h5 class="text-or">Composition proposee</h5>
    <div class="text-muted-custom mb-4" style="white-space:pre-line;">@Model.CompositionProposee</div>
    <h5 class="text-or">Objectifs pedagogiques</h5>
    <div class="text-muted-custom mb-4" style="white-space:pre-line;">@Model.ObjectifsPedagogiques</div>
    <h5 class="text-or">Besoins de formation</h5>
    <div class="text-muted-custom mb-4" style="white-space:pre-line;">@(string.IsNullOrWhiteSpace(Model.BesoinsFormation) ? "Aucun besoin renseigne." : Model.BesoinsFormation)</div>
    <h5 class="text-or">Observations</h5>
    <div class="text-muted-custom" style="white-space:pre-line;">@(string.IsNullOrWhiteSpace(Model.Observations) ? "Aucune observation." : Model.Observations)</div>
</div>
