@model BrancheDto
@using MangoTaika.Helpers
@{
    ViewData["Title"] = "Detail de la branche";
    Layout = "_LayoutAdmin";
    var canManage = User.IsInRole("Administrateur") || User.IsInRole("Gestionnaire");
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
    <h2 class="section-title mb-0"><i class="bi bi-diagram-3-fill text-or"></i> @Model.Nom</h2>
    <div class="d-flex flex-wrap gap-2">
        @if (canManage)
        {
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-bleu btn-sm" title="Modifier"><i class="bi bi-pencil"></i></a>
        }
        <a asp-action="Index" class="btn btn-outline-or btn-sm" title="Liste"><i class="bi bi-arrow-left"></i></a>
    </div>
</div>

<div class="d-flex justify-content-end mb-3">
    <div class="js-list-export-toolbar d-flex flex-wrap gap-2"
         data-export-title="Detail branche - @Model.Nom"
         data-export-target="#branch-details-export-table"
         data-export-mode="table">
        <button type="button" class="btn btn-outline-or btn-sm" data-export-format="pdf">
            <i class="bi bi-file-earmark-pdf"></i> PDF
        </button>
        <button type="button" class="btn btn-outline-or btn-sm" data-export-format="excel">
            <i class="bi bi-file-earmark-excel"></i> Excel
        </button>
    </div>
</div>

<div class="branch-export-source" aria-hidden="true">
    <table id="branch-details-export-table" class="table table-sm align-middle mb-0">
        <thead>
            <tr>
                <th scope="col">Section</th>
                <th scope="col">Categorie</th>
                <th scope="col">Reference</th>
                <th scope="col">Valeur</th>
                <th scope="col">Detail 1</th>
                <th scope="col">Detail 2</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>Synthese</td>
                <td>Branche</td>
                <td>@Model.Nom</td>
                <td>@(Model.NomGroupe ?? "-")</td>
                <td>@(Model.NomChefUnite ?? "-")</td>
                <td>@(Model.Description ?? "-")</td>
            </tr>
            <tr>
                <td>Synthese</td>
                <td>Responsable</td>
                <td>@(Model.NomChefUnite ?? "-")</td>
                <td>@(Model.ContactChefUnite ?? "-")</td>
                <td>@(Model.NomGroupe ?? "-")</td>
            </tr>
            <tr>
                <td>Effectifs</td>
                <td>Scouts</td>
                <td>Total</td>
                <td>@Model.NombreScouts</td>
                <td>Filles @Model.NombreFilles</td>
                <td>Garcons @Model.NombreGarcons</td>
            </tr>
            <tr>
                <td>Effectifs</td>
                <td>Jeunes</td>
                <td>Total</td>
                <td>@Model.Jeunes.Total</td>
                <td>Filles @Model.Jeunes.NombreFeminin</td>
                <td>Garcons @Model.Jeunes.NombreMasculin</td>
            </tr>
            <tr>
                <td>Effectifs</td>
                <td>Adultes</td>
                <td>Total</td>
                <td>@Model.Adultes.Total</td>
                <td>Femmes @Model.Adultes.NombreFeminin</td>
                <td>Hommes @Model.Adultes.NombreMasculin</td>
            </tr>
            @foreach (var groupe in Model.TotauxParGroupes)
            {
                <tr>
                    <td>Totaux par groupe</td>
                    <td>Scouts</td>
                    <td>@groupe.NomGroupe</td>
                    <td>@groupe.NombreScouts</td>
                    <td>Filles @groupe.NombreFilles</td>
                    <td>Garcons @groupe.NombreGarcons</td>
                </tr>
                <tr>
                    <td>Totaux par groupe</td>
                    <td>Jeunes</td>
                    <td>@groupe.NomGroupe</td>
                    <td>@groupe.NombreJeunes</td>
                    <td>Filles @groupe.Jeunes.NombreFeminin</td>
                    <td>Garcons @groupe.Jeunes.NombreMasculin</td>
                </tr>
                <tr>
                    <td>Totaux par groupe</td>
                    <td>Adultes</td>
                    <td>@groupe.NomGroupe</td>
                    <td>@groupe.NombreAdultes</td>
                    <td>Femmes @groupe.Adultes.NombreFeminin</td>
                    <td>Hommes @groupe.Adultes.NombreMasculin</td>
                </tr>
            }
            @foreach (var membre in Model.Membres)
            {
                <tr>
                    <td>Membres</td>
                    <td>Membre</td>
                    <td>@membre.Matricule</td>
                    <td>@($"{membre.Nom} {membre.Prenoms}".Trim())</td>
                    <td>@(membre.Groupe ?? "-")</td>
                    <td>@(membre.Fonction ?? "-")</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="card-3d p-4 mb-4">
    <div class="row g-4 align-items-start">
        <div class="col-xl-2 col-lg-3">
            @if (!string.IsNullOrWhiteSpace(Model.LogoUrl))
            {
                <img src="@Model.LogoUrl" alt="Logo de la branche @Model.Nom" class="branche-details-logo" />
            }
            else
            {
                <div class="branche-details-logo branche-details-logo--placeholder">
                    <i class="bi bi-diagram-3"></i>
                </div>
            }
        </div>

        <div class="col-xl-7 col-lg-6">
            <div class="mb-3">
                <h4 class="mb-1">@BranchDisplay.CanonicalLabel(Model.Nom)</h4>
                <p class="text-muted-custom mb-2">@(Model.NomGroupe ?? "Groupe non renseigne")</p>
                <p class="text-muted-custom mb-0">@(Model.Description ?? "-")</p>
            </div>

            <div class="branche-kpi-grid mb-3">
                <div class="branche-kpi-card">
                    <span class="branche-kpi-label">Scouts</span>
                    <strong>@Model.NombreScouts</strong>
                    <small>@Model.NombreFilles filles | @Model.NombreGarcons garcons</small>
                </div>
                <div class="branche-kpi-card">
                    <span class="branche-kpi-label">Jeunes</span>
                    <strong>@Model.Jeunes.Total</strong>
                    <small>@Model.Jeunes.NombreFeminin filles | @Model.Jeunes.NombreMasculin garcons</small>
                </div>
                <div class="branche-kpi-card">
                    <span class="branche-kpi-label">Adultes</span>
                    <strong>@Model.Adultes.Total</strong>
                    <small>@Model.Adultes.NombreFeminin femmes | @Model.Adultes.NombreMasculin hommes</small>
                </div>
            </div>

            <dl class="row mb-0 small">
                <dt class="col-sm-4 text-muted-custom">Groupe</dt>
                <dd class="col-sm-8">@(Model.NomGroupe ?? "-")</dd>

                <dt class="col-sm-4 text-muted-custom">Scouts</dt>
                <dd class="col-sm-8">@Model.NombreScouts | @Model.NombreFilles filles | @Model.NombreGarcons garcons</dd>

                <dt class="col-sm-4 text-muted-custom">Jeunes</dt>
                <dd class="col-sm-8">@Model.Jeunes.Total | Filles @Model.Jeunes.NombreFeminin / Garcons @Model.Jeunes.NombreMasculin</dd>

                <dt class="col-sm-4 text-muted-custom">Adultes</dt>
                <dd class="col-sm-8">@Model.Adultes.Total | Femmes @Model.Adultes.NombreFeminin / Hommes @Model.Adultes.NombreMasculin</dd>

                <dt class="col-sm-4 text-muted-custom">Responsable de branche</dt>
                <dd class="col-sm-8">@(Model.NomChefUnite ?? "-")</dd>

                <dt class="col-sm-4 text-muted-custom">Contact du responsable</dt>
                <dd class="col-sm-8">@(Model.ContactChefUnite ?? "-")</dd>
            </dl>
        </div>

        <div class="col-xl-3 col-lg-3">
            <div class="branche-responsable-card">
                <span class="branche-responsable-card__label">Responsable</span>
                @if (!string.IsNullOrWhiteSpace(Model.ResponsablePhotoUrl))
                {
                    <img src="@Model.ResponsablePhotoUrl" alt="Photo du responsable @Model.NomChefUnite" class="branche-responsable-card__photo" />
                }
                else
                {
                    <div class="branche-responsable-card__photo branche-responsable-card__photo--placeholder">
                        <i class="bi bi-person-circle"></i>
                    </div>
                }
                <strong class="branche-responsable-card__name">@(Model.NomChefUnite ?? "Non renseigne")</strong>
                <span class="branche-responsable-card__contact">@(Model.ContactChefUnite ?? "Contact non renseigne")</span>
            </div>
        </div>
    </div>
</div>

<div class="card-3d p-4 mb-4">
    @if (Model.TotauxParGroupes.Any())
    {
        <div class="table-responsive">
            <table class="table table-sm align-middle branche-groupes-table mb-0">
                <thead>
                    <tr>
                        <th scope="col">Categorie</th>
                        @foreach (var groupe in Model.TotauxParGroupes)
                        {
                            <th scope="col">
                                <span class="branche-groupe-head">
                                    <span class="branche-groupe-head__logo-shell">
                                        <img src="@BranchDisplay.LogoOrDefault(groupe.LogoGroupeUrl)" alt="Logo du groupe @groupe.NomGroupe" class="branche-groupe-head__logo" />
                                    </span>
                                    <span class="branche-groupe-head__name">@groupe.NomGroupe</span>
                                </span>
                            </th>
                        }
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <th scope="row">Scouts</th>
                        @foreach (var groupe in Model.TotauxParGroupes)
                        {
                            <td>
                                <strong>@groupe.NombreScouts</strong>
                                <div class="small text-muted-custom">F @groupe.NombreFilles / G @groupe.NombreGarcons</div>
                            </td>
                        }
                    </tr>
                    <tr>
                        <th scope="row">Jeunes</th>
                        @foreach (var groupe in Model.TotauxParGroupes)
                        {
                            <td>
                                <strong>@groupe.NombreJeunes</strong>
                                <div class="small text-muted-custom">F @groupe.Jeunes.NombreFeminin / G @groupe.Jeunes.NombreMasculin</div>
                            </td>
                        }
                    </tr>
                    <tr>
                        <th scope="row">Adultes</th>
                        @foreach (var groupe in Model.TotauxParGroupes)
                        {
                            <td>
                                <strong>@groupe.NombreAdultes</strong>
                                <div class="small text-muted-custom">F @groupe.Adultes.NombreFeminin / G @groupe.Adultes.NombreMasculin</div>
                            </td>
                        }
                    </tr>
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-muted-custom">Aucun groupe rattache pour cette branche.</div>
    }
</div>

<div class="card-3d p-4" id="branche-membres-panel">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <div>
            <h4 class="mb-1">Liste des scouts et adultes de la branche</h4>
            <p class="text-muted-custom mb-0">Matricules, identite, groupe et fonction de tous les membres rattaches.</p>
        </div>
    </div>

    @if (Model.Membres.Any())
    {
        <div class="branche-membres-toolbar d-flex flex-wrap gap-2 align-items-center justify-content-between mb-3">
            <div class="branche-membres-search">
                <i class="bi bi-search"></i>
                <input type="search" id="brancheMembresSearch" class="form-control form-control-sm"
                       placeholder="Rechercher (matricule, nom, prenom, groupe, fonction)..." autocomplete="off" />
            </div>
            <div class="d-flex align-items-center gap-2">
                <label for="brancheMembresPageSize" class="small text-muted-custom mb-0">Par page</label>
                <select id="brancheMembresPageSize" class="form-select form-select-sm" style="width:auto; border-radius:12px;">
                    <option value="10">10</option>
                    <option value="20" selected>20</option>
                    <option value="50">50</option>
                    <option value="100">100</option>
                </select>
            </div>
        </div>

        <div class="table-responsive" id="brancheMembresTableWrap">
            <table class="table table-sm align-middle branche-membres-table mb-0">
                <thead>
                    <tr>
                        <th scope="col">Matricule</th>
                        <th scope="col">Nom</th>
                        <th scope="col">Prenoms</th>
                        <th scope="col">Groupe</th>
                        <th scope="col">Fonction</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var membre in Model.Membres)
                    {
                        <tr class="branche-membre-row" data-search="@($"{membre.Matricule} {membre.Nom} {membre.Prenoms} {membre.Groupe} {membre.Fonction}")">
                            <td>@membre.Matricule</td>
                            <td>@membre.Nom</td>
                            <td>@membre.Prenoms</td>
                            <td>@membre.Groupe</td>
                            <td>@membre.Fonction</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div id="brancheMembresNoResults" class="text-center py-4 text-muted-custom" style="display:none;">
            <i class="bi bi-search" style="font-size: 1.6rem; opacity: 0.35;"></i>
            <p class="mt-2 mb-0">Aucun membre ne correspond a la recherche.</p>
        </div>

        <div class="d-flex flex-wrap gap-2 align-items-center justify-content-between mt-3">
            <span class="small text-muted-custom" id="brancheMembresCount"></span>
            <div class="d-flex flex-wrap align-items-center gap-1" id="brancheMembresPager"></div>
        </div>
    }
    else
    {
        <div class="text-muted-custom">Aucun membre actif rattache a cette branche.</div>
    }
</div>

<style>
    .branch-export-source {
        position: absolute;
        left: -100000px;
        top: 0;
        width: 1px;
        height: 1px;
        overflow: hidden;
        opacity: 0;
        pointer-events: none;
    }

    .branche-details-logo {
        width: 100%;
        max-width: 120px;
        aspect-ratio: 1;
        object-fit: cover;
        border-radius: 24px;
        border: 1px solid rgba(255, 255, 255, 0.12);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .branche-details-logo--placeholder {
        background: rgba(94, 117, 188, 0.12);
        border: 1px solid rgba(94, 117, 188, 0.25);
        color: var(--bleu-logo);
        font-size: 2rem;
    }

    .branche-kpi-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
        gap: 12px;
    }

    .branche-kpi-card {
        padding: 14px 16px;
        border-radius: 18px;
        background: rgba(255, 255, 255, 0.55);
        border: 1px solid rgba(94, 117, 188, 0.14);
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .branche-kpi-card strong {
        font-size: 1.4rem;
        color: var(--bleu-logo);
        line-height: 1;
    }

    .branche-kpi-card small {
        color: #546173;
    }

    .branche-kpi-label {
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: #7b8a9b;
    }

    .branche-responsable-card {
        border-radius: 24px;
        background: linear-gradient(180deg, rgba(94, 117, 188, 0.12), rgba(255, 255, 255, 0.8));
        border: 1px solid rgba(94, 117, 188, 0.18);
        padding: 18px;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: 10px;
        min-height: 100%;
    }

    .branche-responsable-card__label {
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: #7b8a9b;
    }

    .branche-responsable-card__photo {
        width: 120px;
        height: 120px;
        border-radius: 28px;
        object-fit: cover;
        border: 1px solid rgba(94, 117, 188, 0.18);
        background: rgba(255, 255, 255, 0.75);
    }

    .branche-responsable-card__photo--placeholder {
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--bleu-logo);
        font-size: 3rem;
    }

    .branche-responsable-card__name {
        color: #213547;
    }

    .branche-responsable-card__contact {
        color: var(--bleu-logo);
        font-weight: 600;
    }

    .branche-groupe-head {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 6px;
        text-align: center;
        min-width: 88px;
    }

    .branche-groupe-head__logo-shell {
        width: 54px;
        height: 54px;
        border-radius: 16px;
        background: #fff;
        border: 1px solid rgba(94, 117, 188, 0.18);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex: 0 0 auto;
        box-shadow: 0 4px 10px rgba(18, 24, 33, 0.08);
    }

    .branche-groupe-head__logo {
        width: 42px;
        height: 42px;
        object-fit: contain;
        border-radius: 8px;
    }

    .branche-groupe-head__name {
        display: block;
        font-size: 0.78rem;
        font-weight: 700;
        line-height: 1.15;
        color: var(--bleu-logo);
    }

    .branche-membres-search {
        position: relative;
        flex: 1 1 280px;
        max-width: 420px;
    }

    .branche-membres-search .bi-search {
        position: absolute;
        left: 12px;
        top: 50%;
        transform: translateY(-50%);
        color: #9aa7b6;
        font-size: 0.9rem;
        pointer-events: none;
    }

    .branche-membres-search input {
        padding-left: 34px;
        border-radius: 12px;
    }

    .branche-groupes-table thead th,
    .branche-membres-table thead th {
        border-bottom-width: 1px;
        color: #546173;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }

    .branche-groupes-table tbody th {
        color: #213547;
        white-space: nowrap;
    }

    .branche-groupes-table td strong {
        color: var(--bleu-logo);
    }
</style>

@section Scripts {
    <script>
        (function () {
            var panel = document.getElementById('branche-membres-panel');
            if (!panel) {
                return;
            }

            var rows = Array.prototype.slice.call(panel.querySelectorAll('.branche-membre-row'));
            if (!rows.length) {
                return;
            }

            var searchInput = document.getElementById('brancheMembresSearch');
            var pageSizeSelect = document.getElementById('brancheMembresPageSize');
            var pager = document.getElementById('brancheMembresPager');
            var countLabel = document.getElementById('brancheMembresCount');
            var noResults = document.getElementById('brancheMembresNoResults');
            var tableWrap = document.getElementById('brancheMembresTableWrap');

            var pageSize = parseInt(pageSizeSelect.value, 10) || 20;
            var currentPage = 1;
            var term = '';

            function filtered() {
                if (!term) {
                    return rows;
                }
                return rows.filter(function (row) {
                    return (row.getAttribute('data-search') || '').toLowerCase().indexOf(term) !== -1;
                });
            }

            function makeBtn(label, page, opts) {
                opts = opts || {};
                var btn = document.createElement('button');
                btn.type = 'button';
                btn.className = 'btn btn-sm ' + (opts.active ? 'btn-mango' : 'btn-outline-or');
                btn.innerHTML = label;
                btn.style.minWidth = '38px';
                if (opts.disabled) {
                    btn.disabled = true;
                    btn.style.opacity = '0.5';
                } else {
                    btn.addEventListener('click', function () {
                        currentPage = page;
                        render();
                    });
                }
                return btn;
            }

            function buildPager(totalPages) {
                pager.innerHTML = '';
                if (totalPages <= 1) {
                    return;
                }

                pager.appendChild(makeBtn('<i class="bi bi-chevron-left"></i>', currentPage - 1, { disabled: currentPage <= 1 }));

                var start = Math.max(1, currentPage - 2);
                var end = Math.min(totalPages, currentPage + 2);
                if (end - start < 4) {
                    if (start === 1) { end = Math.min(totalPages, start + 4); }
                    else if (end === totalPages) { start = Math.max(1, end - 4); }
                }
                if (start > 1) {
                    pager.appendChild(makeBtn('1', 1, {}));
                    if (start > 2) {
                        var dots = document.createElement('span');
                        dots.className = 'small text-muted-custom px-1';
                        dots.textContent = '...';
                        pager.appendChild(dots);
                    }
                }
                for (var i = start; i <= end; i++) {
                    pager.appendChild(makeBtn(String(i), i, { active: i === currentPage }));
                }
                if (end < totalPages) {
                    if (end < totalPages - 1) {
                        var dots2 = document.createElement('span');
                        dots2.className = 'small text-muted-custom px-1';
                        dots2.textContent = '...';
                        pager.appendChild(dots2);
                    }
                    pager.appendChild(makeBtn(String(totalPages), totalPages, {}));
                }

                pager.appendChild(makeBtn('<i class="bi bi-chevron-right"></i>', currentPage + 1, { disabled: currentPage >= totalPages }));
            }

            function render() {
                var list = filtered();
                var total = list.length;
                var totalPages = Math.max(1, Math.ceil(total / pageSize));
                if (currentPage > totalPages) {
                    currentPage = totalPages;
                }

                rows.forEach(function (row) { row.style.display = 'none'; });

                var startIndex = (currentPage - 1) * pageSize;
                var pageRows = list.slice(startIndex, startIndex + pageSize);
                pageRows.forEach(function (row) { row.style.display = ''; });

                if (noResults) { noResults.style.display = total === 0 ? '' : 'none'; }
                if (tableWrap) { tableWrap.style.display = total === 0 ? 'none' : ''; }

                if (countLabel) {
                    if (total === 0) {
                        countLabel.textContent = '0 membre';
                    } else {
                        countLabel.textContent = (startIndex + 1) + '-' + (startIndex + pageRows.length) + ' sur ' + total + ' membre(s)';
                    }
                }

                buildPager(totalPages);
            }

            if (searchInput) {
                searchInput.addEventListener('input', function () {
                    term = this.value.trim().toLowerCase();
                    currentPage = 1;
                    render();
                });
            }
            if (pageSizeSelect) {
                pageSizeSelect.addEventListener('change', function () {
                    pageSize = parseInt(this.value, 10) || 20;
                    currentPage = 1;
                    render();
                });
            }

            render();
        })();
    </script>
}
