@model BrancheDto
@{
    ViewData["Title"] = "Detail de la branche";
    Layout = "_LayoutAdmin";
    var canManage = User.IsInRole("Administrateur") || User.IsInRole("Gestionnaire");
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
    <h2 class="section-title mb-0"><i class="bi bi-diagram-3-fill text-or"></i> @Model.Nom</h2>
    <div class="d-flex flex-wrap gap-2">
        @if (canManage)
        {
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-bleu btn-sm" title="Modifier"><i class="bi bi-pencil"></i></a>
        }
        <a asp-action="Index" class="btn btn-outline-or btn-sm" title="Liste"><i class="bi bi-arrow-left"></i></a>
    </div>
</div>

<div class="card-3d p-4">
    <div class="d-flex flex-wrap align-items-center gap-3 mb-3">
        @if (!string.IsNullOrWhiteSpace(Model.LogoUrl))
        {
            <img src="@Model.LogoUrl" alt="Logo de la branche @Model.Nom" style="width:88px;height:88px;object-fit:cover;border-radius:20px;border:1px solid rgba(255,255,255,0.12);" />
        }
        else
        {
            <div style="width:88px;height:88px;border-radius:20px;background:rgba(94,117,188,0.12);border:1px solid rgba(94,117,188,0.25);display:flex;align-items:center;justify-content:center;">
                <i class="bi bi-diagram-3" style="font-size:2rem;color:var(--bleu-logo);"></i>
            </div>
        }
        <div>
            <h4 class="mb-1">@Model.Nom</h4>
            <p class="text-muted-custom mb-0">@(Model.NomGroupe ?? "Groupe non renseigne")</p>
        </div>
    </div>
    <p class="text-muted-custom mb-3">@(Model.Description ?? "-")</p>
    <dl class="row mb-0 small">
        <dt class="col-sm-4 text-muted-custom">Groupe</dt>
        <dd class="col-sm-8">@(Model.NomGroupe ?? "-")</dd>
        <dt class="col-sm-4 text-muted-custom">Scouts</dt>
        <dd class="col-sm-8">@Model.NombreScouts</dd>
        <dt class="col-sm-4 text-muted-custom">Chef d'unite</dt>
        <dd class="col-sm-8">@(Model.NomChefUnite ?? "-")</dd>
    </dl>
</div>
