@model List<MangoTaika.Data.Entities.DonPublic>
@{
    ViewData["Title"] = "Dons";
    Layout = "_LayoutAdmin";
    var selectedStatut = ViewBag.Statut as MangoTaika.Data.Entities.StatutDonPublic?;
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
    <h2 class="section-title mb-0"><i class="bi bi-heart-fill text-or"></i> Gestion des dons</h2>
    <a asp-controller="Home" asp-action="FaireUnDon" class="btn btn-outline-or btn-sm" target="_blank">
        <i class="bi bi-box-arrow-up-right"></i> Page publique
    </a>
</div>

<form method="get" class="card-3d p-3 mb-4">
    <div class="row g-2 align-items-end">
        <div class="col-md-4">
            <label class="form-label">Statut</label>
            <select name="statut" class="form-select">
                <option value="">Tous</option>
                @foreach (var statut in Enum.GetValues<MangoTaika.Data.Entities.StatutDonPublic>())
                {
                    <option value="@statut" selected="@(selectedStatut == statut ? "selected" : null)">@statut</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <button class="btn btn-or w-100" type="submit">Filtrer</button>
        </div>
    </div>
</form>

<div class="card-3d p-4">
    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Donateur</th>
                        <th>Reference</th>
                        <th>Statut</th>
                        <th class="text-end">Montant</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var don in Model)
                    {
                        <tr>
                            <td>@don.DateCreation.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                <strong>@don.NomDonateur</strong>
                                <div class="small text-muted-custom">@don.Telephone @don.Email</div>
                            </td>
                            <td>@(don.ReferencePaiement ?? "-")</td>
                            <td><span class="badge-3d @(don.Statut == MangoTaika.Data.Entities.StatutDonPublic.Confirme ? "badge-approuvee" : don.Statut == MangoTaika.Data.Entities.StatutDonPublic.Rejete ? "badge-rejetee" : "badge-soumise")">@don.Statut</span></td>
                            <td class="text-end">@don.Montant.ToString("N0") @don.Devise</td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@don.Id" class="btn btn-outline-or btn-sm">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p class="text-muted-custom mb-0">Aucun don trouve.</p>
    }
</div>
