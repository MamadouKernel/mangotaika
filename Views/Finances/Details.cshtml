@model TransactionFinanciere
@using MangoTaika.Data.Entities
@{
    ViewData["Title"] = "Detail transaction";
    Layout = "_LayoutAdmin";
    var canManage = User.IsInRole("Administrateur") || User.IsInRole("Gestionnaire");
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
    <h2 class="section-title mb-0"><i class="bi bi-wallet2 text-or"></i> Transaction</h2>
    <div class="d-flex flex-wrap gap-2">
        @if (canManage)
        {
            @if (Model.Statut == StatutTransactionFinanciere.Declaree)
            {
                <form asp-action="ValiderDeclaration" asp-route-id="@Model.Id" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-mango btn-sm"><i class="bi bi-check2-circle"></i> Valider</button>
                </form>
                <form asp-action="RejeterDeclaration" asp-route-id="@Model.Id" method="post" class="d-inline" onsubmit="const motif = prompt('Motif de rejet :'); if (motif === null) return false; this.querySelector('[name=motif]').value = motif;">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="motif" />
                    <button type="submit" class="btn btn-sm" style="background:rgba(239,68,68,0.15);color:#f87171;border:1px solid rgba(239,68,68,0.3);border-radius:14px;"><i class="bi bi-x-lg"></i> Rejeter</button>
                </form>
            }
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-bleu btn-sm" title="Modifier"><i class="bi bi-pencil"></i></a>
        }
        <a asp-action="Index" asp-route-annee="@Model.DateTransaction.Year" class="btn btn-outline-or btn-sm" title="Liste"><i class="bi bi-arrow-left"></i></a>
    </div>
</div>

<div class="card-3d p-4">
    <h4 class="text-or mb-3">@Model.Libelle</h4>
    <div class="mb-2">
        <span class="badge-3d @(Model.Statut == StatutTransactionFinanciere.Validee ? "badge-validee" : Model.Statut == StatutTransactionFinanciere.Rejetee ? "badge-rejetee" : "badge-soumise")">@Model.Statut</span>
        <span class="badge bg-secondary bg-opacity-25 ms-1" style="color:var(--bleu-logo);border-radius:10px;">@Model.Categorie</span>
    </div>
    <p style="font-size:1.5rem;font-weight:700;color:@(Model.Type == TypeTransaction.Recette ? "#10b981" : "#f87171");">
        @(Model.Type == TypeTransaction.Recette ? "+" : "-")@Model.Montant.ToString("N0") <small class="fw-normal">FCFA</small>
    </p>
    <dl class="row mb-0">
        <dt class="col-sm-3">Reference</dt>
        <dd class="col-sm-9">@(Model.Reference ?? "-")</dd>
        <dt class="col-sm-3">Activite</dt>
        <dd class="col-sm-9">@(Model.Activite?.Titre ?? "-")</dd>
        <dt class="col-sm-3">Payeur</dt>
        <dd class="col-sm-9">@(Model.Scout != null ? $"{Model.Scout.Nom} {Model.Scout.Prenom}" : Model.Createur != null ? $"{Model.Createur.Prenom} {Model.Createur.Nom}".Trim() : "-")</dd>
        <dt class="col-sm-3">Commentaire</dt>
        <dd class="col-sm-9">@(Model.Commentaire ?? "-")</dd>
    </dl>
</div>
