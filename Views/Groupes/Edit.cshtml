@model GroupeDto
@{
    ViewData["Title"] = "Modifier l'entite";
    Layout = "_LayoutAdmin";
    var chefsGroupe = ViewBag.ChefsGroupe as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> ?? Enumerable.Empty<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>();
    var parts = (Model.Adresse ?? "").Split(',', 2, StringSplitOptions.TrimEntries);
    var quartier = parts.Length > 0 ? parts[0] : "";
    var commune = parts.Length > 1 ? parts[1] : "";
}

<h2 class="section-title mb-1"><i class="bi bi-pencil-fill text-or"></i> Modifier l'<span class="accent">entite</span></h2>
<div class="section-divider"></div>

<div class="card-3d p-4 mt-3">
    <form asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data" class="form-modern">
        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
        <input asp-for="LogoUrl" type="hidden" />
        <div class="mb-3">
            <label class="form-label">Nom de l'entite</label>
            <input name="Nom" class="form-control" value="@Model.Nom" />
            <span asp-validation-for="Nom" class="text-danger small"></span>
        </div>
        <div class="mb-3">
            <label class="form-label">Description</label>
            <textarea name="Description" class="form-control" rows="3">@Model.Description</textarea>
        </div>
        <div class="mb-3">
            <label class="form-label">Logo de l'entite</label>
            <input type="file" name="Logo" class="form-control" accept="image/*" />
            <small class="text-muted-custom">Formats acceptes: JPG, PNG, GIF, WEBP. Taille maximale: 5 Mo.</small>
            <span asp-validation-for="LogoUrl" class="text-danger small d-block"></span>
            @if (!string.IsNullOrWhiteSpace(Model.LogoUrl))
            {
                <div class="mt-2">
                    <img src="@Model.LogoUrl" alt="Logo actuel de l'entite" style="width:72px;height:72px;object-fit:cover;border-radius:16px;border:1px solid rgba(255,255,255,0.12);" />
                </div>
            }
        </div>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Commune</label>
                <input name="Commune" class="form-control" value="@commune" placeholder="Ex: Cocody" />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">Quartier / Lieu-dit</label>
                <input name="Quartier" class="form-control" value="@quartier" placeholder="Ex: 2 Plateaux, Carrefour Celeste" />
            </div>
        </div>
        <div class="mb-3">
            <label asp-for="ChefGroupeScoutId" class="form-label">Chef de groupe</label>
            <select asp-for="ChefGroupeScoutId" class="form-select">
                <option value="">-- Selectionner un chef de groupe --</option>
                @foreach (var chef in chefsGroupe)
                {
                    <option value="@chef.Value" selected="@(chef.Selected ? "selected" : null)">@chef.Text</option>
                }
            </select>
            <small class="text-muted-custom">Pour Equipe de District Mango Taika, les fonctions CD, CDA et ACD sont proposees. Pour les autres entites, seule la fonction CHEF DE GROUPE (CG) est proposee.</small>
            <span asp-validation-for="ChefGroupeScoutId" class="text-danger small d-block"></span>
        </div>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Latitude <small class="text-muted-custom">(optionnel, si le geocodage echoue)</small></label>
                <input name="Latitude" class="form-control" type="number" step="0.000001" value="@Model.Latitude" placeholder="Ex: 5.3364" />
                <span asp-validation-for="Latitude" class="text-danger small"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">Longitude <small class="text-muted-custom">(optionnel)</small></label>
                <input name="Longitude" class="form-control" type="number" step="0.000001" value="@Model.Longitude" placeholder="Ex: -4.0267" />
                <span asp-validation-for="Longitude" class="text-danger small"></span>
            </div>
        </div>
        <div class="d-flex gap-2 mt-2">
            <button type="submit" class="btn btn-mango" title="Mettre a jour"><i class="bi bi-check-lg"></i></button>
            <a asp-action="Index" class="btn btn-outline-or" title="Annuler"><i class="bi bi-x-lg"></i></a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}



