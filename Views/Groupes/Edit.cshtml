@model GroupeDto
@{
    ViewData["Title"] = "Modifier groupe";
    Layout = "_LayoutAdmin";
    // Extraire commune et quartier depuis l'adresse stockée "Quartier, Commune"
    var parts = (Model.Adresse ?? "").Split(',', 2, StringSplitOptions.TrimEntries);
    var quartier = parts.Length > 0 ? parts[0] : "";
    var commune = parts.Length > 1 ? parts[1] : "";
}

<h2 class="section-title mb-1"><i class="bi bi-pencil-fill text-or"></i> Modifier le <span class="accent">groupe</span></h2>
<div class="section-divider"></div>

<div class="card-3d p-4 mt-3">
    <form asp-action="Edit" asp-route-id="@Model.Id" method="post" class="form-modern">
        <div class="mb-3">
            <label class="form-label">Nom</label>
            <input name="Nom" class="form-control" value="@Model.Nom" />
        </div>
        <div class="mb-3">
            <label class="form-label">Description</label>
            <textarea name="Description" class="form-control" rows="3">@Model.Description</textarea>
        </div>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Commune</label>
                <input name="Commune" class="form-control" value="@commune" placeholder="Ex: Cocody" />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">Quartier / Lieu-dit</label>
                <input name="Quartier" class="form-control" value="@quartier" placeholder="Ex: 2 Plateaux, Carrefour Céleste" />
            </div>
        </div>
        <div class="mb-3">
            <label class="form-label">Noms des Adjoints</label>
            <input name="NomAdjoints" class="form-control" value="@Model.NomAdjoints" placeholder="Ex: Koné Moussa, Traoré Awa" />
            <small class="text-muted-custom">Séparez les noms par des virgules.</small>
        </div>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Latitude <small class="text-muted-custom">(optionnel, si le géocodage échoue)</small></label>
                <input name="Latitude" class="form-control" type="number" step="0.000001" value="@Model.Latitude" placeholder="Ex: 5.3364" />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">Longitude <small class="text-muted-custom">(optionnel)</small></label>
                <input name="Longitude" class="form-control" type="number" step="0.000001" value="@Model.Longitude" placeholder="Ex: -4.0267" />
            </div>
        </div>
        <div class="d-flex gap-2 mt-2">
            <button type="submit" class="btn btn-mango" title="Mettre à jour"><i class="bi bi-check-lg"></i></button>
            <a asp-action="Index" class="btn btn-outline-or" title="Annuler"><i class="bi bi-x-lg"></i></a>
        </div>
    </form>
</div>
