@model GroupeCreateDto
@{
    ViewData["Title"] = "Nouvelle entite";
    Layout = "_LayoutAdmin";
    var chefsGroupe = ViewBag.ChefsGroupe as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> ?? Enumerable.Empty<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>();
    var hasChefsGroupe = chefsGroupe.Any();
}

<h2 class="section-title mb-1"><i class="bi bi-plus-lg text-or"></i> Nouvelle <span class="accent">entite</span></h2>
<div class="section-divider"></div>

<div class="card-3d p-4 mt-3">
    <form asp-action="Create" method="post" enctype="multipart/form-data" class="form-modern">
        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
        <input asp-for="LogoUrl" type="hidden" />
        <div class="mb-3">
            <label asp-for="Nom" class="form-label">Nom de l'entite</label>
            <input asp-for="Nom" class="form-control" />
            <span asp-validation-for="Nom" class="text-danger small"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Description" class="form-label">Description</label>
            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
        </div>
        <div class="mb-3">
            <label class="form-label">Logo de l'entite</label>
            <input type="file" name="Logo" class="form-control" accept="image/*" />
            <small class="text-muted-custom">Formats acceptes: JPG, PNG, GIF, WEBP. Taille maximale: 5 Mo.</small>
            <span asp-validation-for="LogoUrl" class="text-danger small d-block"></span>
            @if (!string.IsNullOrWhiteSpace(Model?.LogoUrl))
            {
                <div class="mt-2">
                    <img src="@Model.LogoUrl" alt="Apercu du logo de l'entite" style="width:72px;height:72px;object-fit:cover;border-radius:16px;border:1px solid rgba(255,255,255,0.12);" />
                </div>
            }
        </div>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="Commune" class="form-label">Commune</label>
                <input asp-for="Commune" class="form-control" placeholder="Ex: Cocody" />
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="Quartier" class="form-label">Quartier / Lieu-dit</label>
                <input asp-for="Quartier" class="form-control" placeholder="Ex: 2 Plateaux, Carrefour Celeste" />
            </div>
        </div>
        <div class="mb-3">
            <label asp-for="ChefGroupeScoutId" class="form-label">Chef de groupe</label>
            @if (hasChefsGroupe)
            {
                <select asp-for="ChefGroupeScoutId" class="form-select">
                    <option value="">-- Selectionner un chef de groupe --</option>
                    @foreach (var chef in chefsGroupe)
                    {
                        <option value="@chef.Value" selected="@(chef.Selected ? "selected" : null)">@chef.Text</option>
                    }
                </select>
            }
            else
            {
                <select class="form-select" disabled>
                    <option value="">-- Enregistrez d'abord l'entite --</option>
                </select>
            }
            <small class="text-muted-custom">Apres creation de l'entite, revenez sur la modification pour selectionner un scout ayant la fonction Chef de groupe.</small>
            <span asp-validation-for="ChefGroupeScoutId" class="text-danger small d-block"></span>
        </div>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="Latitude" class="form-label">Latitude <small class="text-muted-custom">(optionnel, si le geocodage echoue)</small></label>
                <input asp-for="Latitude" class="form-control" type="number" step="0.000001" placeholder="Ex: 5.3364" />
                <span asp-validation-for="Latitude" class="text-danger small"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="Longitude" class="form-label">Longitude <small class="text-muted-custom">(optionnel)</small></label>
                <input asp-for="Longitude" class="form-control" type="number" step="0.000001" placeholder="Ex: -4.0267" />
                <span asp-validation-for="Longitude" class="text-danger small"></span>
            </div>
        </div>
        <div class="d-flex gap-2 mt-2">
            <button type="submit" class="btn btn-mango"><i class="bi bi-check-lg"></i> Creer</button>
            <a asp-action="Index" class="btn btn-outline-or">Annuler</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

