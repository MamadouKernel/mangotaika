@model List<GroupeDto>
@{
    ViewData["Title"] = "Entites scouts";
    Layout = "_LayoutAdmin";
    var canManage = User.IsInRole("Administrateur") || User.IsInRole("Gestionnaire");

    static string GetResponsableLabel(string groupeNom)
    {
        return string.Equals((groupeNom ?? string.Empty).Trim(), "Equipe de District Mango Taika", StringComparison.OrdinalIgnoreCase)
            ? "Commissaire de district"
            : "Chef de groupe";
    }
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="section-title mb-0"><i class="bi bi-building text-or"></i> Entit&eacute;s <span class="accent">Scouts du District</span></h2>
    @if (canManage)
    {
        <a asp-action="Create" class="btn btn-mango"><i class="bi bi-plus-lg"></i> Nouvelle entite</a>
    }
</div>

<div class="row g-4">
    @foreach (var g in Model)
    {
        <div class="col-md-4">
            <div class="card-3d p-4 h-100">
                <div class="d-flex align-items-center gap-3 mb-3">
                    @if (!string.IsNullOrWhiteSpace(g.LogoUrl))
                    {
                        <img src="@g.LogoUrl" alt="Logo du groupe @g.Nom" style="width:64px;height:64px;object-fit:cover;border-radius:16px;border:1px solid rgba(255,255,255,0.12);" />
                    }
                    else
                    {
                        <div style="width:64px;height:64px;border-radius:16px;background:rgba(138,181,90,0.12);border:1px solid rgba(138,181,90,0.25);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                            <i class="bi bi-building" style="font-size:1.5rem;color:var(--vert-logo);"></i>
                        </div>
                    }
                    <div class="min-w-0">
                        <h5 class="text-or mb-1">@g.Nom</h5>
                        <p class="text-muted-custom small mb-0">@(g.Description ?? "")</p>
                    </div>
                </div>
                <div class="d-flex flex-column gap-1 mb-3" style="font-size:0.85rem;">
                    <span><i class="bi bi-people-fill text-bleu"></i> @g.NombreMembres membres</span>
                    <span><i class="bi bi-geo-alt-fill text-or"></i> @(g.Adresse ?? "Adresse non renseignee")</span>
                    @if (g.NomChefGroupe != null)
                    {
                        <span><i class="bi bi-person-fill text-bleu"></i> @GetResponsableLabel(g.Nom) : @g.NomChefGroupe</span>
                    }
                    @if (!string.IsNullOrWhiteSpace(g.ContactChefGroupe))
                    {
                        <span><i class="bi bi-telephone-fill text-or"></i> Contact : @g.ContactChefGroupe</span>
                    }
                </div>
                <div class="d-flex flex-wrap gap-2">
                    <a asp-action="Details" asp-route-id="@g.Id" class="btn btn-sm btn-outline-or" title="Details">
                        <i class="bi bi-eye"></i>
                    </a>
                    @if (canManage)
                    {
                        <a asp-action="Edit" asp-route-id="@g.Id" class="btn btn-sm btn-bleu" title="Modifier">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <form asp-action="Delete" asp-route-id="@g.Id" method="post"
                              onsubmit="return confirm('Confirmer ?')">
                            <button type="submit" class="btn btn-sm" style="background:rgba(239,68,68,0.2);color:#f87171;border:1px solid rgba(239,68,68,0.3);border-radius:14px;" title="Supprimer">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                    }
                </div>
            </div>
        </div>
    }
    @if (!Model.Any())
    {
        <div class="col-12 text-center text-muted-custom py-5">Aucune entite enregistree</div>
    }
</div>

<partial name="_ListPagination" />

