@model GroupeDto
@{
    ViewData["Title"] = "Detail du groupe";
    Layout = "_LayoutAdmin";
    var canManage = User.IsInRole("Administrateur") || User.IsInRole("Gestionnaire");
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
    <h2 class="section-title mb-0"><i class="bi bi-building text-or"></i> @Model.Nom</h2>
    <div class="d-flex flex-wrap gap-2">
        @if (canManage)
        {
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-bleu btn-sm" title="Modifier"><i class="bi bi-pencil"></i></a>
        }
        <a asp-action="Index" class="btn btn-outline-or btn-sm" title="Liste"><i class="bi bi-arrow-left"></i></a>
    </div>
</div>

<div class="card-3d p-4 mb-4">
    <div class="d-flex flex-wrap align-items-center gap-3 mb-3">
        @if (!string.IsNullOrWhiteSpace(Model.LogoUrl))
        {
            <img src="@Model.LogoUrl" alt="Logo du groupe @Model.Nom" style="width:88px;height:88px;object-fit:cover;border-radius:20px;border:1px solid rgba(255,255,255,0.12);" />
        }
        else
        {
            <div style="width:88px;height:88px;border-radius:20px;background:rgba(138,181,90,0.12);border:1px solid rgba(138,181,90,0.25);display:flex;align-items:center;justify-content:center;">
                <i class="bi bi-building" style="font-size:2rem;color:var(--vert-logo);"></i>
            </div>
        }
        <div>
            <h4 class="mb-1">@Model.Nom</h4>
            <p class="text-muted-custom mb-0">@(Model.Adresse ?? "Adresse non renseignee")</p>
        </div>
    </div>
    <p class="text-muted-custom mb-3">@(Model.Description ?? "-")</p>
    <dl class="row mb-0 small">
        <dt class="col-sm-3 text-muted-custom">Adresse</dt>
        <dd class="col-sm-9">@(Model.Adresse ?? "-")</dd>
        <dt class="col-sm-3 text-muted-custom">Membres</dt>
        <dd class="col-sm-9">@Model.NombreMembres</dd>
        <dt class="col-sm-3 text-muted-custom">Chef de groupe</dt>
        <dd class="col-sm-9">@(Model.NomChefGroupe ?? "-")</dd>
    </dl>
</div>
