@model GroupeDto
@{
    ViewData["Title"] = "Detail de l'entite";
    Layout = "_LayoutAdmin";
    var canManage = User.IsInRole("Administrateur") || User.IsInRole("Gestionnaire");
    var responsableLabel = string.Equals((Model.Nom ?? string.Empty).Trim(), "Equipe de District Mango Taika", StringComparison.OrdinalIgnoreCase)
        ? "Commissaire du district"
        : "Chef de groupe";

    static string GetBranchAccent(string nom)
    {
        var normalized = (nom ?? string.Empty).Trim().ToUpperInvariant();

        return normalized switch
        {
            var value when value.Contains("OISILLON") => "#ec4899",
            var value when value.Contains("LOUVETEAU") => "#facc15",
            var value when value.Contains("ECLAIREUR") => "#16a34a",
            var value when value.Contains("CHEMINOT") => "#f59e0b",
            var value when value.Contains("ROUTIER") => "#ef4444",
            _ => "#5f7f43"
        };
    }
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
    <h2 class="section-title mb-0"><i class="bi bi-building text-or"></i> @Model.Nom</h2>
    <div class="d-flex flex-wrap gap-2">
        @if (canManage)
        {
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-bleu btn-sm" title="Modifier"><i class="bi bi-pencil"></i></a>
        }
        <a asp-action="Index" class="btn btn-outline-or btn-sm" title="Liste"><i class="bi bi-arrow-left"></i></a>
    </div>
</div>

<div class="card-3d p-4 mb-4">
    <div class="row g-4 align-items-start">
        <div class="col-xl-2 col-lg-3">
            @if (!string.IsNullOrWhiteSpace(Model.LogoUrl))
            {
                <img src="@Model.LogoUrl"
                     alt="Logo du groupe @Model.Nom"
                     class="groupe-details-logo" />
            }
            else
            {
                <div class="groupe-details-logo groupe-details-logo--placeholder">
                    <i class="bi bi-building"></i>
                </div>
            }
        </div>

        <div class="col-xl-7 col-lg-6">
            <div class="mb-3">
                <h4 class="mb-1">@Model.Nom</h4>
                <p class="text-muted-custom mb-2">@(Model.Adresse ?? "Adresse non renseignee")</p>
                <p class="text-muted-custom mb-0">@(Model.Description ?? "-")</p>
            </div>

            <div class="groupe-kpi-grid mb-3">
                <div class="groupe-kpi-card">
                    <span class="groupe-kpi-label">Membres</span>
                    <strong>@Model.NombreMembres</strong>
                    <small>@Model.NombreFilles filles | @Model.NombreGarcons garcons</small>
                </div>
                <div class="groupe-kpi-card">
                    <span class="groupe-kpi-label">Jeunes</span>
                    <strong>@Model.Jeunes.Total</strong>
                    <small>@Model.Jeunes.NombreFeminin filles | @Model.Jeunes.NombreMasculin garcons</small>
                </div>
                <div class="groupe-kpi-card">
                    <span class="groupe-kpi-label">Adultes</span>
                    <strong>@Model.Adultes.Total</strong>
                    <small>@Model.Adultes.NombreFeminin femmes | @Model.Adultes.NombreMasculin hommes</small>
                </div>
            </div>

            <dl class="row mb-0 small">
                <dt class="col-sm-4 text-muted-custom">Adresse</dt>
                <dd class="col-sm-8">@(Model.Adresse ?? "-")</dd>

                <dt class="col-sm-4 text-muted-custom">@responsableLabel</dt>
                <dd class="col-sm-8">@(Model.NomChefGroupe ?? "-")</dd>

                <dt class="col-sm-4 text-muted-custom">Contact</dt>
                <dd class="col-sm-8">@(Model.ContactChefGroupe ?? "-")</dd>

                <dt class="col-sm-4 text-muted-custom">R&eacute;partition g&eacute;n&eacute;rale</dt>
                <dd class="col-sm-8">@Model.NombreMembres membres | @Model.NombreFilles filles | @Model.NombreGarcons garcons</dd>

                <dt class="col-sm-4 text-muted-custom">Jeunes</dt>
                <dd class="col-sm-8">@Model.Jeunes.Total | Filles @Model.Jeunes.NombreFeminin / Garcons @Model.Jeunes.NombreMasculin</dd>

                <dt class="col-sm-4 text-muted-custom">Adultes</dt>
                <dd class="col-sm-8">@Model.Adultes.Total | Femmes @Model.Adultes.NombreFeminin / Hommes @Model.Adultes.NombreMasculin</dd>
            </dl>
        </div>

        <div class="col-xl-3 col-lg-3">
            <div class="responsable-card">
                <span class="responsable-card__label">@responsableLabel</span>
                @if (!string.IsNullOrWhiteSpace(Model.ResponsablePhotoUrl))
                {
                    <img src="@Model.ResponsablePhotoUrl"
                         alt="Photo du chef de groupe @Model.NomChefGroupe"
                         class="responsable-card__photo" />
                }
                else
                {
                    <div class="responsable-card__photo responsable-card__photo--placeholder">
                        <i class="bi bi-person-circle"></i>
                    </div>
                }
                <strong class="responsable-card__name">@(Model.NomChefGroupe ?? "Non renseigne")</strong>
                <span class="responsable-card__contact">@(Model.ContactChefGroupe ?? "Contact non renseigne")</span>
            </div>
        </div>
    </div>
</div>

<div class="card-3d p-4">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
        <div>
            <h4 class="mb-1">Totaux par branche</h4>
            <p class="text-muted-custom mb-0">Totaux par branche avec le detail scouts, jeunes et adultes.</p>
        </div>
    </div>

    @if (Model.BranchesScouts.Any())
    {
        <div class="groupe-branches-grid mb-4">
            @foreach (var branche in Model.BranchesScouts)
            {
                <div class="branche-summary-card" style="--branch-accent:@GetBranchAccent(branche.Nom)">
                    <span class="branche-summary-card__name">@branche.Nom</span>
                    <strong class="branche-summary-card__total">@branche.NombreScouts</strong>
                    <small class="branche-summary-card__meta">@branche.NombreFilles filles | @branche.NombreGarcons garcons</small>
                    <small class="branche-summary-card__meta">Jeunes @branche.Jeunes.Total | Adultes @branche.Adultes.Total</small>
                </div>
            }
        </div>

        <div class="table-responsive">
            <table class="table table-sm align-middle groupe-branches-table mb-0">
                <thead>
                    <tr>
                        <th scope="col">Cat&eacute;gorie</th>
                        @foreach (var branche in Model.BranchesScouts)
                        {
                            <th scope="col">@branche.Nom</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <th scope="row">Scouts</th>
                        @foreach (var branche in Model.BranchesScouts)
                        {
                            <td>
                                <strong>@branche.NombreScouts</strong>
                                <div class="small text-muted-custom">
                                    F @branche.NombreFilles / G @branche.NombreGarcons
                                </div>
                            </td>
                        }
                    </tr>
                    <tr>
                        <th scope="row">Jeunes</th>
                        @foreach (var branche in Model.BranchesScouts)
                        {
                            <td>
                                <strong>@branche.Jeunes.Total</strong>
                                <div class="small text-muted-custom">
                                    F @branche.Jeunes.NombreFeminin / G @branche.Jeunes.NombreMasculin
                                </div>
                            </td>
                        }
                    </tr>
                    <tr>
                        <th scope="row">Adultes</th>
                        @foreach (var branche in Model.BranchesScouts)
                        {
                            <td>
                                <strong>@branche.Adultes.Total</strong>
                                <div class="small text-muted-custom">
                                    F @branche.Adultes.NombreFeminin / G @branche.Adultes.NombreMasculin
                                </div>
                            </td>
                        }
                    </tr>
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-muted-custom">Aucune branche active rattachee a cette entite.</div>
    }
</div>

<style>
    .groupe-details-logo {
        width: 100%;
        max-width: 120px;
        aspect-ratio: 1;
        object-fit: cover;
        border-radius: 24px;
        border: 1px solid rgba(255, 255, 255, 0.12);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .groupe-details-logo--placeholder {
        background: rgba(138, 181, 90, 0.12);
        border: 1px solid rgba(138, 181, 90, 0.25);
        color: var(--vert-logo);
        font-size: 2rem;
    }

    .groupe-kpi-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
        gap: 12px;
    }

    .groupe-kpi-card {
        padding: 14px 16px;
        border-radius: 18px;
        background: rgba(255, 255, 255, 0.55);
        border: 1px solid rgba(95, 127, 67, 0.12);
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .groupe-kpi-card strong {
        font-size: 1.4rem;
        color: var(--vert-logo);
        line-height: 1;
    }

    .groupe-kpi-card small {
        color: #546173;
    }

    .groupe-kpi-label {
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: #7b8a9b;
    }

    .responsable-card {
        border-radius: 24px;
        background: linear-gradient(180deg, rgba(95, 127, 67, 0.12), rgba(255, 255, 255, 0.8));
        border: 1px solid rgba(95, 127, 67, 0.18);
        padding: 18px;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: 10px;
        min-height: 100%;
    }

    .responsable-card__label {
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: #7b8a9b;
    }

    .responsable-card__photo {
        width: 120px;
        height: 120px;
        border-radius: 28px;
        object-fit: cover;
        border: 1px solid rgba(95, 127, 67, 0.18);
        background: rgba(255, 255, 255, 0.75);
    }

    .responsable-card__photo--placeholder {
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--vert-logo);
        font-size: 3rem;
    }

    .responsable-card__name {
        color: #213547;
    }

    .responsable-card__contact {
        color: #5f7f43;
        font-weight: 600;
    }

    .groupe-branches-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        gap: 14px;
    }

    .branche-summary-card {
        border-radius: 22px;
        padding: 18px 16px;
        color: #fff;
        background: linear-gradient(135deg, var(--branch-accent), color-mix(in srgb, var(--branch-accent) 78%, #111 22%));
        box-shadow: 0 16px 28px rgba(18, 24, 33, 0.16);
        display: flex;
        flex-direction: column;
        gap: 6px;
        min-height: 132px;
    }

    .branche-summary-card__name {
        font-size: 0.9rem;
        font-weight: 700;
    }

    .branche-summary-card__total {
        font-size: 2rem;
        line-height: 1;
    }

    .branche-summary-card__meta {
        opacity: 0.92;
    }

    .groupe-branches-table thead th {
        border-bottom-width: 1px;
        color: #546173;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }

    .groupe-branches-table tbody th {
        color: #213547;
        white-space: nowrap;
    }

    .groupe-branches-table td strong {
        color: var(--vert-logo);
        display: block;
    }
</style>


