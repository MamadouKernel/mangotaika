@model MembreHistorique
@using MangoTaika.Data.Entities
@{
    ViewData["Title"] = Model.Nom;
    Layout = "_LayoutAdmin";
    var canManage = User.IsInRole("Administrateur") || User.IsInRole("Gestionnaire");
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
    <h2 class="section-title mb-0"><i class="bi bi-clock-history text-or"></i> @Model.Nom</h2>
    <div class="d-flex flex-wrap gap-2">
        @if (canManage)
        {
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-bleu btn-sm" title="Modifier"><i class="bi bi-pencil"></i></a>
        }
        <a asp-action="Index" class="btn btn-outline-or btn-sm" title="Liste"><i class="bi bi-arrow-left"></i></a>
    </div>
</div>

<div class="card-3d p-4">
    @if (Model.CategorieDetails.Any())
    {
        <div class="d-flex flex-column gap-3">
            @foreach (var detail in Model.CategorieDetails.OrderBy(entry => entry.Ordre).ThenBy(entry => entry.Categorie))
            {
                <div class="border rounded-3 p-3" style="border-color:rgba(255,255,255,0.08)!important;">
                    <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
                        <span class="badge-3d badge-soumise">@detail.Categorie.GetLabel()</span>
                    </div>

                    <dl class="row mb-0 small">
                        <dt class="col-sm-3 text-muted-custom">Période</dt>
                        <dd class="col-sm-9">@(detail.Periode ?? "-")</dd>

                        <dt class="col-sm-3 text-muted-custom">Ordre</dt>
                        <dd class="col-sm-9">@detail.Ordre</dd>
                    </dl>

                    @if (!string.IsNullOrWhiteSpace(detail.Description))
                    {
                        <h6 class="text-or mt-4 mb-2">Biographie / texte</h6>
                        <div class="text-muted-custom small" style="white-space:pre-wrap;line-height:1.7;">@detail.Description</div>
                    }
                </div>
            }
        </div>
    }
    else
    {
        <div class="d-flex flex-wrap gap-2">
            @foreach (var category in Model.Categories.GetSelectedCategories())
            {
                <span class="badge-3d badge-soumise">@category.GetLabel()</span>
            }
        </div>

        <dl class="row mt-4 mb-0 small">
            <dt class="col-sm-3 text-muted-custom">Période</dt>
            <dd class="col-sm-9">@(Model.Periode ?? "-")</dd>

            <dt class="col-sm-3 text-muted-custom">Ordre</dt>
            <dd class="col-sm-9">@Model.Ordre</dd>
        </dl>

        @if (!string.IsNullOrWhiteSpace(Model.Description))
        {
            <h6 class="text-or mt-4 mb-2">Biographie / texte</h6>
            <div class="text-muted-custom small" style="white-space:pre-wrap;line-height:1.7;">@Model.Description</div>
        }
    }
</div>
