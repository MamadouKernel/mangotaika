@model MangoTaika.Models.HistoriqueFormViewModel
@{
    ViewData["Title"] = "Ajouter un membre historique";
    Layout = "_LayoutAdmin";
}

<h2 class="section-title mb-1"><i class="bi bi-plus-lg text-or"></i> Ajouter un <span class="accent">membre historique</span></h2>
<div class="section-divider"></div>

<div class="card-3d p-4 mt-3" style="max-width:840px;">
    <form asp-action="Create" method="post" enctype="multipart/form-data" class="form-modern">
        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

        <partial name="_HistoriqueFormFields" model="Model" />

        <div class="d-flex flex-wrap gap-2">
            <button type="submit" class="btn btn-mango"><i class="bi bi-check-lg"></i> Enregistrer</button>
            <a asp-action="Index" class="btn btn-outline-or">Annuler</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <partial name="_HistoriqueFormScripts" />
}
