@model MangoTaika.Models.HistoriqueIndexViewModel
@using MangoTaika.Data.Entities
@{
    ViewData["Title"] = "Membres historiques";
    Layout = "_LayoutAdmin";
    var canManage = User.IsInRole("Administrateur") || User.IsInRole("Gestionnaire");
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
    <h2 class="section-title mb-0"><i class="bi bi-clock-history text-or"></i> Membres <span class="accent">historiques</span></h2>
    @if (canManage)
    {
        <a asp-action="Create" class="btn btn-mango"><i class="bi bi-plus-lg"></i> Ajouter</a>
    }
</div>

<form method="get" class="card-3d p-4 mb-4">
    <div class="row g-3 align-items-end">
        <div class="col-lg-5">
            <label for="recherche" class="form-label">Recherche</label>
            <input id="recherche" name="recherche" value="@Model.Recherche" class="form-control" placeholder="Nom, periode ou description" />
        </div>
        <div class="col-lg-5">
            <span class="form-label d-block mb-2">Filtres</span>
            <div class="d-flex flex-wrap gap-3">
                @foreach (var category in CategorieHistoriqueExtensions.All)
                {
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="categories" value="@((int)category)"
                               id="filter_@category" @(Model.Categories.Contains(category) ? "checked" : "") />
                        <label class="form-check-label" for="filter_@category">@category.GetLabel()</label>
                    </div>
                }
            </div>
        </div>
        <div class="col-lg-2 d-flex flex-wrap gap-2">
            <button type="submit" class="btn btn-mango"><i class="bi bi-search"></i> Filtrer</button>
            <a asp-action="Index" class="btn btn-outline-or">Reinitialiser</a>
        </div>
    </div>
</form>

@if (Model.Membres.Any())
{
    <div class="js-view-switch" id="historique-view" data-default-view="cards">
        <div class="d-flex justify-content-end mb-3">
            <div class="btn-group lv-toggle" role="group" aria-label="Changer de vue">
                <button type="button" class="btn btn-sm" data-view-set="cards" title="Vue en cartes"><i class="bi bi-grid-3x3-gap"></i></button>
                <button type="button" class="btn btn-sm" data-view-set="list" title="Vue en liste"><i class="bi bi-list-ul"></i></button>
            </div>
        </div>
        <div data-view-pane="cards">
            <div class="row g-4">
                @foreach (var membre in Model.Membres)
                {
                    var details = membre.CategorieDetails.Any()
                        ? membre.CategorieDetails
                            .OrderBy(detail => detail.Categorie.GetSortOrder())
                            .ThenBy(detail => detail.Ordre)
                            .ToList()
                        : membre.Categories
                            .GetSelectedCategories()
                            .Select(category => new MembreHistoriqueCategorie
                            {
                                Categorie = category,
                                Groupe = null,
                                PhotoUrl = membre.PhotoUrl,
                                Description = membre.Description,
                                Periode = membre.Periode,
                                Ordre = membre.Ordre
                            })
                            .ToList();
                    <div class="col-lg-4 col-md-6">
                        <div class="card-3d p-4 h-100 d-flex flex-column">
                            <h5 class="text-or mb-2">@membre.Nom</h5>
                            <div class="d-flex flex-wrap gap-1 mb-3">
                                @foreach (var detail in details)
                                {
                                    <span class="badge-3d badge-soumise">@detail.Categorie.GetLabel()</span>
                                }
                            </div>
                            <div class="d-flex flex-column gap-2 mb-3 flex-grow-1" style="font-size:0.85rem;">
                                @foreach (var detail in details)
                                {
                                    <div class="border rounded-3 p-2" style="border-color:rgba(255,255,255,0.08)!important;">
                                        <div class="fw-semibold text-bleu">@detail.Categorie.GetLabel()</div>
                                        @if (!string.IsNullOrWhiteSpace(detail.Groupe))
                                        {
                                            <div><i class="bi bi-house-flag text-or"></i> @detail.Groupe</div>
                                        }
                                        <div><i class="bi bi-calendar-range text-bleu"></i> @(detail.Periode ?? "-")</div>
                                        <div><i class="bi bi-sort-numeric-down text-or"></i> Ordre : @detail.Ordre</div>
                                    </div>
                                }
                            </div>
                            <div class="d-flex flex-wrap gap-2 mt-auto">
                                <a asp-action="Details" asp-route-id="@membre.Id" class="btn btn-sm btn-outline-or" title="Details"><i class="bi bi-eye"></i></a>
                                @if (canManage)
                                {
                                    <a asp-action="Edit" asp-route-id="@membre.Id" class="btn btn-sm btn-bleu" title="Modifier"><i class="bi bi-pencil"></i></a>
                                    <form asp-action="Delete" asp-route-id="@membre.Id" method="post" class="d-inline" onsubmit="return confirm('Supprimer ?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm" style="background:rgba(239,68,68,0.2);color:#f87171;border:1px solid rgba(239,68,68,0.3);border-radius:14px;" title="Supprimer">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
        <div data-view-pane="list">
            <div class="card-3d p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th scope="col">Nom</th>
                                <th scope="col">Categories</th>
                                <th scope="col">Groupes</th>
                                <th scope="col">Periodes</th>
                                <th scope="col" class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var membre in Model.Membres)
                            {
                                var details = membre.CategorieDetails.Any()
                                    ? membre.CategorieDetails
                                        .OrderBy(detail => detail.Categorie.GetSortOrder())
                                        .ThenBy(detail => detail.Ordre)
                                        .ToList()
                                    : membre.Categories
                                        .GetSelectedCategories()
                                        .Select(category => new MembreHistoriqueCategorie
                                        {
                                            Categorie = category,
                                            Groupe = null,
                                            PhotoUrl = membre.PhotoUrl,
                                            Description = membre.Description,
                                            Periode = membre.Periode,
                                            Ordre = membre.Ordre
                                        })
                                        .ToList();
                                var categories = string.Join(", ", details.Select(detail => detail.Categorie.GetLabel()).Distinct());
                                var groupes = string.Join(", ", details.Select(detail => detail.Groupe).Where(groupe => !string.IsNullOrWhiteSpace(groupe)).Distinct());
                                var periodes = string.Join(", ", details.Select(detail => detail.Periode).Where(periode => !string.IsNullOrWhiteSpace(periode)).Distinct());
                                <tr>
                                    <td>@membre.Nom</td>
                                    <td>@categories</td>
                                    <td>@(string.IsNullOrWhiteSpace(groupes) ? "-" : groupes)</td>
                                    <td>@(string.IsNullOrWhiteSpace(periodes) ? "-" : periodes)</td>
                                    <td class="text-end">
                                        <div class="d-inline-flex flex-wrap gap-1 justify-content-end">
                                            <a asp-action="Details" asp-route-id="@membre.Id" class="btn btn-sm btn-outline-or" title="Details"><i class="bi bi-eye"></i></a>
                                            @if (canManage)
                                            {
                                                <a asp-action="Edit" asp-route-id="@membre.Id" class="btn btn-sm btn-bleu" title="Modifier"><i class="bi bi-pencil"></i></a>
                                                <form asp-action="Delete" asp-route-id="@membre.Id" method="post" class="d-inline" onsubmit="return confirm('Supprimer ?')">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-sm" style="background:rgba(239,68,68,0.2);color:#f87171;border:1px solid rgba(239,68,68,0.3);border-radius:14px;" title="Supprimer">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </form>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="card-3d p-5 text-center text-muted-custom">
        <i class="bi bi-search" style="font-size:2.5rem;opacity:0.35;"></i>
        <p class="mt-3 mb-0">Aucun membre historique ne correspond aux filtres selectionnes.</p>
    </div>
}

<partial name="_ListPagination" />
