@model List<MangoTaika.Data.Entities.MembreHistorique>
@using MangoTaika.Data.Entities
@{
    ViewData["Title"] = ViewBag.Titre;
    var icone = ViewBag.Icone as string;
    var recherche = ViewBag.Recherche as string;
    var categorie = ViewBag.Categorie is CategorieHistorique current ? current : CategorieHistorique.Aucune;
}

<div class="container my-5">
    <div class="text-center mb-4">
        <img src="~/images/logo.png" alt="Logo" style="width:90px;height:90px;" />
        <h2 class="section-title mt-3"><i class="bi @icone text-or"></i> <span class="accent">@ViewBag.Titre</span></h2>
        <div class="section-divider mx-auto"></div>
    </div>

    <form method="get" class="card-3d p-4 mb-4">
        <div class="row g-3 align-items-end">
            <div class="col-md-9">
                <label for="recherche" class="form-label">Recherche</label>
                <input id="recherche" name="recherche" value="@recherche" class="form-control" placeholder="Nom, période ou description" />
            </div>
            <div class="col-md-3 d-flex flex-wrap gap-2">
                <button type="submit" class="btn btn-mango"><i class="bi bi-search"></i> Rechercher</button>
                @if (!string.IsNullOrWhiteSpace(recherche))
                {
                    <a asp-action="@(ViewContext.RouteData.Values["action"]?.ToString())" class="btn btn-outline-or">Réinitialiser</a>
                }
            </div>
        </div>
    </form>

    @if (Model.Any())
    {
        <div class="row g-4 justify-content-center">
            @foreach (var membre in Model)
            {
                var details = membre.CategorieDetails.Any()
                    ? membre.CategorieDetails
                        .OrderBy(entry => entry.Ordre)
                        .ThenBy(entry => entry.Categorie)
                        .ToList()
                    : membre.Categories
                        .GetSelectedCategories()
                        .Select(category => new MembreHistoriqueCategorie
                        {
                            Categorie = category,
                            Description = membre.Description,
                            Periode = membre.Periode,
                            Ordre = membre.Ordre
                        })
                        .ToList();
                var detail = details.FirstOrDefault(entry => categorie == CategorieHistorique.Aucune || entry.Categorie == categorie);
                <div class="col-md-4 col-sm-6">
                    <div class="card-3d p-4 text-center h-100">
                        @if (!string.IsNullOrEmpty(membre.PhotoUrl))
                        {
                            <img src="@membre.PhotoUrl" alt="@membre.Nom" style="width:120px;height:120px;object-fit:cover;border-radius:50%;border:3px solid var(--vert-pastel);margin-bottom:1rem;" />
                        }
                        else
                        {
                            <div style="width:120px;height:120px;border-radius:50%;background:var(--vert-logo);display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;">
                                <i class="bi bi-person-fill" style="font-size:3rem;color:#fff;"></i>
                            </div>
                        }
                        <h5 style="color:var(--bleu-logo);">@membre.Nom</h5>
                        @if (!string.IsNullOrEmpty(detail?.Periode))
                        {
                            <span class="badge-3d badge-soumise mb-2">@detail.Periode</span>
                        }
                        @if (categorie == CategorieHistorique.Aucune)
                        {
                            <div class="d-flex flex-wrap justify-content-center gap-1 mt-2">
                                @foreach (var category in details.Select(entry => entry.Categorie))
                                {
                                    <span class="badge-3d badge-soumise">@category.GetLabel()</span>
                                }
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(detail?.Description))
                        {
                            <p class="text-muted-custom small mt-2">@detail.Description</p>
                        }
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center text-muted-custom py-5">
            <i class="bi @icone" style="font-size:3rem;opacity:0.3;"></i>
            <p class="mt-2">Aucun membre enregistré pour le moment.</p>
        </div>
    }

    <div class="text-center mt-4">
        <a asp-controller="Home" asp-action="LivreDor" class="btn btn-outline-or"><i class="bi bi-arrow-left"></i> Retour au Livre d'or</a>
    </div>
</div>
