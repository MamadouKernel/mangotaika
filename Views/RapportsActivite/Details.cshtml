@using MangoTaika.Data.Entities
@model RapportActivite
@{
    ViewData["Title"] = Model.Activite.Titre;
    Layout = "_LayoutAdmin";
    var canManage = User.IsInRole("Administrateur") || User.IsInRole("Gestionnaire");
    string statusClass = Model.Statut switch
    {
        StatutWorkflowDocument.Brouillon => "tracking-status-pill--draft",
        StatutWorkflowDocument.Soumis => "tracking-status-pill--pending",
        StatutWorkflowDocument.AReviser => "tracking-status-pill--revision",
        StatutWorkflowDocument.Valide => "tracking-status-pill--approved",
        _ => "tracking-status-pill--draft"
    };
}

<div class="tracking-module tracking-module--rapports-details">
    <section class="tracking-hero tracking-hero--compact">
        <div class="tracking-hero__content">
            <span class="tracking-hero__eyebrow"><i class="bi bi-clipboard2-data"></i> Retour post-activite</span>
            <h2 class="section-title tracking-hero__title mb-2"><i class="bi bi-journal-richtext text-or"></i> <span class="accent">@Model.Activite.Titre</span></h2>
            <p class="tracking-hero__text mb-0">Rapport post-activite pour lire les resultats, les difficultes rencontrees et les suites recommandees.</p>
            <div class="tracking-hero__chips">
                <span class="tracking-chip"><i class="bi bi-building"></i> @(Model.Activite.Groupe?.Nom ?? "District")</span>
                <span class="tracking-chip tracking-chip--soft"><i class="bi bi-calendar3"></i> Cree le @Model.DateCreation.ToString("dd/MM/yyyy")</span>
            </div>
        </div>
        <div class="tracking-hero__actions">
            <div class="tracking-hero__focus">
                <span>Workflow</span>
                <strong>@Model.Statut</strong>
                <small>rapport de cloture</small>
            </div>
            <div class="tracking-action-stack">
                @if (canManage)
                {
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-bleu"><i class="bi bi-pencil"></i> Modifier</a>
                    @if (Model.Statut is StatutWorkflowDocument.Brouillon or StatutWorkflowDocument.AReviser)
                    {
                        <form asp-action="Soumettre" asp-route-id="@Model.Id" method="post" class="d-inline">@Html.AntiForgeryToken()<button type="submit" class="btn btn-mango"><i class="bi bi-send"></i> Soumettre</button></form>
                    }
                    @if (Model.Statut == StatutWorkflowDocument.Soumis)
                    {
                        <form asp-action="Valider" asp-route-id="@Model.Id" method="post" class="d-inline">@Html.AntiForgeryToken()<button type="submit" class="btn btn-mango"><i class="bi bi-check2-circle"></i> Valider</button></form>
                        <form asp-action="DemanderRevision" asp-route-id="@Model.Id" method="post" class="d-inline">@Html.AntiForgeryToken()<button type="submit" class="btn btn-outline-or"><i class="bi bi-arrow-counterclockwise"></i> Revision</button></form>
                    }
                }
                <a asp-action="Index" class="btn btn-outline-or"><i class="bi bi-arrow-left"></i> Retour</a>
            </div>
        </div>
    </section>

    <section class="tracking-panel tracking-panel--soft"><div class="tracking-panel__header"><div><h3 class="tracking-panel__title">Etat du rapport</h3><p class="tracking-panel__text">Suivi de validation et commentaires eventuels.</p></div><span class="tracking-status-pill @statusClass">@Model.Statut</span></div>@if (!string.IsNullOrWhiteSpace(Model.CommentaireValidation)){<div class="alert alert-warning border-0 mb-0">@Model.CommentaireValidation</div>}</section>
    <section class="tracking-panel"><div class="tracking-panel__header"><div><h3 class="tracking-panel__title">Resume executif</h3><p class="tracking-panel__text">Lecture rapide du bilan.</p></div></div><div class="tracking-rich-text">@Model.ResumeExecutif</div></section>
    <section class="tracking-panel"><div class="tracking-panel__header"><div><h3 class="tracking-panel__title">Resultats obtenus</h3><p class="tracking-panel__text">Ce qui a ete reellement produit.</p></div></div><div class="tracking-rich-text">@Model.ResultatsObtenus</div></section>
    <section class="tracking-panel"><div class="tracking-panel__header"><div><h3 class="tracking-panel__title">Difficultes rencontrees</h3><p class="tracking-panel__text">Points de blocage ou fragilites constatees.</p></div></div><div class="tracking-rich-text">@Model.DifficultesRencontrees</div></section>
    <section class="tracking-panel"><div class="tracking-panel__header"><div><h3 class="tracking-panel__title">Recommandations</h3><p class="tracking-panel__text">Actions a engager pour les prochains cycles.</p></div></div><div class="tracking-rich-text">@Model.Recommandations</div></section>
    <section class="tracking-panel"><div class="tracking-panel__header"><div><h3 class="tracking-panel__title">Observations complementaires</h3><p class="tracking-panel__text">Complements de contexte.</p></div></div><div class="tracking-rich-text">@(string.IsNullOrWhiteSpace(Model.ObservationsComplementaires) ? "Aucune observation." : Model.ObservationsComplementaires)</div></section>
</div>