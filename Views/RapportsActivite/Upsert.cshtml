@using MangoTaika.Data.Entities
@model RapportActivite
@{
    ViewData["Title"] = Model.Id == Guid.Empty ? "Nouveau rapport d'activite" : "Modifier le rapport d'activite";
    Layout = "_LayoutAdmin";
    var activites = ViewBag.Activites as List<Activite> ?? new();
    var piecesExistantes = Model.PiecesJointes?.OrderByDescending(p => p.DateAjout).ToList() ?? new List<RapportActivitePieceJointe>();
}

<div class="tracking-module tracking-module--rapports-form">
    <section class="tracking-hero tracking-hero--compact">
        <div class="tracking-hero__content">
            <span class="tracking-hero__eyebrow"><i class="bi bi-journal-check"></i> Cloture d'une activite</span>
            <h2 class="section-title tracking-hero__title mb-2"><i class="bi bi-journal-richtext text-or"></i> <span class="accent">@ViewData["Title"]</span></h2>
            <p class="tracking-hero__text mb-0">Le chef de groupe peut deposer le bilan, les difficultes, les resultats, les recommandations et les pieces jointes. Le commissaire de district peut demander correction puis valider.</p>
        </div>
        <div class="tracking-hero__actions">
            <div class="tracking-hero__focus">
                <span>Flux</span>
                <strong>Soumission district</strong>
                <small>bilan, commentaires, correction puis resoumission</small>
            </div>
            <div class="tracking-action-stack">
                <a asp-action="Index" class="btn btn-outline-or"><i class="bi bi-arrow-left"></i> Retour</a>
            </div>
        </div>
    </section>

    <div class="tracking-form-layout">
        <section class="tracking-panel tracking-form-shell">
            <form method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                @if (Model.Id != Guid.Empty)
                {
                    <input type="hidden" asp-for="Id" />
                }
                <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
                <div class="tracking-form-grid">
                    <div class="tracking-form-col-12">
                        <label asp-for="ActiviteId" class="form-label">Activite concernee</label>
                        <select asp-for="ActiviteId" class="form-select">
                            <option value="">-- Selectionner une activite cloturee --</option>
                            @foreach (var activite in activites)
                            {
                                <option value="@activite.Id">@activite.Titre (@(activite.Groupe?.Nom ?? "District"))</option>
                            }
                        </select>
                    </div>
                    <div class="tracking-form-col-6"><label asp-for="DateRealisation" class="form-label">Date de realisation</label><input asp-for="DateRealisation" class="form-control" type="date" /></div>
                    <div class="tracking-form-col-6"><label asp-for="NombreParticipants" class="form-label">Nombre de participants</label><input asp-for="NombreParticipants" class="form-control" type="number" min="0" /></div>
                    <div class="tracking-form-col-12"><label asp-for="ResumeExecutif" class="form-label">Resume de l'activite</label><textarea asp-for="ResumeExecutif" class="form-control" rows="4"></textarea></div>
                    <div class="tracking-form-col-12"><label asp-for="ResultatsObtenus" class="form-label">Resultats obtenus</label><textarea asp-for="ResultatsObtenus" class="form-control" rows="5"></textarea></div>
                    <div class="tracking-form-col-12"><label asp-for="DifficultesRencontrees" class="form-label">Difficultes rencontrees</label><textarea asp-for="DifficultesRencontrees" class="form-control" rows="5"></textarea></div>
                    <div class="tracking-form-col-12"><label asp-for="Recommandations" class="form-label">Recommandations</label><textarea asp-for="Recommandations" class="form-control" rows="5"></textarea></div>
                    <div class="tracking-form-col-12"><label asp-for="ObservationsComplementaires" class="form-label">Observations complementaires</label><textarea asp-for="ObservationsComplementaires" class="form-control" rows="4"></textarea></div>
                    <div class="tracking-form-col-12">
                        <label class="form-label">Pieces jointes eventuelles</label>
                        <input type="file" name="piecesJointes" class="form-control" multiple />
                    </div>
                    @if (piecesExistantes.Any())
                    {
                        <div class="tracking-form-col-12">
                            <label class="form-label">Pieces jointes deja enregistrees</label>
                            <div class="tracking-list-stack">
                                @foreach (var piece in piecesExistantes)
                                {
                                    <label class="tracking-inline-check">
                                        <input type="checkbox" name="piecesASupprimer" value="@piece.Id" />
                                        <span>Supprimer @piece.NomFichier</span>
                                    </label>
                                }
                            </div>
                        </div>
                    }
                </div>
                <div class="tracking-actions">
                    <button type="submit" class="btn btn-mango"><i class="bi bi-check-lg"></i> Enregistrer</button>
                    <a asp-action="Index" class="btn btn-outline-or">Annuler</a>
                </div>
            </form>
        </section>

        <aside class="tracking-side-stack">
            <div class="tracking-side-card"><span class="tracking-side-card__label"><i class="bi bi-lightbulb"></i> Attendu</span><h4>Un bilan exploitable</h4><p class="text-muted-custom mb-0">Le rapport doit faire ressortir les resultats, les difficultes, les recommandations et les preuves documentaires utiles au district.</p></div>
            <div class="tracking-side-card"><span class="tracking-side-card__label"><i class="bi bi-paperclip"></i> Pieces</span><h5>Conseil</h5><p class="text-muted-custom mb-0">Ajoutez les supports utiles: rapport PDF, photos, liste de presence ou tout autre justificatif lie a l'activite.</p></div>
        </aside>
    </div>
</div>

<style>
    .tracking-list-stack {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .tracking-inline-check {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 10px 14px;
        border-radius: 14px;
        background: rgba(255,255,255,0.68);
        border: 1px solid rgba(95,127,67,0.14);
    }
</style>
