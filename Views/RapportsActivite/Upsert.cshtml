@using MangoTaika.Data.Entities
@model RapportActivite
@{
    ViewData["Title"] = Model.Id == Guid.Empty ? "Nouveau rapport d'activite" : "Modifier le rapport d'activite";
    Layout = "_LayoutAdmin";
    var activites = ViewBag.Activites as List<Activite> ?? new();
}

<div class="tracking-module tracking-module--rapports-form">
    <section class="tracking-hero tracking-hero--compact">
        <div class="tracking-hero__content">
            <span class="tracking-hero__eyebrow"><i class="bi bi-journal-check"></i> Cloture d'une activite</span>
            <h2 class="section-title tracking-hero__title mb-2"><i class="bi bi-journal-richtext text-or"></i> <span class="accent">@ViewData["Title"]</span></h2>
            <p class="tracking-hero__text mb-0">Formalisez les resultats, les difficultes et les recommandations dans un canevas unique, plus lisible pour la validation.</p>
        </div>
        <div class="tracking-hero__actions">
            <div class="tracking-hero__focus">
                <span>Nature du document</span>
                <strong>Retour terrain</strong>
                <small>choisissez une activite cloturee ou prete a etre analysee.</small>
            </div>
            <div class="tracking-action-stack">
                <a asp-action="Index" class="btn btn-outline-or"><i class="bi bi-arrow-left"></i> Retour</a>
            </div>
        </div>
    </section>

    <div class="tracking-form-layout">
        <section class="tracking-panel tracking-form-shell">
            <form method="post">
                @Html.AntiForgeryToken()
                @if (Model.Id != Guid.Empty)
                {
                    <input type="hidden" asp-for="Id" />
                }
                <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
                <div class="tracking-form-grid">
                    <div class="tracking-form-col-12">
                        <label asp-for="ActiviteId" class="form-label">Activite</label>
                        <select asp-for="ActiviteId" class="form-select">
                            <option value="">-- Selectionner une activite cloturee --</option>
                            @foreach (var activite in activites)
                            {
                                <option value="@activite.Id">@activite.Titre (@(activite.Groupe?.Nom ?? "District"))</option>
                            }
                        </select>
                    </div>
                    <div class="tracking-form-col-12"><label asp-for="ResumeExecutif" class="form-label">Resume executif</label><textarea asp-for="ResumeExecutif" class="form-control" rows="4"></textarea></div>
                    <div class="tracking-form-col-12"><label asp-for="ResultatsObtenus" class="form-label">Resultats obtenus</label><textarea asp-for="ResultatsObtenus" class="form-control" rows="5"></textarea></div>
                    <div class="tracking-form-col-12"><label asp-for="DifficultesRencontrees" class="form-label">Difficultes rencontrees</label><textarea asp-for="DifficultesRencontrees" class="form-control" rows="5"></textarea></div>
                    <div class="tracking-form-col-12"><label asp-for="Recommandations" class="form-label">Recommandations</label><textarea asp-for="Recommandations" class="form-control" rows="5"></textarea></div>
                    <div class="tracking-form-col-12"><label asp-for="ObservationsComplementaires" class="form-label">Observations complementaires</label><textarea asp-for="ObservationsComplementaires" class="form-control" rows="4"></textarea></div>
                </div>
                <div class="tracking-actions">
                    <button type="submit" class="btn btn-mango"><i class="bi bi-check-lg"></i> Enregistrer</button>
                    <a asp-action="Index" class="btn btn-outline-or">Annuler</a>
                </div>
            </form>
        </section>

        <aside class="tracking-side-stack">
            <div class="tracking-side-card"><span class="tracking-side-card__label"><i class="bi bi-lightbulb"></i> Angle attendu</span><h4>Un bilan exploitable</h4><p class="text-muted-custom mb-0">Mettez en evidence les resultats observes, les points de friction et les recommandations directement activables.</p></div>
            <div class="tracking-side-card"><span class="tracking-side-card__label"><i class="bi bi-chat-left-text"></i> Bon reflexe</span><h5>Rester concret</h5><p class="text-muted-custom mb-0">Une phrase par idee forte vaut mieux qu'un bloc trop dense: cela facilite la lecture lors de la validation.</p></div>
        </aside>
    </div>
</div>