@model List<MangoTaika.DTOs.CertificationFormationDto>
@{
    ViewData["Title"] = "Mes certificats";
    Layout = "_LayoutAdmin";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="section-title mb-1"><i class="bi bi-patch-check-fill text-or"></i> Mes certificats</h2>
        <p class="text-muted-custom mb-0">Badges, attestations et certificats obtenus sur la plateforme.</p>
    </div>
</div>

@if (!Model.Any())
{
    <div class="card-3d p-4">
        <p class="mb-0 text-muted-custom">Aucune delivrance disponible pour le moment. Termine une formation pour obtenir un badge, une attestation ou un certificat.</p>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var certificat in Model)
        {
            var badgeClass = certificat.Type switch
            {
                MangoTaika.Data.Entities.TypeCertificationFormation.Badge => "bg-success",
                MangoTaika.Data.Entities.TypeCertificationFormation.Attestation => "bg-primary",
                _ => "bg-warning text-dark"
            };

            <div class="col-lg-4 col-md-6">
                <div class="card-3d p-4 h-100 d-flex flex-column">
                    <div class="d-flex justify-content-between align-items-start gap-2 mb-3">
                        <span class="badge @badgeClass">@certificat.Type</span>
                        <small class="text-muted-custom">@certificat.DateEmission.ToString("dd/MM/yyyy")</small>
                    </div>
                    <h5 class="text-or mb-2">@certificat.FormationTitre</h5>
                    <div class="small text-muted-custom mb-1">Code: @certificat.Code</div>
                    <div class="small text-muted-custom mb-3">Score final: @certificat.ScoreFinal% • Mention: @certificat.Mention</div>
                    <div class="d-flex gap-2 mt-auto">
                        <a asp-action="Details" asp-route-id="@certificat.Id" class="btn btn-sm btn-outline-or">
                            <i class="bi bi-eye"></i> Voir
                        </a>
                        <a asp-action="Imprimer" asp-route-id="@certificat.Id" class="btn btn-sm btn-bleu" target="_blank">
                            <i class="bi bi-printer"></i> Imprimer
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}
