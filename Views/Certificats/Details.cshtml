@model MangoTaika.DTOs.CertificationFormationDto
@{
    ViewData["Title"] = "Certificat";
    Layout = "_LayoutAdmin";
    var typeClass = Model.Type switch
    {
        MangoTaika.Data.Entities.TypeCertificationFormation.Badge => "bg-success",
        MangoTaika.Data.Entities.TypeCertificationFormation.Attestation => "bg-primary",
        _ => "bg-warning text-dark"
    };
}

<div class="card-3d p-4">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
        <div>
            <span class="badge @typeClass mb-2">@Model.Type</span>
            <h2 class="section-title mb-1">@Model.FormationTitre</h2>
            <p class="text-muted-custom mb-0">Attribue a @Model.NomScout</p>
        </div>
        <a asp-action="Imprimer" asp-route-id="@Model.Id" class="btn btn-bleu" target="_blank">
            <i class="bi bi-printer"></i> Imprimer
        </a>
    </div>

    <div class="row g-3">
        <div class="col-md-4">
            <div class="border rounded p-3 h-100">
                <div class="text-muted-custom small mb-1">Code</div>
                <div class="fw-semibold">@Model.Code</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="border rounded p-3 h-100">
                <div class="text-muted-custom small mb-1">Date d'emission</div>
                <div class="fw-semibold">@Model.DateEmission.ToString("dd/MM/yyyy HH:mm")</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="border rounded p-3 h-100">
                <div class="text-muted-custom small mb-1">Resultat</div>
                <div class="fw-semibold">@Model.ScoreFinal% • @Model.Mention</div>
            </div>
        </div>
    </div>

    <div class="mt-4">
        <a asp-action="MesCertificats" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Retour
        </a>
    </div>
</div>
