@model BoutiqueCartViewModel
@{
    ViewData["Title"] = "Valider la commande";
    var isAuthenticatedCheckout = ViewBag.IsAuthenticatedCheckout as bool? ?? false;
    var checkoutNom = ViewBag.CheckoutNomClient as string ?? string.Empty;
    var checkoutTelephone = ViewBag.CheckoutTelephoneClient as string ?? string.Empty;
    var checkoutEmail = ViewBag.CheckoutEmailClient as string ?? string.Empty;
    var portefeuilleSolde = ViewBag.PortefeuilleSolde as decimal? ?? 0;
    var portefeuilleDevise = ViewBag.PortefeuilleDevise as string ?? Model.Devise;
    var portefeuilleActif = ViewBag.PortefeuilleActif as bool? ?? false;
    var canPayWithWallet = isAuthenticatedCheckout
        && portefeuilleActif
        && string.Equals(portefeuilleDevise, Model.Devise, StringComparison.OrdinalIgnoreCase)
        && portefeuilleSolde >= Model.Total;
}

<section class="container py-5 marketplace-detail">
    <a asp-action="Panier" class="marketplace-back-link"><i class="bi bi-arrow-left"></i> Retour au panier</a>

    <div class="marketplace-detail-grid">
        <div class="marketplace-detail-panel">
            <span class="boutique-eyebrow"><i class="bi bi-bag-check"></i> Checkout boutique</span>
            <h1>Valider ma commande</h1>
            <p class="marketplace-detail-description">Une seule commande sera creee avec tous les articles de votre panier.</p>
            @if (isAuthenticatedCheckout)
            {
                <div class="alert alert-success">
                    <i class="bi bi-person-check"></i>
                    Vos informations de compte sont reprises automatiquement. Solde portefeuille :
                    <strong>@portefeuilleSolde.ToString("N0") @portefeuilleDevise</strong>.
                </div>
            }

            <form asp-action="Checkout" method="post" class="marketplace-order-form">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Nom complet</label>
                        <input name="nomClient" class="form-control" required autocomplete="name" value="@checkoutNom" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Telephone</label>
                        <input name="telephoneClient" class="form-control" required autocomplete="tel" value="@checkoutTelephone" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Email</label>
                        <input name="emailClient" type="email" class="form-control" autocomplete="email" value="@checkoutEmail" />
                    </div>
                    <div class="col-md-6" id="mobileMoneyReferenceField">
                        <label class="form-label">Reference paiement</label>
                        <input name="referencePaiement" class="form-control" placeholder="Reference Mobile Money si deja paye" />
                        <div class="form-text">Ce champ concerne uniquement un paiement Mobile Money.</div>
                    </div>
                    <div class="col-12">
                        <label class="form-label">Mode de paiement</label>
                        <div class="marketplace-payment-options">
                            <label>
                                <input type="radio" name="modePaiement" value="MobileMoney" checked />
                                <span>
                                    <strong>Mobile Money</strong>
                                    <small>Reference operateur a verifier par l'equipe finance.</small>
                                </span>
                            </label>
                            @if (isAuthenticatedCheckout)
                            {
                                <label class="@(!canPayWithWallet ? "opacity-50" : string.Empty)">
                                    <input type="radio" name="modePaiement" value="Portefeuille" disabled="@(!canPayWithWallet)" />
                                    <span>
                                        <strong>Mon portefeuille</strong>
                                        <small>
                                            Debit interne immediat. Solde : @portefeuilleSolde.ToString("N0") @portefeuilleDevise.
                                            @if (portefeuilleSolde < Model.Total)
                                            {
                                                <text> Solde insuffisant.</text>
                                            }
                                        </small>
                                    </span>
                                </label>
                            }
                            <label>
                                <input type="radio" name="modePaiement" value="PaiementLivraison" />
                                <span>
                                    <strong>Paiement a la livraison</strong>
                                    <small>Paiement au retrait ou a la livraison.</small>
                                </span>
                            </label>
                        </div>
                        @if (isAuthenticatedCheckout)
                        {
                            <div id="walletPaymentNotice" class="alert mt-3 mb-0" style="display:none;background:rgba(89,117,55,.08);border:1px solid rgba(89,117,55,.22);border-radius:12px;">
                                <strong>Paiement portefeuille</strong>
                                <div class="small text-muted-custom">
                                    Le montant sera debite directement de votre portefeuille Mango Taika. Aucune reference Mobile Money n'est demandee.
                                    Solde apres paiement : @((portefeuilleSolde - Model.Total).ToString("N0")) @portefeuilleDevise.
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <div class="marketplace-order-actions">
                    <a asp-action="Panier" class="btn btn-outline-or">Modifier le panier</a>
                    <button type="submit" class="btn btn-or btn-lg"><i class="bi bi-send"></i> Envoyer la commande</button>
                </div>
            </form>
        </div>

        <aside class="marketplace-cart-summary">
            <div class="card-3d p-4">
                <h2>Votre panier</h2>
                <div class="marketplace-checkout-lines">
                    @foreach (var line in Model.Lignes)
                    {
                        <div>
                            <span>@line.Article.Nom x @line.Quantite</span>
                            <strong>@line.Total.ToString("N0") @line.Article.Devise</strong>
                        </div>
                    }
                </div>
                <dl>
                    <dt>Total</dt>
                    <dd>@Model.Total.ToString("N0") @Model.Devise</dd>
                </dl>
            </div>
        </aside>
    </div>
</section>

@section Scripts {
    <script>
        (() => {
            const referenceField = document.getElementById('mobileMoneyReferenceField');
            const walletNotice = document.getElementById('walletPaymentNotice');
            const paymentRadios = document.querySelectorAll('input[name="modePaiement"]');
            const refreshPaymentUi = () => {
                const selected = document.querySelector('input[name="modePaiement"]:checked')?.value || 'MobileMoney';
                if (referenceField) {
                    referenceField.style.display = selected === 'MobileMoney' ? '' : 'none';
                    const input = referenceField.querySelector('input');
                    if (input && selected !== 'MobileMoney') input.value = '';
                }
                if (walletNotice) {
                    walletNotice.style.display = selected === 'Portefeuille' ? '' : 'none';
                }
            };
            paymentRadios.forEach(radio => radio.addEventListener('change', refreshPaymentUi));
            refreshPaymentUi();
        })();
    </script>
}
