@model List<MangoTaika.Data.Entities.ArticleBoutique>
@{
    ViewData["Title"] = "Articles boutique";
    Layout = "_LayoutAdmin";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
    <h2 class="section-title mb-0"><i class="bi bi-bag-fill text-or"></i> Articles boutique</h2>
    <div class="d-flex gap-2">
        <a asp-action="Commandes" class="btn btn-outline-or btn-sm"><i class="bi bi-receipt"></i> Commandes</a>
        <a asp-action="Import" class="btn btn-outline-or btn-sm"><i class="bi bi-upload"></i> Importer</a>
        <a asp-action="Create" class="btn btn-or btn-sm"><i class="bi bi-plus-lg"></i> Ajouter</a>
    </div>
</div>

<div class="card-3d p-4">
    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0 js-list-cards">
                <thead>
                    <tr>
                        <th>Article</th>
                        <th>Categorie</th>
                        <th>Stock</th>
                        <th>Statut</th>
                        <th class="text-end">Prix</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var article in Model)
                    {
                        <tr>
                            <td>
                                <strong>@article.Nom</strong>
                                <div class="small text-muted-custom">@article.Description</div>
                            </td>
                            <td>@(article.Categorie ?? "-")</td>
                            <td>@article.StockDisponible</td>
                            <td><span class="badge-3d @(article.EstPublie ? "badge-approuvee" : "badge-soumise")">@(article.EstPublie ? "Publie" : "Brouillon")</span></td>
                            <td class="text-end">@article.Prix.ToString("N0") @article.Devise</td>
                            <td class="text-end">
                                <a asp-action="Edit" asp-route-id="@article.Id" class="btn btn-bleu btn-sm"><i class="bi bi-pencil"></i></a>
                                <form asp-action="Delete" asp-route-id="@article.Id" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-outline-danger btn-sm"><i class="bi bi-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p class="text-muted-custom mb-0">Aucun article enregistre.</p>
    }
</div>
