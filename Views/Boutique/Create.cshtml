@model MangoTaika.Data.Entities.ArticleBoutique
@{
    ViewData["Title"] = "Ajouter un article";
    Layout = "_LayoutAdmin";
}

<h2 class="section-title mb-3"><i class="bi bi-bag text-or"></i> Ajouter un article</h2>

<form asp-action="Create" method="post" enctype="multipart/form-data" class="card-3d p-4">
    <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
    <div class="row g-3">
        <div class="col-md-6">
            <label asp-for="Nom" class="form-label">Nom</label>
            <input asp-for="Nom" class="form-control" />
            <span asp-validation-for="Nom" class="text-danger small"></span>
        </div>
        <div class="col-md-3">
            <label asp-for="Categorie" class="form-label">Categorie</label>
            <input asp-for="Categorie" class="form-control" placeholder="Uniforme, badge, livre..." />
        </div>
        <div class="col-md-3">
            <label asp-for="Prix" class="form-label">Prix</label>
            <input asp-for="Prix" type="number" min="0" step="1" class="form-control" />
        </div>
        <div class="col-md-3">
            <label asp-for="StockDisponible" class="form-label">Stock</label>
            <input asp-for="StockDisponible" type="number" min="0" class="form-control" />
        </div>
        <div class="col-md-6">
            <label class="form-label">Image</label>
            <input name="Image" type="file" class="form-control" accept=".jpg,.jpeg,.png,.gif,.webp" />
        </div>
        <div class="col-md-6">
            <label asp-for="ImageUrl" class="form-label">URL image existante ou externe</label>
            <input asp-for="ImageUrl" class="form-control" />
        </div>
        <div class="col-md-3">
            <label asp-for="Devise" class="form-label">Devise</label>
            <input asp-for="Devise" class="form-control" value="XOF" />
        </div>
        <div class="col-md-3 d-flex align-items-end">
            <div class="form-check">
                <input asp-for="EstPublie" class="form-check-input" />
                <label asp-for="EstPublie" class="form-check-label">Publier</label>
            </div>
        </div>
        <div class="col-12">
            <label asp-for="Description" class="form-label">Description</label>
            <textarea asp-for="Description" rows="4" class="form-control"></textarea>
        </div>
    </div>
    <div class="d-flex justify-content-end gap-2 mt-4">
        <a asp-action="Index" class="btn btn-outline-or">Annuler</a>
        <button type="submit" class="btn btn-or">Enregistrer</button>
    </div>
</form>
