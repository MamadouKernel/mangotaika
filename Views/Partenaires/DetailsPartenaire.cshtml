@model Partenaire
@{
    ViewData["Title"] = Model.Nom;
    Layout = "_LayoutAdmin";
    var canManage = User.IsInRole("Administrateur") || User.IsInRole("Gestionnaire");
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
    <h2 class="section-title mb-0"><i class="bi bi-handshake text-or"></i> @Model.Nom</h2>
    <div class="d-flex flex-wrap gap-2">
        @if (canManage)
        {
            <a asp-action="EditPartenaire" asp-route-id="@Model.Id" class="btn btn-bleu btn-sm" title="Modifier"><i class="bi bi-pencil"></i></a>
        }
        <a asp-action="Index" class="btn btn-outline-or btn-sm" title="Liste"><i class="bi bi-arrow-left"></i></a>
    </div>
</div>

<div class="card-3d p-4">
    <dl class="row mb-0 small">
        <dt class="col-sm-4 text-muted-custom">Type</dt>
        <dd class="col-sm-8">@(Model.TypePartenariat ?? "-")</dd>
        <dt class="col-sm-4 text-muted-custom">Site web</dt>
        <dd class="col-sm-8">@(string.IsNullOrEmpty(Model.SiteWeb) ? "-" : Model.SiteWeb)</dd>
        <dt class="col-sm-4 text-muted-custom">Ordre</dt>
        <dd class="col-sm-8">@Model.Ordre</dd>
        <dt class="col-sm-4 text-muted-custom">Actif</dt>
        <dd class="col-sm-8">@(Model.EstActif ? "Oui" : "Non")</dd>
    </dl>
    @if (!string.IsNullOrWhiteSpace(Model.Description))
    {
        <h6 class="text-or mt-4 mb-2">Description</h6>
        <p class="text-muted-custom small mb-0" style="white-space:pre-wrap;">@Model.Description</p>
    }
</div>
