@model MangoTaika.DTOs.CotisationsNationalesIndexViewModel
@using MangoTaika.Data.Entities
@{
    ViewData["Title"] = "Cotisations nationales";
    Layout = "_LayoutAdmin";
    var canManage = User.IsInRole("Administrateur") || User.IsInRole("Gestionnaire");

    string BadgeClass(StatutLigneCotisationNationale statut) => statut switch
    {
        StatutLigneCotisationNationale.Ajour => "badge-approuvee",
        StatutLigneCotisationNationale.NonAjour => "badge-rejetee",
        _ => "badge-soumise"
    };

    string StatutLabel(StatutLigneCotisationNationale statut) => statut switch
    {
        StatutLigneCotisationNationale.Ajour => "A jour",
        StatutLigneCotisationNationale.NonAjour => "Non a jour",
        _ => "A verifier"
    };
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <div>
        <h2 class="section-title mb-1"><i class="bi bi-cash-coin text-or"></i> Cotisations <span class="accent">nationales</span></h2>
        <div class="text-muted-custom">Rapprochement annuel des scouts a jour, non a jour et a verifier.</div>
    </div>
    <div class="d-flex gap-2 align-items-center">
        <a asp-action="Index" asp-route-annee="@(Model.AnneeReference - 1)" class="btn btn-sm btn-outline-or"><i class="bi bi-chevron-left"></i></a>
        <span style="font-weight:700;color:var(--bleu-logo);">@Model.AnneeReference</span>
        <a asp-action="Index" asp-route-annee="@(Model.AnneeReference + 1)" class="btn btn-sm btn-outline-or"><i class="bi bi-chevron-right"></i></a>
        @if (canManage)
        {
            <a asp-action="Template" class="btn btn-outline-or"><i class="bi bi-file-earmark-excel"></i> Modele Excel</a>
        }
    </div>
</div>

@if (canManage)
{
    <div class="card-3d p-4 mb-4">
        <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
            <div>
                <h5 class="text-or mb-1"><i class="bi bi-upload"></i> Import national</h5>
                <p class="text-muted-custom mb-0">Importez le fichier national pour produire le rapprochement annuel et synchroniser les fiches scouts.</p>
            </div>
            <span class="badge-3d badge-soumise">Annee @Model.AnneeReference</span>
        </div>
        <form asp-action="Importer" method="post" enctype="multipart/form-data" class="row g-3 align-items-end mt-2">
            @Html.AntiForgeryToken()
            <input type="hidden" name="anneeReference" value="@Model.AnneeReference" />
            <div class="col-lg-8">
                <label class="form-label">Fichier Excel (.xlsx)</label>
                <input type="file" name="fichier" class="form-control" accept=".xlsx" required />
                <small class="text-muted-custom">Le matricule est optionnel. Sans matricule, le fichier doit fournir Nom, Prenom et DateNaissance pour permettre un premier rattachement fiable.</small>
            </div>
            <div class="col-lg-4 d-grid">
                <button type="submit" class="btn btn-mango"><i class="bi bi-upload"></i> Importer le fichier national</button>
            </div>
        </form>
    </div>
}

<div class="row g-3 mb-4">
    <div class="col-md-4"><div class="card-3d p-3 text-center"><small class="text-muted-custom">A jour</small><h3 style="color:#10b981;">@Model.NombreAjour</h3></div></div>
    <div class="col-md-4"><div class="card-3d p-3 text-center"><small class="text-muted-custom">Non a jour</small><h3 style="color:#f87171;">@Model.NombreNonAjour</h3></div></div>
    <div class="col-md-4"><div class="card-3d p-3 text-center"><small class="text-muted-custom">A verifier</small><h3 style="color:#f59e0b;">@Model.NombreAVerifier</h3></div></div>
</div>

<div class="card-3d p-4 mb-4">
    <form method="get" class="row g-3 align-items-end">
        <div class="col-lg-3">
            <label class="form-label">Import</label>
            <select name="importId" class="form-select">
                <option value="">-- Dernier import de l'annee --</option>
                @foreach (var item in Model.Imports)
                {
                    <option value="@item.Value" selected="@item.Selected">@item.Text</option>
                }
            </select>
        </div>
        <div class="col-lg-3">
            <label class="form-label">Groupe</label>
            <select name="groupeId" class="form-select">
                <option value="">Tous</option>
                @foreach (var item in Model.Groupes)
                {
                    <option value="@item.Value" selected="@item.Selected">@item.Text</option>
                }
            </select>
        </div>
        <div class="col-lg-2">
            <label class="form-label">Branche</label>
            <select name="brancheId" class="form-select">
                <option value="">Toutes</option>
                @foreach (var item in Model.Branches)
                {
                    <option value="@item.Value" selected="@item.Selected">@item.Text</option>
                }
            </select>
        </div>
        <div class="col-lg-2">
            <label class="form-label">Statut</label>
            <select name="statut" class="form-select">
                <option value="">Tous</option>
                @foreach (var statut in Enum.GetValues<StatutLigneCotisationNationale>())
                {
                    var selected = Model.Statut == statut;
                    <option value="@statut" selected="@selected">@StatutLabel(statut)</option>
                }
            </select>
        </div>
        <div class="col-lg-2 d-grid">
            <input type="hidden" name="annee" value="@Model.AnneeReference" />
            <button type="submit" class="btn btn-outline-or"><i class="bi bi-funnel"></i> Filtrer</button>
        </div>
    </form>
</div>

@if (Model.ImportSelectionne is not null)
{
    <div class="card-3d p-3 mb-4">
        <div class="d-flex justify-content-between align-items-center gap-3 flex-wrap">
            <div>
                <div class="small text-muted-custom text-uppercase">Import selectionne</div>
                <div style="font-weight:700;color:var(--bleu-logo);">@Model.ImportSelectionne.NomFichier</div>
                <div class="small text-muted-custom">Importe le @Model.ImportSelectionne.DateImport.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
            </div>
            <div class="d-flex gap-2 align-items-center flex-wrap">
                <span class="badge-3d badge-soumise">@Model.NombreVisible ligne(s)</span>
                <span style="font-weight:700;color:var(--bleu-logo);">@Model.ImportSelectionne.MontantTotal.ToString("N0") FCFA</span>
                <a asp-action="Details" asp-route-id="@Model.ImportSelectionne.Id" class="btn btn-sm btn-outline-or"><i class="bi bi-eye"></i> Details</a>
            </div>
        </div>
    </div>
}

<div class="card-3d p-4">
    @if (Model.Lignes.Any())
    {
        <div class="table-responsive">
            <table class="table-modern exportable-list" data-export-name="cotisations-nationales-@Model.AnneeReference">
                <thead>
                    <tr>
                        <th>Statut</th>
                        <th>Scout</th>
                        <th>Matricule</th>
                        <th>Groupe</th>
                        <th>Branche</th>
                        <th>Montant</th>
                        <th>Motif</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var ligne in Model.Lignes)
                {
                    <tr>
                        <td><span class="badge-3d @BadgeClass(ligne.Statut)">@StatutLabel(ligne.Statut)</span></td>
                        <td>@(ligne.Scout is null ? (ligne.NomImporte ?? "-") : $"{ligne.Scout.Prenom} {ligne.Scout.Nom}")</td>
                        <td>@(string.IsNullOrWhiteSpace(ligne.Matricule) ? "-" : ligne.Matricule)</td>
                        <td>@(ligne.Scout?.Groupe?.Nom ?? "-")</td>
                        <td>@(ligne.Scout?.Branche?.Nom ?? "-")</td>
                        <td>@(ligne.Montant.HasValue ? $"{ligne.Montant.Value:N0} FCFA" : "-")</td>
                        <td>@(string.IsNullOrWhiteSpace(ligne.Motif) ? "-" : ligne.Motif)</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-center py-5 text-muted-custom">
            <i class="bi bi-receipt-cutoff" style="font-size:2rem;"></i>
            <div class="mt-3">Aucune ligne de cotisation nationale disponible pour cette selection.</div>
        </div>
    }
</div>

<partial name="_ListPagination" />
