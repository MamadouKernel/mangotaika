@using MangoTaika.Data.Entities
@model InscriptionAnnuelleScout
@{
    ViewData["Title"] = Model.Id == Guid.Empty ? "Nouvelle inscription annuelle" : "Modifier l'inscription annuelle";
    Layout = "_LayoutAdmin";
    var scouts = ViewBag.Scouts as List<Scout> ?? new();
    var groupes = ViewBag.Groupes as List<Groupe> ?? new();
    var branches = ViewBag.Branches as List<Branche> ?? new();
    var isCreate = Model.Id == Guid.Empty;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <div class="d-flex align-items-center gap-2 flex-wrap">
            <h2 class="section-title mb-1"><i class="bi bi-journal-check text-or"></i> <span class="accent">@ViewData["Title"]</span></h2>
            @await Html.PartialAsync("_ScoutWorkflowHelp", "annual-create")
        </div>
        <p class="text-muted-custom mb-0">Renseignez l'annee pastorale et le snapshot annuel du groupe, de la branche et de la fonction.</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-or"><i class="bi bi-arrow-left"></i></a>
</div>

<div class="card-3d p-4">
    <form method="post">
        @Html.AntiForgeryToken()
        @if (Model.Id != Guid.Empty)
        {
            <input type="hidden" asp-for="Id" />
        }
        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
        <div class="row g-3">
            <div class="col-lg-6" data-searchable-select-wrapper>
                <label asp-for="ScoutId" class="form-label">Scout</label>
                <input type="search" class="form-control form-control-sm mb-2" placeholder="Rechercher un scout par nom, prenom, matricule..." data-select-search-input />
                <select asp-for="ScoutId" class="form-select" data-searchable-select>
                    <option value="">-- Selectionner un scout --</option>
                    @foreach (var scout in scouts)
                    {
                        <option value="@scout.Id"
                                data-group="@(scout.GroupeId?.ToString() ?? string.Empty)"
                                data-branch="@(scout.BrancheId?.ToString() ?? string.Empty)"
                                data-fonction="@(scout.Fonction ?? string.Empty)"
                                data-cotisation="@scout.AssuranceAnnuelle.ToString().ToLowerInvariant()"
                                data-search-label="@($"{scout.Prenom} {scout.Nom} {scout.Matricule} {scout.Groupe?.Nom} {scout.Branche?.Nom} {scout.Fonction}")">
                            @scout.Prenom @scout.Nom (@(string.IsNullOrWhiteSpace(scout.Matricule) ? "sans matricule" : scout.Matricule))@(scout.Groupe != null ? $" - {scout.Groupe.Nom}" : string.Empty)
                        </option>
                    }
                </select>
                <small class="text-muted-custom" data-select-search-empty hidden>Aucun scout correspondant.</small>
                <small class="text-muted-custom d-block mt-2">Le groupe, la branche et la fonction de l'annee se remplissent automatiquement a partir du scout choisi. Vous pouvez ensuite ajuster le snapshot si besoin.</small>
                <span asp-validation-for="ScoutId" class="text-danger small"></span>
            </div>
            <div class="col-lg-3">
                <label asp-for="AnneeReference" class="form-label">Annee</label>
                <input asp-for="AnneeReference" class="form-control" />
                <span asp-validation-for="AnneeReference" class="text-danger small"></span>
            </div>
            <div class="col-lg-3">
                <label asp-for="LibelleAnnee" class="form-label">Libelle</label>
                <input asp-for="LibelleAnnee" class="form-control" />
            </div>
            <div class="col-lg-4">
                <label asp-for="DateInscription" class="form-label">Date d'inscription</label>
                <input asp-for="DateInscription" type="date" class="form-control" value="@Model.DateInscription.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-lg-4">
                <label asp-for="Statut" class="form-label">Statut</label>
                <select asp-for="Statut" class="form-select" asp-items="Html.GetEnumSelectList<StatutInscriptionAnnuelle>()"></select>
            </div>
            <div class="col-lg-4 d-flex align-items-end">
                <div class="form-check form-switch">
                    <input asp-for="InscriptionParoissialeValidee" class="form-check-input" />
                    <label asp-for="InscriptionParoissialeValidee" class="form-check-label">Inscription paroissiale validee</label>
                </div>
            </div>
            <div class="col-lg-4">
                <label asp-for="GroupeId" class="form-label">Groupe de l'annee</label>
                <select asp-for="GroupeId" class="form-select">
                    <option value="">-- Selectionner un groupe --</option>
                    @foreach (var groupe in groupes)
                    {
                        <option value="@groupe.Id">@groupe.Nom</option>
                    }
                </select>
                <span asp-validation-for="GroupeId" class="text-danger small"></span>
            </div>
            <div class="col-lg-4">
                <label asp-for="BrancheId" class="form-label">Branche de l'annee</label>
                <select asp-for="BrancheId" class="form-select">
                    <option value="">-- Selectionner une branche --</option>
                    @foreach (var branche in branches)
                    {
                        <option value="@branche.Id" data-groupe-id="@branche.GroupeId">@branche.Nom</option>
                    }
                </select>
                <span asp-validation-for="BrancheId" class="text-danger small"></span>
            </div>
            <div class="col-lg-4">
                <label asp-for="FonctionSnapshot" class="form-label">Fonction de l'annee</label>
                <input asp-for="FonctionSnapshot" class="form-control" placeholder="Chef, tresorier, secretaire..." />
                <span asp-validation-for="FonctionSnapshot" class="text-danger small"></span>
            </div>
            <div class="col-lg-6">
                <label class="form-label">Cotisation nationale</label>
                <div id="InscriptionCotisationLabel" class="form-control d-flex align-items-center bg-light-subtle">@(Model.CotisationNationaleAjour ? "A jour" : "Non a jour")</div>
                <small class="text-muted-custom">Ce statut est synchronise par l'import du fichier national et ne se modifie pas manuellement ici.</small>
            </div>
            <div class="col-12">
                <label asp-for="Observations" class="form-label">Observations</label>
                <textarea asp-for="Observations" class="form-control" rows="5"></textarea>
            </div>
        </div>
        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-mango"><i class="bi bi-check-lg"></i> Enregistrer</button>
            <a asp-action="Index" class="btn btn-outline-or">Annuler</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const groupeSelect = document.getElementById('GroupeId');
            const brancheSelect = document.getElementById('BrancheId');
            const scoutSelect = document.getElementById('ScoutId');
            const fonctionInput = document.getElementById('FonctionSnapshot');
            const cotisationLabel = document.getElementById('InscriptionCotisationLabel');
            const anneeInput = document.getElementById('AnneeReference');
            const libelleInput = document.getElementById('LibelleAnnee');
            const isCreate = @isCreate.ToString().ToLowerInvariant();
            const currentYear = new Date().getUTCFullYear();
            let lastAutoLabel = libelleInput ? libelleInput.value : '';

            if (!groupeSelect || !brancheSelect) {
                return;
            }

            const firstOption = brancheSelect.querySelector('option[value=""]');
            const syncBranches = () => {
                const selectedGroup = groupeSelect.value;
                if (firstOption) {
                    firstOption.textContent = selectedGroup
                        ? '-- Selectionner une branche du groupe --'
                        : '-- Selectionner une branche --';
                }

                Array.from(brancheSelect.options).forEach((option) => {
                    if (!option.value) {
                        option.hidden = false;
                        return;
                    }

                    const visible = !selectedGroup || option.dataset.groupeId === selectedGroup;
                    option.hidden = !visible;
                });

                const selected = brancheSelect.selectedOptions[0];
                if (selected && selected.value && selectedGroup && selected.dataset.groupeId !== selectedGroup) {
                    brancheSelect.value = '';
                }
            };

            const computeAnnualLabel = (yearValue) => {
                const year = Number.parseInt(yearValue, 10);
                if (!Number.isFinite(year)) {
                    return '';
                }

                return `${year}-${year + 1}`;
            };

            const syncYearLabel = () => {
                if (!libelleInput || !anneeInput || !isCreate) {
                    return;
                }

                const computed = computeAnnualLabel(anneeInput.value);
                if (!computed) {
                    return;
                }

                if (!libelleInput.value || libelleInput.value === lastAutoLabel) {
                    libelleInput.value = computed;
                }

                lastAutoLabel = computed;
            };

            const syncCotisationPreview = () => {
                if (!isCreate || !scoutSelect || !cotisationLabel || !anneeInput) {
                    return;
                }

                const selectedScout = scoutSelect.selectedOptions[0];
                const annualYear = Number.parseInt(anneeInput.value, 10);
                const isCurrentCotisation = selectedScout && selectedScout.dataset.cotisation === 'true' && annualYear === currentYear;
                cotisationLabel.textContent = isCurrentCotisation ? 'A jour' : 'Non a jour';
            };

            const syncScoutSnapshot = () => {
                if (!scoutSelect) {
                    return;
                }

                const selectedScout = scoutSelect.selectedOptions[0];
                if (!selectedScout || !selectedScout.value) {
                    groupeSelect.value = '';
                    syncBranches();
                    brancheSelect.value = '';
                    if (fonctionInput) {
                        fonctionInput.value = '';
                    }
                    syncCotisationPreview();
                    return;
                }

                groupeSelect.value = selectedScout.dataset.group || '';
                syncBranches();
                brancheSelect.value = selectedScout.dataset.branch || '';
                if (fonctionInput) {
                    fonctionInput.value = selectedScout.dataset.fonction || '';
                }
                syncCotisationPreview();
            };

            groupeSelect.addEventListener('change', syncBranches);
            syncBranches();

            if (scoutSelect) {
                scoutSelect.addEventListener('change', syncScoutSnapshot);
            }

            if (anneeInput) {
                anneeInput.addEventListener('input', () => {
                    syncYearLabel();
                    syncCotisationPreview();
                });
            }
        })();
    </script>
}


